ID = "st-afa.beta_federation"
Name = "[Beta] ST-AFA - Federation"
Version = "[Beta] 0.2.1"//look I always forget these so don't expect it to change :p
Author = "ST-AFA Mod-Team"
CompatibleGameVersions = ["0.30.0"]
ModifiesMultiplayer = true
Logo = logo.png
Description = "Adds STAR TREK stuff to the game \n\n"\
              "<red>WARNING: This mod is a WIP and a development mod. Some things might be really unbalanced or broken!</red> \n\n"\
			  "- adds Weapons\n"\
			  "- adds Engines\n"\
			  "- adds Rooms\n"\
			  "- adds Energy (WarpCore)\n"\
			  "- adds shields\n"\
			  "Requires [Beta] ST-AFA-Core"
StringsFolder = "strings"


Actions:
&<adaptations.rules>/Adaptations

[
	//******************** FUNCTIONS ********************
	{
		Action = Overrides
		OverrideIn = "<./Data/ships/priorities.rules>"
		Overrides
		{
			CaptainsRoom_Supply = 10
			CaptainsRoom_Crew = 10
		}
	}
	{
		Action = Replace
		Replace = "<gui/menus.rules>/LogoShip"
		With = &<gui/menus.rules>/LogoShip
	}

	
	//******************** TUTORIALS ********************
	{
		Action = AddMany
		AddTo = "<codex/tutorials/tutorials.rules>/CodexPages"
		ManyToAdd = &<codex/tutorials/tutorials.rules>/CodexPages
	}	
	//******************** TECHS ********************
	{
		Action = AddMany
		AddTo = "<modes/career/techs.rules>/Techs"
		ManyToAdd = &<fed_tech.rules>/Techs
	}
	
	{
		Action = AddMany
		AddTo = "<modes/pvp/pvp_buildbattle/techs_buildbattle.rules>/Techs"
		ManyToAdd = &<bnb_tech.rules>/Techs
	}
	//******************** PARTS ********************
	{
		Action = AddMany
		AddTo = "<ships/terran/terran.rules>/terran/parts"
		ManyToAdd = &<parts/federation.rules>/Parts
	}
	//******************** Statuses ********************
	{
		Action = AddMany
		AddTo = "<statuses/statuses.rules>/Statuses"
		ManyToAdd = &<statuses/statuses.rules>/Statuses
	}
	//******************** SOUNDS ********************
//	{
//		Action = Overrides
//		OverrideIn = "<common_effects/common_effects.rules>"
//		Overrides = &<audio/audio.rules>/PhaseCannonDeploy
//	}
	//******************** RESOURCES ********************
	//******************** UI ********************
	{
		Action = AddMany
		AddTo = "<gui/game/parts/part_toggles.rules>/PartToggles"
		ManyToAdd = &<gui/game/parts/part_toggles.rules>/PartToggles
	}

	{
		Action = Add
		AddTo = "<./Data/ships/base_ship.rules>/Blueprints/DrawProhibitedZoneCategories"
		ToAdd = phaserbank
	}

	{
		Action = Overrides
		OverrideIn = "<./Data/gui/game/indicators/indicators.rules>"
		Overrides = &<gui/game/indicators/indicators.rules>
	}
	{
		Action = AddMany
		AddTo = "<./Data/gui/game/parts/part_stats.rules>/PartStats"
		ManyToAdd
		[
			{
				ID = AntimatterPowerGen
				FormatKey = "Stats/AntimatterPowerGenFmt"
			}
		]
	}
	{
		Action = AddMany
		AddTo = "<./Data/gui/game/parts/part_stats.rules>/PartStats"
		ManyToAdd
		[
			{
				ID = BasePowerGen
				FormatKey = "Stats/BasePowerGenFmt"
			}
		]
	}
	{
		Action = AddMany
		AddTo = "<./Data/gui/game/parts/part_stats.rules>/PartStats"
		ManyToAdd
		[
			{
				ID = TransferRate
				FormatKey = "Stats/TransferRateFmt"
			}
		]
	}
	//Text Sprites
	{
		Action = Overrides
		OverrideIn = "<./Data/gui/text_sprites.rules>"
		Overrides
		{
			transphasic_torpedo_part
			{
				Texture
				{
					File = "images/transphasic_torpedo_part.png"
					MipLevels = max
					SampleMode = Linear
				}
				Size = [1, 1]
				ProportionalSize = true
			}
		}
	}
	{
		Action = Overrides
		OverrideIn = "<./Data/gui/text_sprites.rules>"
		Overrides
		{
			battery
			{
				Texture
				{
					File = "./Data/resources/battery/battery_small.png"
					MipLevels = max
					SampleMode = Linear
				}
				Size = [1, 1]
				ProportionalSize = true
			}
		}
	}
	//******************** BUFFS ********************
    {
		Action = Overrides
		OverrideIn = "<./Data/buffs/buffs.rules>"
		Overrides = &<buffs/buffs.rules>
	}
	//Ships
