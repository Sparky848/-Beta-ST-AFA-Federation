ID = "stafa.fed_quantum_torpedo_shot"  // originals by kurim
Range = { BaseValue=320; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=360; }
IdealRange
[
	{ BaseValue=60; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=60; }
	{ BaseValue=320; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=360; }
]
IdealRadius = [5, 50]
Speed = { BaseValue=150; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=180; }

Components
{
	Physics
	{
		Type = CirclePhysics
		Radius = 0.3
		Density = 0.1
	}

	Homing
	{
		Type = TargetHoming
		TurnVelocity = 90d
		Delay = .1
		AvoidanceRaycastDistance = 250
		VelocityCompensation = 60%
	}

	Retarget
	{
		Type = SameShipRetarget
	}

	Acceleration
	{
		Type = Acceleration
		Acceleration = 90
	}

	NegativeAcceleration
	{
		Type = Acceleration
		Acceleration = [-90, 0]
		AccelerationOverTime = [0, .75]
		Direction = FrameOfReferenceVelocity
	}

	DeathByLifetime
	{
		Type = DeathByLifetime
		Lifetime = 10
		HasTarget = true
	}

	DeathByDistanceTraveled
	{
		Type = DeathByDistanceTraveled
		// Distance auto-computed from range.
		HasTarget = false
	}

	Targetable
	{
		Type = Targetable
		Health = 3600
		TargetCategory = "stafa_torpedo"
		OnDeath = &../Hit/HitOperational
	}
	
	DamagePool
	{
		Type = DamagePool
		Damage = 18000//15000
	}

	Hit
	{
		Type = PenetratingHit
		SourcePartCollisionDelay = 1.5/30
		Penetration = 8//6
		PenetrationSpeed = &~/Speed
		FactorEffectsWith = Targetable

		//CrewCollisions = {Enemies=true; Junk=true}
		//HitCrew = &HitOperational

		HitShield
		{
			ReduceEffectsByPenetration = true

			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 17000//20000//25000
					Radius = 2
					Slices = 1
				}
				{
					Type = Impulse
					Impulse = 100
				}
			]

			MediaEffects = &../HitOperational/MediaEffects
		}
		HitOperational
		{
			ReduceEffectsByPenetration = true
			Offset = [-0.15, 0]

			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 19000//22000//16000
					DamagePool = DamagePool
					Radius = 5
					StatusType = cosmoteer.fire
					StatusChancePerNDamage = 50%
					StatusValue = 1
					StatusValueType = Interpolated
					NDamage = 1500
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 13000//19000//25000//10000
					Radius = 3
					Slices = 1
					Filter
					{
						OnlyPartCategories = [armor]
					}
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 28500//32500
					Radius = 2
					Slices = 1
					Filter
					{
						OnlyPartCategories = [durarmour]
					}
				}
				{
					Type = Impulse;
					Impulse = 70;//100
				}
			]

			MediaEffects
			[
				&<particles/quantum_torpedo_hit.rules>
				&<particles/quantum_torpedo_flash.rules>
				&<particles/quantum_torpedo_sparks.rules>
				&<particles/quantum_torpedo_spikes.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "quantum_torpedo_hit.wav"
					Volume = .4
					SpeedVariation = .4
				}

				: /BASE_SHAKE
				{
					ShakeAmount = .03
					Duration = .3
				}
			]
		}
		HitStructural
		{
			ReduceEffectsByPenetration = true
			
			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 17500//{ BaseValue=4000; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=10000; }
					Radius = 2
				}
				{
					Type = Impulse;
					Impulse = 24;
				}
			]

			MediaEffects
			[
				&<particles/quantum_torpedo_hit_struct.rules>
				&<particles/quantum_torpedo_flash.rules>
				&<particles/quantum_torpedo_sparks_struct.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "quantum_torpedo_hit.wav"
					Volume = .3
					SpeedVariation = .4
				}
			]
		}
		PenetratingOperational
		{
			ReduceEffectsByPenetration = true

			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 500//10000//12500//{ BaseValue=6000; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=10000; }
					DamagePool = DamagePool
					DoPooledDamageFirst = true
					Radius = 4//3
					StatusType = cosmoteer.fire
					StatusChancePerNDamage = 50%
					StatusValue = 1
					StatusValueType = Interpolated
					NDamage = 750
				}
				{
					Type = Impulse
					Impulse = 100
				}
			]
		}
		PenetratingStructural
		{
			// No effect.
		}
		FinishedPenetratingOperational = &PenetratingOperational
		FinishedPenetratingStructural = &PenetratingStructural
	}

	Sprite
	{
		Type = AnimatedSprite
		ReduceScaleWith = Hit
		ReduceScaleExponent = 0.5
		Animation
		{
			AtlasSprite
			{
				Texture
				{
					File = "quantum_torpedo_shot.png"
					SampleMode = Linear
					MipLevels = max
				}
				Size = [3, 3]//[2, 2]
			}
			FrameCount = 8
			FrameSize = [128, 128]
			FramesPerRow = 2
			FramesPerSecond = 60
		}
	}

	GlowSprite
	{
		Type = Sprite
		RenderBucket = BulletUpper2
		Z = 0
		IsLight = true
		Sprite
		{
			Texture
			{
				File = "./Data/common_effects/particles/blob.png"
				MipLevels = max
				SampleMode = Linear
			}
			Size = [9, 9]//[6, 6]
			VertexColor = [72, 175, 225]//[119, 202, 225]
			TargetBlendMode = Add
			Shader = "./Data/common_effects/fancy_light.shader"
			_litReflectiveStrength = 24
			_litAdditiveStrength = 0.05
			_unlitAdditiveStrength = 0.25
		}
	}
	GlowSprite2
	{
		Type = AnimatedSprite
		RenderBucket = BulletUpper2
		Z = 0
		IsLight = true
		Offset = [0, 0]
		Animation
		{
			AtlasSprite
			{
				Texture
				{
					File = "bullet_large_oc_light.png"
					MipLevels = max
					SampleMode = Linear
				}
				Size = [27.3, 27.3] //[18.2, 18.2]
				//VertexColor = [255, 255, 255]
				TargetBlendMode = Add
				Shader = "./Data/common_effects/fancy_light.shader"
				_z = 1
				_nrmlStrengthLimit = 1
				_litReflectiveStrength = 24
				_litAdditiveStrength = 0
				_unlitAdditiveStrength = 1
			}
		FrameCount = 16
		FrameSize = [512, 512]
		FramesPerRow = 4
		FramesPerSecond = 120
		}
	}
}