ID = "stafa.fed_photon_torpedo_shot_standard"  // originals by kurim
Range = { BaseValue=260; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=300; }
IdealRange
[
	{ BaseValue=60; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=60; }
	{ BaseValue=260; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=300; }
]
IdealRadius = [5, 50]
Speed = { BaseValue=35; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=40; }
SourceShipLowCollisions = false
Components
{
	Physics
	{
		Type = CirclePhysics
		Radius = 0.3
		Density = 0.1
	}

	Homing
	{
		Type = TargetHoming
		TurnVelocity = 180d
		Delay = .1
		AvoidanceRaycastDistance = 250
		VelocityCompensation = 60%
	}

	Retarget
	{
		Type = SameShipRetarget
	}

	Acceleration
	{
		Type = Acceleration
		Acceleration = 45
	}

	NegativeAcceleration
	{
		Type = Acceleration
		Acceleration = [-90, 0]
		AccelerationOverTime = [0, .75]
		Direction = FrameOfReferenceVelocity
	}

	DeathByLifetime
	{
		Type = DeathByLifetime
		Lifetime = 15
		HasTarget = true
	}

	DeathByDistanceTraveled
	{
		Type = DeathByDistanceTraveled
		// Distance auto-computed from range.
		HasTarget = false
	}

	Targetable
	{
		Type = Targetable
		Health = 400
		TargetCategory = "stafa_torpedo"
		OnDeath = &../Hit/HitOperational
	}

	Hit
	{
		Type = SimpleHit
		SourcePartCollisionDelay = 1.5/30
		FactorEffectsWith = Targetable
		SourceShipLowCollisions = false
		FriendlyShipLowCollisions = false
		CrewCollisions = {Enemies=true; Junk=true}
		HitCrew = &HitOperational

		HitShield
		{
			HitEffects
			[
				: ../../HitOperational/HitEffects/0
				{
					Amount = 3500
					TreatShieldAsPart = true
				}
			]

			MediaEffects = &../HitOperational/MediaEffects
		}
		HitOperational
		{
			Offset = [-0.15, 0]

			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 9000
					Radius = 2
					Slices = 1
				}
				{
					Type = Impulse;
					Impulse = 15;
				}
			]

			MediaEffects
			[
				&<particles/photon_torpedo_hit.rules>
				&<particles/photon_torpedo_flash.rules>
				&<particles/photon_torpedo_sparks.rules>
				&<particles/photon_torpedo_spikes.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "photon_torpedo_hit.wav"
					Volume = .4
					SpeedVariation = .4
				}

				: /BASE_SHAKE
				{
					ShakeAmount = .03
					Duration = .3
				}
			]
		}
		HitStructural
		{
			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 1500
					Radius = 2
				}
				{
					Type = Impulse;
					Impulse = 1.5;
				}
			]

			MediaEffects
			[
				&<particles/photon_torpedo_hit_struct.rules>
				&<particles/photon_torpedo_flash.rules>
				&<particles/photon_torpedo_sparks_struct.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "photon_torpedo_hit.wav"
					Volume = .3
					SpeedVariation = .4
				}
			]
		}
		PenetratingOperational
		{
			// No effect.
		}
		PenetratingStructural
		{
			// No effect.
		}
		FinishedPenetratingOperational
		{
			// No effect.
		}
		FinishedPenetratingStructural
		{
			// No effect.
		}
	}

	Sprite
	{
		Type = AnimatedSprite
		ReduceScaleWith = Hit
		ReduceScaleExponent = 0.5
		Animation
		{
			AtlasSprite
			{
				Texture
				{
					File = "photon_torpedo_shot.png"
					SampleMode = Linear
					MipLevels = max
				}
				Size = [2, 2]
			}
			FrameCount = 8
			FrameSize = [128, 128]
			FramesPerRow = 2
			FramesPerSecond = 60
		}
	}

	GlowSprite
	{
		Type = Sprite
		RenderBucket = BulletUpper2
		Z = 0
		IsLight = true
		Sprite
		{
			Texture
			{
				File = "./Data/common_effects/particles/blob.png"
				MipLevels = max
				SampleMode = Linear
			}
			Size = [6, 6]
			VertexColor = [255, 0, 0]
			TargetBlendMode = Add
			Shader = "./Data/common_effects/fancy_light.shader"
			_litReflectiveStrength = 24
			_litAdditiveStrength = 0.05
			_unlitAdditiveStrength = 0.25
		}
	}
	GlowSprite2
	{
		Type = AnimatedSprite
		RenderBucket = BulletUpper2
		Z = 0
		IsLight = true
		Offset = [0, 0]
		Animation
		{
			AtlasSprite
			{
				Texture
				{
					File = "bullet_large_oc_light.png"
					MipLevels = max
					SampleMode = Linear
				}
				Size = [9.1, 9.1]
				//VertexColor = [255, 255, 255]
				TargetBlendMode = Add
				Shader = "./Data/common_effects/fancy_light.shader"
				_z = 1
				_nrmlStrengthLimit = 1
				_litReflectiveStrength = 24
				_litAdditiveStrength = 0
				_unlitAdditiveStrength = 1
			}
		FrameCount = 16
		FrameSize = [512, 512]
		FramesPerRow = 4
		FramesPerSecond = 120
		}
	}
}