ID = "stafa.fed_heavy_dual_phaser_bolt"
Range = { BaseValue=340; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=380; }
IdealRange
[
	{ BaseValue=60; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=160; }
	{ BaseValue=320; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=380; }
]
IdealRadius = [5, 50]
Speed = { BaseValue=190; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=200; }

Components
{
	Physics
	{
		Type = CirclePhysics
		Radius = 0.25
		Density = 0.6
	}

	DeathByLifetime
	{
		Type = DeathByLifetime
		// Lifetime will be auto-calculated based on range and speed.
	}

	Targetable
	{
		Type = Targetable
		Health = 850
		TargetCategory = "laser"
	}

	DamagePool
	{
		Type = DamagePool
		Damage = 1500
	}

	Hit
	{
		Type = PenetratingHit
		SourcePartCollisionDelay = 1.5/30
		Penetration = 8
		PenetrationSpeed = (&~/Speed/BaseValue) * 1.25
		FactorEffectsWith = Targetable
		SourceShipLowCollisions = true
		HitCrew = &HitOperational

		HitShield
		{
			HitEffects
			[
				: ../../HitOperational/HitEffects/0
				{
					Amount = 5000
					TreatShieldAsPart = true
				}
			]
			MediaEffects = &../HitOperational/MediaEffects
		}
		HitOperational
		{
			Offset = [-0.15, 0]

			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 2000
					//DamagePool = DamagePool
					Radius = 2
				}
				{
					Type = Damage
					Damage = 2500
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 1750
					Radius = 3
					Filter
					{
						OnlyPartCategories = [armor, durarmour]
					}
				}
				{
					Type = GridStatusApplication
					StatusType = cosmoteer.heat
					HitPartSourceRectType = Normal
					StatusValue = 0
					StatusValuePool
					{
						BaseValue = 250
						EffectScaleExponent = 1
					}
					MaxCost = 2
					EmptyTileCost = Infinity
					ValueFalloff = 1
					FalloffPadding = 1
				}
				{
					Type = Impulse;
					Impulse = 30;
				}
			]
			MediaEffectsScale = 1.5
			MediaEffects
			[
				&<particles/phaser_bolt_small_hit.rules>
				&<particles/phaser_bolt_small_flash.rules>
				&<particles/phaser_bolt_small_sparks.rules>
				&<particles/phaser_bolt_small_spikes.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "heavy_dual_phaser_bolt.wav"
					Volume = .3
					SpeedVariation = 0
				}

				: /BASE_SHAKE
				{
					ShakeAmount = .1
					Duration = .6
				}
			]
		}
		HitStructural
		{
			HitEffects
			[
				{
					Type = Damage
					Damage = (&~/Components/Hit/HitOperational/HitEffects/1/Damage) / 2
				}
				{
					Type = Impulse;
					Impulse = 6;
				}
			]
			
			MediaEffects
			[
				&<particles/phaser_bolt_small_hit_struct.rules>
				&<particles/phaser_bolt_small_flash.rules>
				&<particles/phaser_bolt_small_sparks_struct.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "heavy_dual_phaser_bolt.wav"
					Volume = .3
					SpeedVariation = 0
				}
			]
		}
		PenetratingOperational
		{
			// No effect.
		}
		PenetratingStructural
		{
			// No effect.
		}
		FinishedPenetratingOperational
		{
			HitEffects
			[
				/*{
					Type = ExplosiveDamage
					TotalDamage = 1000
					Radius = 2
				}*///test with lightning or other fancy things
				{
					Type = GridStatusApplication
					StatusType = cosmoteer.fire
					HitPartSourceRectType = Normal
					StatusValue = 0
					StatusValuePool
					{
						BaseValue = 50
						EffectScaleExponent = 1
					}
					MaxCost = 2
					EmptyTileCost = Infinity
					ValueFalloff = 0.5
					FalloffPadding = 1
				}
			]
		}
		FinishedPenetratingStructural
		{
			// No effect.
		}
	}

	Sprite
	{
		Type = Sprite
		ReduceScaleWith = Hit
		ReduceScaleExponent = 0.2
		Sprite
		{
			Texture
			{
				File = "heavy_dual_phaser_bolt.png"
				SampleMode = Linear
				MipLevels = max
			}
			Size = [6, 6]
		}
	}

	GlowSprite
	{
		Type = Sprite
		RenderBucket = BulletUpper4
		Z = 0
		IsLight = true
		Sprite
		{
			Texture
			{
				File = "./Data/common_effects/particles/blob.png"
				MipLevels = max
				SampleMode = Linear
			}
			Size = [4, 4]
			VertexColor = [255, 147, 15]
			TargetBlendMode = Add
			Shader = "./Data/common_effects/fancy_light.shader"
			_litReflectiveStrength = 24
			_litAdditiveStrength = 0.05
			_unlitAdditiveStrength = 0.25
		}
	}
	MediaEffects
	{
		Type = MediaEffects
		MediaEffectsScale = 1
		Offset = [2, 0]
		MediaEffects
		[
			&<particles/bullet_trail_railgun.rules>
		]
	}
	MediaEffects2
	{
		Type = MediaEffects
		MediaEffectsScale = 1
		Offset = [2, 0]
		MediaEffects
		[
			&<particles/bullet_trail_deck.rules>
		]
	}
}