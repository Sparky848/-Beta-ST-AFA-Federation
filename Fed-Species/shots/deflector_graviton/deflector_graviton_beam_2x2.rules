ID = "stafa.fed_deflector_graviton_beam_2x2"
Range = { BaseValue=280; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=320; }
IdealRange
[
	{ BaseValue=180; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=200; }
	{ BaseValue=280; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=320; }
]
Duration = 4
HitInterval = .1
Width = 1
SourceShipLowCollisions = false
ReceivableBuffs = [PhaserMainDebuff, CaptainsRoomBuff]
BeamMediaEffects
[
	// The beam itself.
	/*{
		Type = Beam
		BeamSprite
		{
			Texture
			{
				File = ./Data/common_effects/particles/noise_gradient.png
				SampleMode = Linear
				MipLevels = max
				UVMode = Wrap
			}
			Texture2
			{
				File = ./Data/common_effects/particles/spark.png
				SampleMode = Linear
				MipLevels = max
				UVMode = Wrap
			}
			_noiseTexture
			{
				File = ../../common_effects/particles/line_test1.png
				MipLevels = max
				SampleMode = Linear
				UVMode = Wrap
			}
			Shader = "./Data/shots/ion_beam/ion_beam.shader"
			_gradientPow = 0.35
			_sineFreq = 2.5
			_sineAmp = 0.03
			_noiseAmp = 0.12
			_gradientIntensity = 3
			_endCapSize = .125
			Size = [100%, 3.5]
			VertexColor = [0, 253, 178, 217]
			_baseColor = [0, 0.992156862745, 0.698039215686, 1]
			_halfHighlightColor = [0, 0.960784313725, 0.709803921569, 1]
			VertexColor = [79, 253, 178, 217]
			_baseColor = [0.309803921569, 0.992156862745, 0.698039215686, 1]
			_halfHighlightColor = [0.380392156863, 0.960784313725, 0.709803921569, 1]

			TargetBlendMode
			{
				SourceRgbFactor = SourceAlpha
				DestRgbFactor = One
				RgbOperator = Add
				SourceAlphaFactor = One
				DestAlphaFactor = One
				AlphaOperator = Add
			}
		}
		FadeInTime = .25
		FadeOutTime = .25
		RandomTimeOffset = [0, 1]
		Bucket = Lower1
	}*/
	{
        Type = Beam
        Sprite
        {
            _displacementStrength = 4
            _displacementSpeed = .08
            Texture
            {
                File = beam.png
                SampleMode = Linear
                MipLevels = max
                UVMode = Wrap
            }
            _noiseTexture
            {
                File = beam_noise.png
                MipLevels = max
                SampleMode = Linear
                UVMode = Wrap
            }
            Shader = "./Data/shots/ion_beam/ion_beam.shader"
            _extraBeginLength = 0
            _extraEndLength = 0.25
            _sizePulseFactor = 1.2
            _sizePulseInterval = .1
            _sizePulseUOffsetFactor = -.03
            _endCapSize = 4
            Size = [100%, 2]
            VertexColor = [255, 255, 255, 150]
            _baseColor = [0, 0.992156862745, 0.698039215686, 1]
			_halfHighlightColor = [0, 0.496078431373, 0.354901960785, 1]
            TargetBlendMode
            {
                SourceRgbFactor = InverseDestColor
                DestRgbFactor = One
                RgbOperator = Add
                SourceAlphaFactor = One
                DestAlphaFactor = One
                AlphaOperator = Add
            }
        }
        FadeInTime = .25
        FadeOutTime = .25
        RandomTimeOffset = [0, 1]
        Bucket = Lower1
    }
	&<particles/phaser_beam_emit_sparks.rules>
	&<particles/phaser_beam_hit.rules>
	&<particles/phaser_beam_hit_flash.rules>
	// Beam lighting.
	{
		Type = Beam
		BeamSprite
		{
			Texture
			{
				File = "beam.png"
				MipLevels = max
				SampleMode = Linear
			}
			Shader = "./Data/common_effects/fancy_beam_light.shader"
			Size = [100%, 5]
			_extraBeginLength = (&Size/1) / 2
			_extraEndLength = (&Size/1) / 2
			VertexColor = [0, 253, 178, 217]//[79, 253, 178, 217]
			_z = 0.1
			_litReflectiveStrength = 8
			_litAdditiveStrength = 0
			_unlitAdditiveStrength = 0.25
			_nrmlStrengthLimit = 0.2
			TargetBlendMode
			{
				SourceRgbFactor = InverseDestColor
				DestRgbFactor = One
				RgbOperator = Add
				SourceAlphaFactor = Zero
				DestAlphaFactor = One
				AlphaOperator = Add
			}
		}
		Bucket = Lower1
		IsLight = true
		FadeInTime = .5
		FadeOutTime = .1
	}

	: /BASE_SOUNDS/AudioExterior
	{
		Sound = "light_phasor_beam.wav"
		Volume = 1
		Speed = 1
		MaxConcurrent = 1
		RampUpTime = .5
		RampDownTime = .5

		DynamicVolume : ^/0/DynamicVolume
		{
			UseCustomShapeForDistance = true
		}
		DynamicFilter : ^/0/DynamicFilter
		{
			UseCustomShapeForDistance = true
		}
	}

]
HitShield
{
	HitEffects
	[
		{
			Type = Impulse
			Impulse = 800
		}
	]
}
HitOperational
{
	HitEffects
	[
		{
			Type = Impulse
			Impulse = 1250//3000
		}
		{
			Type = Impulse
			Impulse = 100000
			Filter
			{
				Asteroids = true
				Ships = false
			}
		}
	]
	Media
	MediaEffects
	[
		/*&<tractor_beam_glints.rules>
		&<../phaser_bolt_deck/particles2/disruptor_bolt_hit_lightning.rules>
		&<../phaser_bolt_deck/particles2/disruptor_bolt_hit_orb.rules>
		&<../phaser_bolt_deck/particles2/disruptor_bolt_hit_bolts.rules>
		&<../phaser_bolt_deck/particles2/disruptor_bolt_flash.rules>*/
		: /BASE_SOUNDS/AudioExterior
		{
			Sound = "tractor_beam.wav"
			Volume = 1
			SpeedVariation = .15
		}

		: /BASE_SHAKE
		{
			ShakeAmount = .03
			Duration = .3
		}
	]
}
HitStructural = &HitOperational