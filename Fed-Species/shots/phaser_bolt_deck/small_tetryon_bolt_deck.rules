BASE = &<phaser_bolt_deck.rules>

SPEED = (&BASE/Speed/BaseValue) + 40
RANGE = (&BASE/Range/BaseValue) + 50
TOTAL_DRAIN = 3500
TOTAL_SHIELD_DRAIN = 3500
DRAIN_DURATION = 8

DRAIN_PER_SECOND = (&TOTAL_DRAIN) / (&DRAIN_DURATION)
SHIELD_DRAIN_PER_SECOND = (&TOTAL_SHIELD_DRAIN) / (&DRAIN_DURATION)


Bullet : BASE
{
	ID = "stafa.fed_small_tetryon_bolt_deck"
	OtherIDs = ["small_tetryon_bolt_deck"]
	Range = &~/RANGE
	IdealRange = [&../^/0/IdealRange/0, &~/RANGE]
	Speed = &~/SPEED
	//SourceShipLowCollisions = false
	Components : ^/0/Components
	{
		Hit : ^/0/Hit
		{
			PenetratesOperational = false
			HitShield : ^/0/HitShield
			{
				HitEffects
				[
					: ../../HitOperational/HitEffects/0
					{
						Amount = 5000
						StatusValue = { BaseValue = (&~/SHIELD_DRAIN_PER_SECOND) / 1000; EffectScaleExponent = 1 }
					}
					{
						Type = StatusApplication
						StatusType = cosmoteer.disruptor_drain
						StatusDuration = &~/DRAIN_DURATION
						StatusValue = { BaseValue = (&~/DRAIN_PER_SECOND) / 1000; EffectScaleExponent = 1 }
					}
				]
				MediaEffects
				[
					&<particles2/disruptor_bolt_hit_lightning.rules>
					&<particles2/disruptor_bolt_hit_orb.rules>
					&<particles2/disruptor_bolt_hit_bolts.rules>
					&<particles2/disruptor_bolt_flash.rules>
					: /BASE_SOUNDS/AudioExterior
					{
						Sound = "disruptor_bolt_hit.wav"
						Volume = .4
						SpeedVariation = .4
					}
				]
			}
			HitOperational : ^/0/HitOperational
			{
				HitEffects : ^/0/HitEffects
				[
					{
						Type = StatusApplication
						StatusType = cosmoteer.disruptor_drain
						StatusDuration = &~/DRAIN_DURATION
						StatusValue = { BaseValue = (&~/DRAIN_PER_SECOND) / 1000; EffectScaleExponent = 1 }
					}
				]
				MediaEffects
				[
					&<particles2/disruptor_bolt_hit_lightning.rules>
					&<particles2/disruptor_bolt_hit_orb.rules>
					&<particles2/disruptor_bolt_hit_bolts.rules>
					&<particles2/disruptor_bolt_flash.rules>
					: /BASE_SOUNDS/AudioExterior
					{
						Sound = "disruptor_bolt_hit.wav"
						Volume = .4
						SpeedVariation = .4
					}
				]
				
			}
			HitStructural : ^/0/HitStructural
			{
				MediaEffects
				[
					&<particles2/disruptor_bolt_hit_struct_lightning.rules>

					: /BASE_SOUNDS/AudioExterior
					{
						Sound = "disruptor_bolt_hit.wav"
						Volume = .3
						SpeedVariation = .4
					}
				]
			}
		}
		MediaEffects
		{
			Type = MediaEffects
			FactorEffectsWith = Hit
			FactorEffectsExponent = 0.5
			MediaEffects
			[
				&<particles2/disruptor_bolt_hit_lightning.rules>
				&<particles2/disruptor_bolt_hit_orb.rules>
				&<particles2/disruptor_bolt_hit_bolts.rules>
				&<particles2/disruptor_bolt_flash.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "disruptor_bolt_hit.wav"
					Volume = .4
					SpeedVariation = .4
				}
			]
		}
		Sprite
		{
			Type = Sprite
			ReduceScaleWith = Hit
			ReduceScaleExponent = 0.5
			Sprite
			{
				Texture
				{
					File = "small_tetryon_bolt_deck.png"
					SampleMode = Linear
					MipLevels = max
				}
				Size = [2, 2]
			}
		}

		GlowSprite
		{
			Type = Sprite
			RenderBucket = BulletUpper4
			Z = 0
			IsLight = true
			Sprite
			{
				Texture
				{
					File = "./Data/common_effects/particles/blob.png"
					MipLevels = max
					SampleMode = Linear
				}
				Size = [4, 4]
				VertexColor = [39, 185, 245]
				TargetBlendMode = Add
				Shader = "./Data/common_effects/fancy_light.shader"
				_litReflectiveStrength = 24
				_litAdditiveStrength = 0.05
				_unlitAdditiveStrength = 0.25
			}
		}
		MediaEffects2
		{
			Type = MediaEffects
			MediaEffectsScale = 1
			Offset = [-0.25, 0]
			MediaEffects
			[
				&<particles2/bullet_trail_railgun.rules>
			]
		}
		MediaEffects3
		{
			Type = MediaEffects
			MediaEffectsScale = 1
			Offset = [-0.25, 0]
			MediaEffects
			[
				&<particles2/bullet_trail_railgun2.rules>
			]
		}
	}
}