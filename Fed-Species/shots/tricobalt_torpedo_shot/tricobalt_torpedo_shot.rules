ID = "stafa.fed_tricobalt_torpedo_shot"  // originals by kurim
Range = &<tricobalt_stage1.rules>/Range/BaseValue
IdealRange = &<tricobalt_stage1.rules>/IdealRange/0/BaseValue
Speed = 0

Components
{
	Physics
	{
		Type = CirclePhysics
		Radius = 0.5
		Density = 0.1
	}
	
	Homing
	{
		Type = TargetHoming
		TurnVelocity = 40d//70d//140d
		Delay = .1
		AvoidanceRaycastDistance = 250
		VelocityCompensation = 30%//60%
	}

	Acceleration
	{
		Type = Acceleration
		Acceleration = 15//20
	}

	NegativeAcceleration
	{
		Type = Acceleration
		Acceleration = [-90, 0]
		AccelerationOverTime = [0, .75]
		Direction = FrameOfReferenceVelocity
	}

	DeathByLifetime
	{
		Type = DeathByLifetime
	}

	DeathByDistanceTraveledTargeted
	{
		Type = DeathByDistanceTraveled
		Distance = (&~/Range) * 3
	}

	Targetable = &<tricobalt_stage1.rules>/Components/Targetable
	Hit = &<tricobalt_stage1.rules>/Components/Hit

	Sprite = &<tricobalt_stage1.rules>/Components/Sprite
	GlowSprite = &<tricobalt_stage1.rules>/Components/GlowSprite
	GlowSprite2 = &<tricobalt_stage1.rules>/Components/GlowSprite2
}