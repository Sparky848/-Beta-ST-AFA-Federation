ID = "stafa.field_test"
// Irrelevant
Range = 0
Speed = 0


MODIFIABLE_DAMAGE
{
	Modifiers
	[
		{
			Type = Buff
			BuffType = ElectronBuff
			ModificationMode = Multiply
		}
		{
			Type = EffectScale
			ModificationMode = Multiply
		}
	]
}

Components
{
	Physics
	{
		Type = CirclePhysics
		Radius = 10
		Density = 1
		LinearDamping = 25%
	}
	FieldRepulsion
	{
		Type = ProximityAcceleration
		Range = 8
		Acceleration = -7
		AccelerateTowardsShips = false
		AccelerateTowardsBullets = true
		AccelerateTowardsBulletCategories = [field_test]
		AccelerateTowardsFriendlies = true
		AccelerateTowardsEnemies = false
	}
	Targetable
	{
		Type = Targetable
		// Shouldn't be hit by anything
		Health = 1
		TargetCategory = "field_test"
	}
	
	LifetimeDeath
	{
		Type = DeathByLifetime
		Lifetime = 7
	}
/*	DamagePoolDeath
	{
		Type = DeathByDamagePool
		DamagePool = DamagePool
	}*/
	
	DamagePool
	{
		Type = DamagePool
		Damage = 10000
	}
	
	VolHit
	{
		Type = VolumeHit
		BeamAttenuationDamagePool = DamagePool
		HitShield = &HitOperational
		HitNothing = &HitOperational
		HitBullet = &HitOperational
		HitOperational
		{
			HitEffects
			[
				{
					Type = Damage
					Damage = 1000
				}
				{
					Type = ChainLightning
					MaxChainLength = [1, 3]
					InitialRadius = 5
					ChainRadius = 2
					InitialChance = 100%
					InitialStrikes = [8, 16]
					InitialStrikeRandomOffsetRadius = 2
					RaycastInitialTargets = true
					ChainChance = 100%
					ChainStrikes = [8, 16]
					MaxInitialAngle = 360d
					MaxChainAngle = 360d
					ChainDelay = 0.02
					ChainEffectFalloff = 0.75
					StatusType = cosmoteer.fire
					StatusChancePerNDamage = 100%
					StatusValue = 1
					StatusValueType = Interpolated
					NDamage = 40
					HitEffects
					[
						{
							Type = Damage
							Damage : ~/MODIFIABLE_DAMAGE
							{
								BaseValue = 180
							}
							StatusType = cosmoteer.fire
							StatusChancePerNDamage = 100%
							StatusValue = 1
							StatusValueType = Interpolated
							NDamage = 40
							Filter
							{
								Self = true
								Friendlies = true
								Enemies = true
								Neutrals = true
								Junk = true
								Ships = true
								OperationalHealth = true
								StructuralHealth = true
								Shields = true
								Bullets = true
								Crew = true
								Nuggets = true
								IgnoreInvulnerability = true
							}
						}
					]
					MediaEffects
					[
						&<./Data/shots/ion_beam/particles/ion_beam_overclock_lightning_hit.rules>
						&<./Data/shots/ion_beam/particles/ion_beam_overclock_flash.rules>
						&<./Data/shots/ion_beam/particles/ion_beam_hit_sparks.rules>
					]
					ChainMediaEffects
					[
						&<./Data/shots/ion_beam/particles/ion_beam_overclock_lightning_chain.rules>
						&<./Data/shots/ion_beam/particles/ion_beam_overclock_flash.rules>
						&<./Data/shots/ion_beam/particles/ion_beam_hit_sparks.rules>
					]
					HitFilter
					{
						Self = true
						Friendlies = true
						Enemies = true
						Neutrals = true
						Junk = true
						Ships = true
						OperationalHealth = true
						StructuralHealth = true
						Shields = true
						Bullets = true
						Crew = true
						Nuggets = true
						IgnoreInvulnerability = true
					}
					ChainFilter
					{
						Self = true
						Friendlies = true
						Enemies = true
						Neutrals = true
						Junk = true
						Ships = true
						OperationalHealth = true
						StructuralHealth = true
						Shields = true
						Bullets = true
						Crew = true
						Nuggets = true
						IgnoreInvulnerability = true
					}
					InitialFilter
					{
						Self = true
						Friendlies = true
						Enemies = true
						Neutrals = true
						Junk = true
						Ships = true
						OperationalHealth = true
						StructuralHealth = true
						Shields = true
						Bullets = true
						Crew = true
						Nuggets = true
						IgnoreInvulnerability = true
					}
				}
			]
			MediaEffects
			[
				&<./Data/shots/flak_large/overclock/particles/sparks_field.rules>
			]
		}
	}
	
