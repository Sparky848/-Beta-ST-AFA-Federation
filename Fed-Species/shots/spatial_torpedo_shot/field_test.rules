	MediaEffects
	{
		Type = MediaEffects
		FactorEffectsWith = DamagePool
		MediaEffects
		[
			&<./Data/shots/flak_large/overclock/particles/flak_large_overclock_field_shrapnel.rules>
			&<./Data/shots/flak_large/overclock/particles/flak_large_overclock_field_right.rules>
			&<./Data/shots/flak_large/overclock/particles/flak_large_overclock_field_left.rules>
			
			: /BASE_SOUNDS/AudioExterior
				{
					Sound = "./Data/shots/flak_large/overclock/sounds/flak_cannon_overclocked_field.wav"
					Volume = 1
					SpeedVariation = .2
					MaxConcurrent = 2
					RampUpTime = .25
					RampDownTime = .5
				}
		]
	}
