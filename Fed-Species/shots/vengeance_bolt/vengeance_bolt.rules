ID = "stafa.fed_vengeance_bolt"
Range = { BaseValue=440; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=480; }
IdealRange
[
	{ BaseValue=160; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=260; }
	{ BaseValue=420; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=480; }
]
//IdealRadius = [5, 50]
Speed = { BaseValue=250; BuffType=CaptainsRoomBuff; BuffMode=Multiply; MaxValue=300; }

Components
{
	Physics
	{
		Type = BoxPhysics
		Size = [30, 1.5]
		Density = 1.2
	}

	DeathByLifetime
	{
		Type = DeathByLifetime
		// Lifetime will be auto-calculated based on range and speed.
	}

	Targetable
	{
		Type = Targetable
		Health = 900
		TargetCategory = "laser"
	}

	Hit
	{
		Type = PenetratingHit
		SourcePartCollisionDelay = 1.5/30
		Penetration = 1
		PartCategoryPenetrationFactors
		{
			armor = 10
			durarmour = 20
		}
		PenetrationSpeed = (&~/Speed/BaseValue) * 0.5
		FactorEffectsWith = Targetable
		SourceShipLowCollisions = false
	
		HitShield
		{
			Offset = [15, 0]
			HitEffects
			[
				: ../../HitOperational/HitEffects/0
				{
					Amount = 16000//8750
				}
			]
			MediaEffects = &../HitOperational/MediaEffects
		}
		HitOperational
		{
			Offset = [15, 0]

			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 9500
					//DamagePool = DamagePool
					Radius = 6
					ExpandDuration = 0.2
					ExpandLoss = 25%
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 25500
					Radius = 4
					Filter
					{
						OnlyPartCategories = [armor]
					}
					ExpandDuration = 0.2
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 47500
					Radius = 4
					Filter
					{
						OnlyPartCategories = [durarmour]
					}
					ExpandDuration = 0.2
				}
				{
					Type = Impulse;
					Impulse = 550;
				}
			]
			MediaEffectsScale = 1.5
			MediaEffects
			[
				&<particles/vengeance_bolt_hit.rules>
				&<particles/vengeance_bolt_flash.rules>
				&<particles/vengeance_bolt_sparks.rules>
				&<particles/vengeance_bolt_spikes.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "heavy_dual_phaser_bolt.wav"
					Volume = 1.2
					SpeedVariation = 1
				}

				: /BASE_SHAKE
				{
					ShakeAmount = 1
					Duration = 1.2
				}
			]
		}
		HitStructural
		{
			Offset = [15, 0]
			HitEffects
			[
				{
					Type = Damage
					Damage = (&~/Components/Hit/HitOperational/HitEffects/0/TotalDamage) / 2
				}
				{
					Type = Impulse;
					Impulse = 225;
				}
			]
			
			MediaEffects
			[
				&<particles/vengeance_bolt_hit_struct.rules>
				&<particles/vengeance_bolt_flash.rules>
				&<particles/vengeance_bolt_sparks_struct.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "heavy_dual_phaser_bolt.wav"
					Volume = 1.2
					SpeedVariation = 1
				}
			]
		}
		PenetratingOperational
		{
			// No effect.
		}
		PenetratingStructural
		{
			// No effect.
		}
		FinishedPenetratingOperational
		{
			// No effect.
		}
		FinishedPenetratingStructural
		{
			// No effect.
		}
	}

	Sprite
	{
		Type = AnimatedSprite
		ReduceScaleWith = Hit
		ReduceScaleExponent = 0.5
		Animation
		{
			AtlasSprite
			{
				Texture
				{
					File = "vengeance_shot.png"
					SampleMode = Linear
					MipLevels = max
				}
				Size = [40, 3]
			}
			FrameCount = 8
			FrameSize = [192, 128]
			FramesPerRow = 2
			FramesPerSecond = 60
		}
	}

	GlowSprite
	{
		Type = Sprite
		RenderBucket = BulletLower1
		Z = 0
		IsLight = true
		Sprite
		{
			Texture
			{
				File = "./Data/common_effects/particles/blob.png"
				MipLevels = max
				SampleMode = Linear
			}
			Size = [80, 6]
			VertexColor = [155, 0, 0]
			TargetBlendMode = Add
			Shader = "./Data/common_effects/fancy_light.shader"
			_litReflectiveStrength = 24
			_litAdditiveStrength = 0.05
			_unlitAdditiveStrength = 0.25
		}
	}
}