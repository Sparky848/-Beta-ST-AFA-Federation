Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/BulkAntimatterCrafter"
	IconNameKey = "Parts/BulkAntimatterCrafterIcon"
	ID = stafa.bulk_antimatter_crafter // Part IDs must always be in the form of "author_name.part_name". If making your own mod, do *not* use "cosmoteer" as your author name, because it may conflict with future vanilla parts.
	EditorGroup = "StarfleetProduction"
	DescriptionKey = "Parts/BulkAntimatterCrafterDesc"
	Resources
	[
		[steel, 248]
		[coil, 48]
		[coil2, 32]
		[tristeel, 48]
		[processor, 5]
	]
	Size = [6, 5]
	SelectionPriority = 1
	MaxHealth = 8000
	TypeCategories = [provides_antimatter, uses_hyperium, uses_power, uses_dilithium]
	ReceivableBuffs : ^/0/ReceivableBuffs []
	AllowedDoorLocations
	[
		[-1, 3]
		[-1, 4]
		[0, 5]
		[1, 5]
		[2, 5]
		[3, 5]
		[4, 5]
		[5, 5]
		[6, 3]
		[6, 4]
	]
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [53.33, 64]
	}
	Components : ^/0/Components
	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, BatteryStorage]
			Mode = All
		}

		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = false
		}

		CommandConsumer
		{
			Type = CommandConsumer
			OperationalToggle = PowerToggle
			CommandPoints = 1
		}

		HyperiumStorage
		{
			Type = TypedResourceGrid
			ResourceType = hyperium
			GridRect = [2, 3, 1, 2]
			Layer = "doodads_low"
			ToggleOnResources = 1
			ToggleOffResources = 0
			SpriteInset = [17/64, 9/64, 5/64, 5/64]
			AllowExternalPickupAndDelivery = true
		}
		HyperiumConsumer
		{
			Type = ResourceConsumer
			ResourceType = hyperium
			Storage = HyperiumStorage
			DefaultPriority = &/PRIORITIES/Factory_Supply
			OperationalToggle = PowerToggle
			ConsumptionToggleButtonOffset = [0, -.4]
		}
		DilithiumStorage
		{
			Type = TypedResourceGrid
			ResourceType = dilithium
			GridRect = [3, 3, 1, 2]
			Layer = "doodads_low"
			ToggleOnResources = 1
			ToggleOffResources = 0
			SpriteInset = [17/64, 9/64, 5/64, 5/64]
			AllowExternalPickupAndDelivery = true
		}
		DilithiumConsumer
		{
			Type = ResourceConsumer
			ResourceType = dilithium
			Storage = DilithiumStorage
			DefaultPriority = &/PRIORITIES/Factory_Supply
			OperationalToggle = PowerToggle
			ConsumptionToggleButtonOffset = [0, -.4]
		}

		AntimatterStorage
		{
			Type = TypedResourceGrid
			ResourceType = antimatter
			GridRect = [0, 3, 2, 2]
			Layer = "doodads_low"
			SpriteInset = [8/64, 3/64, 8/64, 12/64]
			SuppliesResources = true
			SupplyToggleButtonOffset = [0, -.4]
			RandomSpriteRotation = true
			InitToMaxResources = 0
		}
		AntimatterStorage2
		{
			Type = TypedResourceGrid
			ResourceType = antimatter
			GridRect = [4, 3, 2, 2]
			Layer = "doodads_low"
			SpriteInset = [8/64, 3/64, 8/64, 12/64]
			SuppliesResources = true
			SupplyToggleButtonOffset = [0, -.4]
			RandomSpriteRotation = true
			InitToMaxResources = 0
		}

		BatteryStorage
		{
			Type = ResourceStorage
			ResourceType = battery
			MaxResources = 13000
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		BatteryConsumer
		{
			Type = ResourceConsumer
			ResourceType = battery
			Storage = BatteryStorage
			DefaultPriority = &/PRIORITIES/Factory_Supply
			ResupplyThreshold = 500
			OperationalToggle = PowerToggle
		}

		HyperiumResourceConverter
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			From
			[
			    {
			        Storage = HyperiumStorage
			        Quantity = 1
			    }
			]
			ToStorage = FakeResourceStorage
			ToQuantity = 1
			Interval = 0.1
			CheckResourceLimits = true
		}
		DilithiumResourceConverter
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			From
			[
			    {
			        Storage = DilithiumStorage
			        Quantity = 1
			    }
			]
			ToStorage = FakeResourceStorage
			ToQuantity = 20
			Interval = 0.1
			CheckResourceLimits = true
		}
		InternalAntimatterResourceConverter
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			From
			[
			    {
			        Storage = FakeResourceStorage
			        Quantity = 40
			    }
				{
			        Storage = BatteryStorage
			        Quantity = 2000
			    }
			]
			ToStorage = FakeResourceStorage2
			ToQuantity = 20
			Interval = 5
			CheckResourceLimits = true
		}
		InternalAntimatterResourceConverter2
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			From
			[
			    {
			        Storage = FakeResourceStorage
			        Quantity = 40
			    }
				{
			        Storage = BatteryStorage
			        Quantity = 2000
			    }
			]
			ToStorage = FakeResourceStorage2
			ToQuantity = 20
			Interval = 5
			CheckResourceLimits = true
		}
		FakeResourceStorage
		{
			Type = ResourceStorage
