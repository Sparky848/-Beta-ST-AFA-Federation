Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/Hull_Polariser_Med"
	IconNameKey = "Parts/Hull_Polariser_MedIcon"
	ID = stafa.fed_hull_polariser_med
	EditorGroup = "StarfleetDefences"
	DescriptionKey = "Parts/Hull_Polariser_MedDesc"
	Resources
	[
		[steel, 68]
		[coil, 16]
		[coil2, 4]
		[tristeel, 10]
	]
	AIValueFactor = 175
	Size = [3, 2]
	SelectionTypeID = "hull_polariser"
	MaxHealth = 4500
	TypeCategories = [hull_polariser, uses_power, is_crewed]
	CrewSpeedFactor = .5
	Density = 2
	AllowedDoorLocations
	[
		[-1, 1]
		[0, 2]
		[1, 2]
		[2, 2]
		[3, 1]
	]
	ReceivableBuffs : ^/0/ReceivableBuffs []
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [72, 42]
	}
	Components : ^/0/Components
	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, PartCrew, BatteryStorage, ScorchedToggle]
			Mode = All
		}

		CommandConsumptionToggle
		{
			Type = MultiToggle
			Toggles = [PowerToggle, ScorchedToggle]
			Mode = All
		}

		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = false
		}

		ScorchedToggle
		{
			Type = StatusToggle
			StatusType = cosmoteer.scorched
			MinStatusValue = 1
			Invert = true
		}

		CommandConsumer
		{
			Type = CommandConsumer
			OperationalToggle = CommandConsumptionToggle
			CommandPoints = 5
		}

		PolariserBuffProvider
		{
			Type = CircleBuffProvider
			BuffType = HullPolariser
			BuffAmount = 12.5%
			BuffRadius = 45
			OperationalToggle = IsOperational
			//BuffCenter = [1.5, 1]
		}
		BatteryStorage
		{
			Type = ResourceStorage
			ResourceType = battery
			MaxResources = 6000
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		BatteryConsumer
		{
			Type = ResourceConsumer
			ResourceType = battery
			Storage = BatteryStorage
			DefaultPriority = &/PRIORITIES/Defense_Supply
			ResupplyThreshold = 500
			OperationalToggle = CommandConsumptionToggle
		}
		PowerDrain
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			FromStorage = BatteryStorage
			FromQuantity = 100
			MinFromQuantityForConversion = 1
			Interval = 0.66666
		}

		Graphics
		{
			Type = Graphics
			Location = [1.5, 1]
			Floor 
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [3, 2]
					}
					{
						File = "floor_33.png"
						Size = [3, 2]
					}
					{
						File = "floor_66.png"
						Size = [3, 2]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				DamageLevels
				[
					{
						File = "wall.png"
						Size = [3, 2]
					}
					{
						File = "wall_33.png"
						Size = [3, 2]
					}
					{
						File = "wall_66.png"
						Size = [3, 2]
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [3, 2]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [3, 2]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [3, 2]
					}
				]
			}
			OperationalDoodad
			{
				Layer = "doodads_low"
				DamageLevels
				[
					{
						AnimationFiles
						[
							"floor_glow1.png"
							"floor_glow2.png"
							"floor_glow3.png"
							"floor_glow4.png"
							"floor_glow5.png"
							"floor_glow6.png"
						]
						Size = [3, 2]
						AnimationInterval = 0.1
						AnimationStartTime = Zero
					}
					{
						AnimationFiles
						[
							"floor_glow_33_1.png"
							"floor_glow_33_2.png"
							"floor_glow_33_3.png"
							"floor_glow_33_4.png"
							"floor_glow_33_5.png"
							"floor_glow_33_6.png"
						]
						Size = [3, 2]
						AnimationInterval = 0.1
						AnimationStartTime = Zero
					}
					{
						AnimationFiles
						[
							"floor_glow_66_1.png"
							"floor_glow_66_2.png"
							"floor_glow_66_3.png"
							"floor_glow_66_4.png"
							"floor_glow_66_5.png"
							"floor_glow_66_6.png"
						]
						Size = [3, 2]
						AnimationInterval = 0.1
						AnimationStartTime = Zero
					}
				]
			}
		}
		BatterySprites
		{
			Type = ResourceSprites
			Location = [1.5, 1]
			ResourceStorage = BatteryStorage
			Layer = "doodads_high"
			ResourceLevels
			[
				{
					File = "batteries1.png"
					Size = [3, 2]
				}
				{
					File = "batteries2.png"
					Size = [3, 2]
				}
				{
					File = "batteries3.png"
					Size = [3, 2]
				}
				{
					File = "batteries4.png"
					Size = [3, 2]
				}
				{
					File = "batteries5.png"
					Size = [3, 2]
				}
				{
					File = "batteries6.png"
					Size = [3, 2]
				}
			]
		}
		CrewLocation1
		{
			Type = CrewLocation
			Location = [0.890625, 1.484375]
			Rotation = 0d
		}
		CrewLocation2
		{
			Type = CrewLocation
			Location = [2.125, 1.484375]
			Rotation = 0d
		}
		PartCrew
		{
			Type = PartCrew
			Crew = 2
			DefaultPriority = &/PRIORITIES/Weapon_Crew
			PrerequisitesBeforeCrewing = [PowerToggle]
			HighPriorityPrerequisites = [BatteryStorage]
			CrewDestinations
			[
				&../../CrewLocation1/Location
				&../../CrewLocation2/Location
			]
			CrewLocations
			[
				CrewLocation1
				CrewLocation2
			]
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/MedPartDestroyedDry
			Location = [1.5, 1]
			HitEffects
			[
				{
					Type = ExplosiveResourceDrain
					ResourceType = battery
					Radius = 6
					TotalDrain = 22500
					Slices = 1
					MediaEffectsOnDrainFactor = .0005
					MediaEffectsOnDrain
					[
						&<./Data/shots/missile_emp/particles/missile_emp_hit_sizzle.rules>
						&<./Data/shots/missile_emp/particles/missile_emp_lightning.rules>
						&<./Data/shots/missile_emp/particles/missile_emp_drain.rules>

						: /BASE_SOUNDS/AudioExterior
						{
							RandomSounds = ["./Data/shots/disruptor_bolt/sounds/disruptor_discharge_01.wav",
											"./Data/shots/disruptor_bolt/sounds/disruptor_discharge_02.wav",
											"./Data/shots/disruptor_bolt/sounds/disruptor_discharge_03.wav",
											"./Data/shots/disruptor_bolt/sounds/disruptor_discharge_04.wav"]
							Volume = 1
							SpeedVariation = .2
						}
					]
					Filter
					{
						OperationalHealth = true
						StructuralHealth = true
						Friendlies = true
					}
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 12500
					Radius = 4
					Slices = 1
					Filter
					{
						OperationalHealth = true
						StructuralHealth = false
						Friendlies = true
					}
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 6250
					Radius = 4
					Slices = 1
					Delay = 0.1
					Filter
					{
						OperationalHealth = false
						StructuralHealth = true
						Friendlies = true
					}
				}
			]
		}

		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [3, 2]
		}
	}

	Stats
	{
		CrewRequired = &~/Part/Components/PartCrew/Crew
		HullPolariserBuff = &~/Part/Components/PolariserBuffProvider/BuffAmount
		PowerUsageContinuous = (&~/Part/Components/PowerDrain/FromQuantity) / (&~/Part/Components/PowerDrain/Interval) / 1000
		PowerCapacity = (&~/Part/Components/BatteryStorage/MaxResources) / 1000

		RecPower = &PowerUsageContinuous
		RecCrew = (&CrewRequired) + (&RecPower) * 4
	}
}