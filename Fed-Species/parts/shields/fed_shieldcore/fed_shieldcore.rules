Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/ShieldCore"
	IconNameKey = "Parts/ShieldCoreIcon"
	ID = "stafa.fed_shieldcore"
	EditorGroup = "StarfleetDefences"
	DescriptionKey = "Parts/ShieldCoreDesc"
	Resources
	[
		[steel, 700]
		[coil2, 250]
		[tristeel, 150]
		[processor, 6]
		[diamond, 17]
	]
	AIValueFactor = 10
	Size = [4, 4]
	SelectionPriority = 1
	SelectionTypeID = "shield_gen"
	SelectionTypeByRotation = true
	MaxHealth = 6000
	TypeCategories = [defense, uses_power, shieldcore, adapted]
	ReceivableBuffs : ^/0/ReceivableBuffs [DeflectorShieldBuff, ShuntStateBuff]
	PenetrationRectType = Normal
	Radius_XS = 15
	Radius_S = 25
	Radius_M = 35
	Radius_L = 45
	Radius_XL = 60

	PenetrationResistance_S = [125, 0]
	PenetrationResistance_M = [175, 0]
	PenetrationResistance_L = [225, 0]
	PenetrationResistance_XL = [275, 0]
	XSFromToQuantity = 2800
	XSInterval = .5

	SFromToQuantity = 4182//4181.81818181818
	SInterval = .5

	MFromToQuantity = 4923//4923.07692307692
	MInterval = .5

	LFromToQuantity = 5125
	LInterval = .5

	XLFromToQuantity = 5000
	XLInterval = .5

	BlockedTravelCells
	[
		[1, 1]
		[1, 2]
		[2, 1]
		[2, 2]
	]
