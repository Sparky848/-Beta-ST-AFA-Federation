	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [64, 64]
	}
	SHUNT_OPERATIONAL = ShuntReset
	SHUNT_FRONT_OPERATIONAL = FrontShuntReset
	SHUNT_BACK_OPERATIONAL = BackShuntReset
	SHUNT_LEFT_OPERATIONAL = LeftShuntReset
	SHUNT_RIGHT_OPERATIONAL = RightShuntReset
	//SHUNTTOGGLE_OPERATIONAL = ShuntToggleReset
	Components : ^/0/Components
	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, PartCrew, &~/Part/SHUNT_OPERATIONAL, &~/Part/SHUNT_FRONT_OPERATIONAL, &~/Part/SHUNT_BACK_OPERATIONAL, &~/Part/SHUNT_LEFT_OPERATIONAL, &~/Part/SHUNT_RIGHT_OPERATIONAL]//&~/Part/SHUNTTOGGLE_OPERATIONAL 
			Mode = All
		}
		//Operational Proxies
		FrontIsOperationalProxy
		{
			Type = ToggleProxy
			ComponentID = FrontIsOperational
		}
		LeftIsOperationalProxy
		{
			Type = ToggleProxy
			ComponentID = LeftIsOperational
		}
		RightIsOperationalProxy
		{
			Type = ToggleProxy
			ComponentID = RightIsOperational
		}
		BackIsOperationalProxy
		{
			Type = ToggleProxy
			ComponentID = BackIsOperational
		}//crashes might be due to these, might need one for each face
		
		//Battery Proxies
