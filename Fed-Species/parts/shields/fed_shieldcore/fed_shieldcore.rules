		//Shunt State Change Timer
		//No Shunt
		ShuntReset
		{
			Type = Timer
			Duration = 3
			StartExpired = true
			StartTrigger = ShuntToggleTrigger
			//StopTrigger = ShuntToggleTrigger
			//ResetTrigger = ShuntToggleTrigger
			DurationAfterResetTrigger = 0
		}
		ShuntResetProgress
		{
			Type = ProgressBar
			OperationalToggle = ShuntReset
			InvertOperationalToggle = true
			ShowProgressFor = ShuntReset
			LowColor = [25, 113, 255]
			HighColor = &LowColor
			FullColor = &LowColor
			Height = 6
		}
		ShuntToggleTrigger
		{
			Type = ToggleTrigger
			Toggle = NotShuntedToggle
			TriggerWhenOff = true
			TriggerWhenOn = true
		}

		//Front Shunt
		FrontShuntReset
		{
			Type = Timer
			Duration = 3
			StartExpired = true
			StartTrigger = FrontShuntToggleTrigger
