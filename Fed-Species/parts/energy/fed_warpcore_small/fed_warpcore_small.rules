		WarpcoreEjectionMechanism
		{
			Type = TriggeredEffects
			Trigger = WarpcoreEjectTimer
			HitEffects
			[
				{
					Type = SpawnBullets
					Bullet = &<ejected_warpcore_small.rules>
					Count = 1
					Distance = 0
					//Spread = [-5d, 5d]
					InheritVelocity = true
				}
			]
		}
		WarpcorePartChange
		{
			Type = TriggeredPartSwap
			Trigger = WarpcoreEjectTimer2
			NewPartID = stafa.fed_empty_warpcore_small
			NewPartLocation = [0, 0]
			InheritHealthFraction = true
		}

		BatteryStorage
		{
			Type = MultiResourceStorage
			ResourceType = battery
			MaxResources = 25000
			StartingResources = 25000
			ViaBuffs
			{
				OutgoingBuffProviders = [BuffProvider]
				ComponentID = BatteryStorage
			}
			AddMode = DistributeEvenly //PrioritizeLeastResources
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
			//ExpectedResourceGenerationRate = { BaseValue = (&../../WarpcoreActive/Components/BatteryProducer/ToQuantity) / (&../../WarpcoreActive/Components/BatteryProducer/Interval/BaseValue); BuffType=WarpcoreBuffSmall; BuffMode=Multiply; }
		}
		InternalCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = BatteryStorage
			Invert = false
			LowColor = [170, 183, 0]
			HighColor = [238, 255, 0]
			FullColor = [238, 255, 0]
			Height = 7
		}
		InternalAntimatterCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = AntimatterSplitter
			Invert = false
			LowColor = [0, 25, 166]
			HighColor = [0, 34, 227]
			FullColor = [0, 34, 227]
			Height = 8
		}
		AntimatterStorage
		{
			Type = ResourceStorage
			ResourceType = antimatter
			MaxResources = 10
			StartingResources = 0
            UITileRect = [3,1,1,1]
            Layer = "structure"
            SpriteInset = [12/64, 4/64, 6/64, 11/64]
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PartDeliver
			DropResourcesWhenDestroyed = false
		}
		AntimatterSplitter
		{
			Type = InlineResourceConverter
			OperationalToggle = IsOperational
			ResourceType = antimatter
			FromStorage = AntimatterStorage
			FromQuantity = 1
			ToQuantity = 15000//10000
		}
		AntimatterConsumer
		{
			Type = ResourceConsumer
			ResourceType = antimatter
			Storage = AntimatterStorage
			DefaultPriority = &/PRIORITIES/Factory_Supply
			OperationalToggle = PowerToggle
			ConsumptionToggleButtonOffset = [0, -.4]
		}
		
		// BatteryProducer
		// {
			// Type = ResourceConverter
			// ToStorage = BatteryStorage
			// ToQuantity = 1000
			// Interval = .2222 / 3
		// }
