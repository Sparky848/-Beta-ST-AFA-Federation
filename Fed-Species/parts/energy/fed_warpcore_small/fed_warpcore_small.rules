		Graphics
		{
			Type = Graphics
			Location = [2, 2]
			OperationalToggle = IsOperational
			Floor
			{
				Layer = "floors"
				DamageLevels
				[
					{
						AnimationFiles
						[
							"floor_on.png"
						]
						Size = [4, 4]
						AnimationInterval = 0.095
					}
				]
			}
			OperationalDoodad
			{
