		HitShield
		{
			HitEffects
			[
				: ../../HitOperational/HitEffects/0
				{
					Amount = 406250
					TreatShieldAsPart = true
				}
			]

			MediaEffects = &../HitOperational/MediaEffects
		}
		HitOperational
		{
			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 812500
					Radius = 62
					Delay = .05
					ExpandDuration = .08
					ExpandStartRadius = 6
					ExpandLoss = 50%
					StatusType = cosmoteer.fire
					StatusChancePerNDamage = 100%
					StatusValue = 1
					StatusValueType = Interpolated
					ImpulsePerNDamage = 5
					NDamage = 1000
					Filter
					{
						OperationalHealth = true
						StructuralHealth = false
						Friendlies = true
						Junk = true
						Neutrals = true
					}
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 100000
					Radius = 40
					Delay = .05
					ExpandDuration = .07
					ExpandStartRadius = 4
					StatusType = cosmoteer.heat
					StatusChancePerNDamage = 50%
