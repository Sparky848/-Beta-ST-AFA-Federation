					MaxCost = 37.5//MaxCost = 750
					EmptyTileCost = Infinity
					ValueFalloff = 1
					FalloffPadding = 1
					Filter
					{
						Self = true
						Friendlies = true
						Enemies = true
						Junk = true
						Neutrals = true
					}
				}
			]
			MediaEffectsScale = 1
