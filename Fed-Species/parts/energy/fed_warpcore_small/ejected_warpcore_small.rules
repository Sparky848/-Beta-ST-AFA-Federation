					NDamage = 1000
					Filter
					{
						OperationalHealth = false
						StructuralHealth = true
						Friendlies = true
						Junk = true
						Neutrals = true
					}
				}
				{
					Type = GridStatusApplication
					StatusType = cosmoteer.heat
					HitPartSourceRectType = Normal
					StatusValue = 0
					StatusValuePool
					{
						BaseValue = 600000//1750000
						EffectScaleExponent = 1
