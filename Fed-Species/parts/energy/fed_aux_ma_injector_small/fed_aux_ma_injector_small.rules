			//		}
			//	]
			//}
			//Celeste Code!
			PartLocation = [4, 1]
			ProxyableComponents
			[
				{
					ComponentID = IsConnected
					PartCriteria
					{
						IDs = [stafa.fed_warpcore_small]
						// Relative to part's top-left corner. The unrotated top of the other part should be at a y-offset of 1
						Top = 1
						// The other part's bottom should be at a y-offset of 2
						Bottom = 2
						// The other part's rotation relative to our rotation should be 2, so it's facing us
						Rot = 2
						FlipX = false
					}
				}
				// To allow flipping, you need a second similar criteria IIRC
				{
					ComponentID = IsConnected
					PartCriteria
					{
						IDs = [stafa.fed_warpcore_small]
						Top = 1
						Bottom = 2
						Rot = 0
						FlipX = true
					}
				}
			]
		}
		Connectedtosmallcorebottom
		{
			Type = ToggleProxy
			//PartLocation = [0, 4]
			//ProxyableComponents
			//[
			//	{
			//		PartCriteria
			//		{
			//			IDs = [stafa.fed_warpcore_small]
