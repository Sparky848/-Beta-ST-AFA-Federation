			// Proxy downwards
			PartLocation = [1, 4]
			ProxyableComponents
			[
				{
					ComponentID = IsConnected
					PartCriteria
					{
						IDs = [stafa.fed_warpcore_small]
						// Relative to part's top-left corner. The unrotated left of the other part should be at an x-offset of 1
						Left = 1
						// The other part's right should be at an x-offset of 2
						Right = 2
						// The other part's rotation relative to our rotation should be 3, so it's facing us
						Rot = 3
						FlipX = false
					}
				}
				// Allows flipping
				{
					ComponentID = IsConnected
					PartCriteria
					{
						IDs = [stafa.fed_warpcore_small]
						Left = 1
						Right = 2
						Rot = 1
						FlipX = true
					}
				}
			]
		}
