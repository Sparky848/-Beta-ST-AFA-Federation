	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, BatteryStorage]
			Mode = All
		}
		PowerDrain
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			FromStorage = BatteryStorage
			FromQuantity = 1000
			MinFromQuantityForConversion = 1000
			Interval = 1 
		}
		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = false
		}
		BuffProvider
		{
			Type = GridBuffProvider
			BuffType = WarpcoreBuffSmall
			BuffAmount = 100%
			GridDistance = 1
			BuffArea = [1, 0, 0, 4]
			PartCriteria
			{
				IDs = [stafa.fed_warpcore_small]
			}
			OperationalToggle = CanBuff
		}
		BuffProvider2
		{
			Type = GridBuffProvider
			BuffType = WarpcoreSubstationBuffSmall
			BuffAmount = 100%
			GridDistance = 1
			BuffArea = [1, 0, 0, 4]
			PartCriteria
			{
				IDs = [stafa.fed_warpcore_small]
			}
			OperationalToggle = CanBuff
		}
		CanBuff
		{
			Type = MultiToggle
			Toggles = [IsConnected, IsOperational]
			Mode = All
		}
		IsConnected
		{
			Type = MultiToggle
			Toggles = [Connectedtosmallcoreleft, Connectedtosmallcoreright, Connectedtosmallcoretop, Connectedtosmallcorebottom]
			Mode = Any
		}

		Connectedtosmallcoreleft
		{
			Type = ToggleProxy
			PartLocation = [1, 0]
			ProxyableComponents
			[
				{
					
					ComponentID = IsConnected
					PartCriteria
					{
						IDs = [stafa.fed_warpcore_small]
						Rot = 3
						Left = 1
					}
				}
			]
		}
		Connectedtosmallcoretop
		{
			Type = ToggleProxy
			PartLocation = [1, 3]
			ProxyableComponents
			[
				{
