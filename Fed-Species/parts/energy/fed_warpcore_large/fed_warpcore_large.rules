		//	ToStorage = BatteryStorage
		//	ToQuantity = 500
		//	Interval = { BaseValue=0.05; BuffType=WarpcoreSubstationBuffLarge; BuffMode=Subtract; MinValue=0.025; }
		//	MinFromQuantityForConversion = 501
		//}
		
		

		Graphics
		{
			Type = Graphics
			Location = [4, 4]
			OperationalToggle = IsOperational
			Floor
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor_on.png"
						Size = [8, 8]
					}
					{
						File = "floor_on_33.png"
