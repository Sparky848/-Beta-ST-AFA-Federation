				// [
					// {
						// File = "./Data/ships/terran/reactor_large/roof_glows.png"
						// Size = [8, 8]
					// }
				// ]
			// }
			OperationalRoofLighting
			{
				Layer = "roof_lights_fancy"
				DamageLevels
				[
					{
