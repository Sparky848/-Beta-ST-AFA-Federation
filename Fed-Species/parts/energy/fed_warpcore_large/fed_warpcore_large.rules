			//NonOperationalDoodad = &OperationalDoodad
			OperationalLighting
			{
				Layer = "lights_add"
				DamageLevels
				[
					{
						File = "lights.png"
						Size = [8, 8]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				DamageLevels
				[
					{
