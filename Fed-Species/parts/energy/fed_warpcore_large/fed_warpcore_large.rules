Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/Warpcore_large"
	IconNameKey = "Parts/Warpcore_large_Icon"
	ID = "stafa.fed_warpcore_large"
	EditorGroup = "StarfleetPower"
	DescriptionKey = "Parts/Warpcore_large_Desc"
	Resources
	[
		[steel, 1520]
		[coil2, 300]
		[tristeel, 200]
		[processor, 20]
		[antimatter, 15]
		[dilithium, 20]
//		[steel, 240]
//		[coil2, 160]
//		[tristeel, 80]
//		[processor, 10]
//		[antimatter, 10]
//		[dilithium, 5]
	]
	CrewSpeedFactor = .4
	CrewCongestedSpeedFactor = .3
	AIValueFactor = 10
	Size = [8, 8]
	//IsRotateable = false
	SelectionPriority = 0
	SelectionTypeID = "reactors"
	MaxHealth = 4000 // Deliberately not increasing this for med/large reactors to make them extra-fragile.
	AutoDoorMaxPathLength = 5
	TypeCategories = [reactor, ftl, is_crewed, uses_antimatter, warpcore]
	ReceivableBuffs : ^/0/ReceivableBuffs [WarpcoreBuffLarge, WarpcoreBuffQuantityLarge, WarpcoreSubstationBuffLarge, LargeInjector]
	CreatePartPerTileWhenDestroyed = ""
	//IgnoreRotationForMirroredSelection = true
	BlockedTravelCells
	[
		[2, 1]
		[2, 2]
		[2, 5]
		[2, 6]
		[6, 1]
		[6, 2]
		[6, 5]
		[6, 6]
		[1, 3]
		[2, 3]
		[3, 3]
		[4, 3]
		[5, 3]
		[6, 3]
		[7, 3]
		[1, 4]
		[2, 4]
		[3, 4]
		[4, 4]
		[5, 4]
		[6, 4]
		[7, 4]
	]
	AllowedDoorLocations
	[
		[0, -1]
		[1, -1]
		[2, -1]
		[3, -1]
		[4, -1]
		[5, -1]
		[6, -1]
		[7, -1]
		[0, 8]
		[1, 8]
		[2, 8]
		[3, 8]
		[4, 8]
		[5, 8]
		[6, 8]
		[7, 8]
	]
	ForceManhattanPathInPart = true
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [72, 72]
	}
	Components : ^/0/Components
	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, PartCrew]
			Mode = All
		}
		
		CommandConsumer
		{
			Type = CommandConsumer
			CommandPoints = 150
		}

		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = false
		}
		IsConnected 
		{
			Type = ToggleProxy
			ComponentID = PowerToggle
		}
		LargeInjector
		{
			Type = BuffToggle
			BuffType = LargeInjector
		}
		WarpcoreEject 
		{
			Type = UIToggle
			ToggleID = "warpcore_eject_toggle"
			Default = 0
		}
		WarpcoreIsActive
		{
			Type = ModeToggle
			Mode = WarpcoreEject
			OnMode = 0
		}
		WarpcoreEjectionCycle
		{
			Type = ModeToggle
			Mode = WarpcoreEject
			OnMode = 1
		}
		WarpcoreEjectTimerTrigger
		{
			Type = ToggleTrigger
			Toggle = WarpcoreEjectionCycle	
		}
		WarpcoreEjectTimer
		{
			Type = Timer
			Duration = 5
			StartTrigger = WarpcoreEjectTimerTrigger
			AutoStart = false
		}
		WarpcoreActive
		{
			Type = ToggledComponents
			Toggle = WarpcoreIsActive
			Components
			{
				BatteryProducer
				{
					Type = ResourceConverter
					OperationalToggle = IsOperational
					ToStorage = BatteryStorage
					ToQuantity = { BaseValue=250; BuffType=WarpcoreBuffQuantityLarge; BuffMode=Add; MaxValue=375; }//was 100 and 200. trying to make shields and control rooms have less of an idle antimatter impact on larger ships
					Interval = { BaseValue=0.5; BuffType=WarpcoreBuffLarge; BuffMode=Subtract; MinValue=0.25; } //small reactor gen rate when buffed (1.5/sec), 0.5/sec when not
				}
				ResourceConverter//467.64705882353 power per antimatter    total is roughly a 20% increase per core starting from the small
				{
					Type = ResourceConverter
					OperationalToggle = IsOperational
					From
					[
						{
							Storage = AntimatterSplitter
							Quantity = 85//75
						}
					]
					ToStorage = BatteryStorage
					ToQuantity = 1590
					Interval = .05
				}
				ConvertEffects
				{
					Type = TriggeredEffects
					Trigger = ResourceConverter
					Location = [4, 4]
					MediaEffects
					[
						: /BASE_SOUNDS/AudioInterior
						{
							Sound = "../../../sounds/create_energy.wav"
							Volume = .1
							Speed = .5
							SpeedVariation = .05
						}
					]
				}
				BuffProvider
				{
					Type = GridBuffProvider
					OperationalToggle = IsOperational
					BuffType = AntimatterPower
					BuffAmount = 100%
					GridDistance = 500
				}
				FtlEnergySubstation
				{
					Type = ResourceConverter
					OperationalToggle = FtlDrive
					From
					[
						{
						Storage = BatteryStorage
						Quantity = 500
						MinQuantityForConversion = 500
						}
					]
					To
					[
						{
						Storage = FtlBatteryStorage
						Quantity = 500
						MinQuantityForConversion = 500
						}
					]
					Interval = 0.4
				}
				// Hyperdrive
				HyperiumStorage
				{
					Type = ResourceStorage
					ResourceType = hyperium
					MaxResources = 100
					UITileRect = [0, 0, 1, 1]
					ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PartDeliver
					DropResourcesWhenDestroyed = true
				}
				HyperiumConsumer
				{
					Type = ResourceConsumer
					ResourceType = hyperium
					Storage = HyperiumStorage
					DefaultPriority = &/PRIORITIES/Utility_Supply
					OperationalToggle = PowerToggle
					ConsumptionToggleButtonOffset = [0, -.4]
				}
				FtlBatteryStorage
				{
					Type = ResourceStorage
					ResourceType = battery
					MaxResources = 16000
					StartingResources = &MaxResources
					//InitToMaxResources = 0
					ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
				}
				// FtlBatteryConsumer
				// {
					// Type = ResourceConsumer
					// ResourceType = battery
					// Storage = FtlBatteryStorage
					// DefaultPriority = &/PRIORITIES/Ftl_Supply
					// OperationalToggle = FtlDrive
					// AllowNonOperationalMinPriorityDelivery = false
					// OverrideExclusiveCrewAssignment = true
				// }
				ReloadProgressBar
				{
					Type = ProgressBar
					OperationalToggle = FtlDrive
					ShowProgressFor = FtlBatteryStorage
				}

				FtlBatteryStorageCharging
				{
					Type = MultiResourceStorage
					ResourceType = battery
					ResourceStorages = [FtlBatteryStorage]
					ToggleOnResources = 1
					ToggleOffResources = 0
				}
				FtlBatteryStorageFull
				{
					Type = MultiResourceStorage
					ResourceType = battery
					ResourceStorages = [FtlBatteryStorage]
					ToggleOnResources = 16000
					ToggleOffResource = 15999
				}

				FtlDrive
				{
					Type = FtlDrive
					OperationalToggle = IsOperational
					PowerStorage = FtlBatteryStorage
					FuelStorage = HyperiumStorage
					SpinDownDuration = 5
					JumpEfficiency = 80%
					JumpEfficiencyDistanceRange = [20, 55]

					JumpOutMediaEffects
					[
						&<./Data/ships/common/particles/ftl_lightning.rules>
						// TODO: Fix size an spacing
					]
					JumpOutGateMediaEffects
					[
						&<./Data/ships/common/particles/ftl_gate_lightning_out.rules>

						: /BASE_SOUNDS/AudioExteriorZoomless
						{
							Sound = "../../../sounds/warp_speed_in.wav"
							Volume = 1
							MaxConcurrentVolume = 1
							Speed = 1
							MaxConcurrent = 3
						}
					]
					JumpInMediaEffects
					[
						: &<./Data/ships/common/particles/ftl_lightning.rules>
						{
							Delay = (&<./Data/ships/base_ship.rules>/FtlEffects/TotalDuration) - (&<./Data/ships/base_ship.rules>/FtlEffects/CropTime/1) - .4
						}
					]
					JumpInGateMediaEffects
					[
						: &<./Data/ships/common/particles/ftl_gate_lightning_in.rules>
						{
							Delay = (&<./Data/ships/base_ship.rules>/FtlEffects/TotalDuration) - (&<./Data/ships/base_ship.rules>/FtlEffects/CropTime/1) - .4
						}

						: /BASE_SOUNDS/AudioExteriorZoomless
						{
							Delay = (&<./Data/ships/base_ship.rules>/FtlEffects/TotalDuration) - (&<./Data/ships/base_ship.rules>/FtlEffects/CropTime/1) - .8
							Sound = "../../../sounds/warp_speed_out.wav"
							Volume = 1
							MaxConcurrentVolume = 1
							Speed = 1
							MaxConcurrent = 3
						}
					]
				}
				DestroyedEffects
				{
					Type = DeathEffects
					Location = [4, 4]

					MediaEffects
					[
						&<boom/reactor_explode_large.rules>
						&<boom/reactor_explode_flash_large.rules>
						&<boom/reactor_shockwave_large.rules>
						&<./Data/common_effects/particles/explosions/huge_part_explode_debris.rules>
						&<./Data/common_effects/particles/explosions/huge_part_explode_smoke.rules>

						: /BASE_SOUNDS/AudioExterior
						{
							RandomSounds = ["./Data/ships/terran/reactor_small/destroyed/destroyed_01.wav", "./Data/ships/terran/reactor_small/destroyed/destroyed_02.wav", "./Data/ships/terran/reactor_small/destroyed/destroyed_03.wav"]
							Volume = 2
							Speed = .5
							SpeedVariation = .25 * (&Speed)
						}

						: /BASE_SHAKE
						{
							ShakeAmount = .75
							Duration = 4
						}
					]

					HitEffects
					[
						{
							Type = ExplosiveDamage
							TotalDamage = 2000000
							Radius = 124
							Delay = .05
							ExpandDuration = .1
							ExpandStartRadius = 6
							ExpandLoss = 50%
							StatusType = cosmoteer.fire
							StatusChancePerNDamage = 100%
							StatusValue = 1
							StatusValueType = Interpolated
							ImpulsePerNDamage = 5
							NDamage = 1000
							Filter
							{
								OperationalHealth = true
								StructuralHealth = false
								Friendlies = true
							}
						}
						{
							Type = ExplosiveDamage
							TotalDamage = 100000
							Radius = 98
							Delay = .05
							ExpandDuration = .1
							ExpandStartRadius = 4
							//ExpandLoss = 10%
							StatusType = cosmoteer.heat
							StatusChancePerNDamage = 100%
							StatusValue = 8000
							StatusValueType = Interpolated
							ImpulsePerNDamage = 3
							NDamage = 1000
							Filter
							{
								OperationalHealth = false
								StructuralHealth = true
								Friendlies = true
							}
						}
						{
							Type = GridStatusApplication
							StatusType = cosmoteer.heat
							HitPartSourceRectType = Normal
							StatusValue = 0
							StatusValuePool
							{
								BaseValue = 3500000//BaseValue = 4000000
								EffectScaleExponent = 1
							}
							MaxCost = 75//MaxCost = 750
							EmptyTileCost = Infinity
							ValueFalloff = 1
							FalloffPadding = 1
							Filter
							{
								Self = true
								Friendlies = true
								Enemies = true
								Junk = true
								Neutrals = true
							}
						}
					]
				}
			}
		}
		
		
		WarpcoreEjectionMechanism
		{
			Type = TriggeredEffects
			Trigger = WarpcoreEjectTimer
			HitEffects
			[
				{
					Type = SpawnBullets
					Bullet = &<ejected_warpcore_large.rules>
					Count = 1
					Distance = 0
					//Spread = [-5d, 5d]
					InheritVelocity = true
				}
				{
					Type = Damage
					Damage = 5000
					Filter
					{
						Friendlies = true
						IgnoreInvulnerability = true
					}
				}
			]
		}

		BatteryStorage
		{
			Type = MultiResourceStorage
			ResourceType = battery
			MaxResources = 100000
			StartingResources = 100000
			ViaBuffs
			{
				OutgoingBuffProviders = [BuffProvider]
				ComponentID = BatteryStorage
			}
			AddMode = DistributeEvenly //PrioritizeLeastResources
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		InternalCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = BatteryStorage
			Invert = false
			LowColor = [170, 183, 0]
			HighColor = [238, 255, 0]
			FullColor = [238, 255, 0]
			Height = 7
		}
		InternalAntimatterCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = AntimatterSplitter
			Invert = false
			LowColor = [0, 25, 166]
			HighColor = [0, 34, 227]
			FullColor = [0, 34, 227]
			Height = 8
		}
		AntimatterStorage
		{
			Type = ResourceStorage
			ResourceType = antimatter
			MaxResources = 10
			StartingResources = 0
            UITileRect = [7,7,1,1]
            Layer = "structure"
            SpriteInset = [12/64, 4/64, 6/64, 11/64]
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PartDeliver
			DropResourcesWhenDestroyed = false
		}
		AntimatterSplitter
		{
			Type = InlineResourceConverter
			OperationalToggle = IsOperational
			ResourceType = antimatter
			FromStorage = AntimatterStorage
			FromQuantity = 1
			ToQuantity = 25000//15000//10000
		}
		AntimatterConsumer
		{
			Type = ResourceConsumer
			ResourceType = antimatter
			Storage = AntimatterStorage
			DefaultPriority = &/PRIORITIES/Factory_Supply
			OperationalToggle = PowerToggle
			ConsumptionToggleButtonOffset = [0, -.4]
		}
		
		
		// BatteryProducer
		// {
			// Type = ResourceConverter
			// ToStorage = BatteryStorage
			// ToQuantity = 1000
			// Interval = .2222 / 3
		// }
		// BatteryConsumer
		// {
			// Type = ResourceConsumer
			// ResourceType = battery
			// Storage = BatteryStorage
			// DefaultPriority = 0
			// ResupplyThreshold = 1000
		// }
		EmpAbsorber
		{
			Type = ExplosiveResourceDrainSink
			ResourceType = battery
			AbsorbsResourceDrain = 800
			RecoveryRate = (&AbsorbsResourceDrain) * 0.1
		}

		
		LargeInjectorSelfBuffProvider
		{
			Type = SelfBuffProvider
			BuffType = LargeInjector
			BuffAmount = 100%
		}
		LargeInjectorBuffProvider
		{
			Type = GridBuffProvider
			BuffType = LargeInjector
			BuffAmount = 0
			GridDistance = 1
			OperationalToggle = IsOperational
			PartCriteria
			{
				IDs = [stafa.aux_ma_injector_large] 
			}
		}
