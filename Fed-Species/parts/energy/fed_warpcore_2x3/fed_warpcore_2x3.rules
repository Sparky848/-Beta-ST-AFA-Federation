Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/Warpcore_2x3"
	IconNameKey = "Parts/Warpcore_2x3_Icon"
	ID = "stafa.fed_warpcore_2x3"
	EditorGroup = "StarfleetPower"
	DescriptionKey = "Parts/Warpcore_2x3_Desc"
	Resources
	[
		[steel, 90]
		[coil2, 60]
		[tristeel, 30]
		[processor, 3]
		[antimatter, 5]
		[dilithium, 2]
	]
	CrewSpeedFactor = .8
	CrewCongestedSpeedFactor = .8
	AIValueFactor = 8
	Size = [2, 3]
	//IsRotateable = true
	SelectionPriority = 0
	SelectionTypeID = "reactors"
	MaxHealth = 4000 // Not changing, makes these slightly more usefull on smaller ships
	AutoDoorMaxPathLength = 5
	TypeCategories = [reactor, ftl, is_crewed, uses_antimatter, warpcore]
	ReceivableBuffs : ^/0/ReceivableBuffs [WarpcoreBuffSmall, WarpcoreSubstationBuffSmall]
	CreatePartPerTileWhenDestroyed = ""
	IgnoreRotationForMirroredSelection = true
	
	BlockedTravelCells
	[

	]
	BlockedTravelCellDirections
	[
		{
			Key = [0, 0]
			Value = [Right]
		}
		{
			Key = [0, 1]
			Value = [Right]
		}
		{
			Key = [0, 2]
			Value = [Right]
		}
		{
			Key = [1, 0]
			Value = [Left]
		}
		{
			Key = [1, 1]
			Value = [Left]
		}
		{
			Key = [1, 2]
			Value = [Left]
		}
	]
	AllowedDoorLocations
	[
		[0, -1]
		[1, -1]
		[-1, 0]
		[2, 0]
		[-1, 2]
		[2, 2]
		[0, 3]
		[1, 3]
	]
	ForceManhattanPathInPart = true
	HasNonContiguousPathing = true
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [42.66, 64]
	}
	Components : ^/0/Components
	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, PartCrew]
			Mode = All
		}
		IsConnected 
		{
			Type = ToggleProxy
			ComponentID = PowerToggle
		}
		CommandConsumer
		{
			Type = CommandConsumer
			CommandPoints = 15
		}

		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = false
		}
		
		BatteryProducer
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			ToStorage = BatteryStorage
			ToQuantity = 25
			Interval = { BaseValue=0.5; BuffType=WarpcoreBuffVSmall; BuffMode=Subtract; MinValue=0.20; }
		}
		//BatteryProducer2
		//{
		//	Type = ResourceConverter
		////	ToStorage = ExtendedBatteryStorage
		//	ToQuantity = 30
		//	Interval = 0.5
		//}
		//WarpcoreBuffProvider
		//{
		//	Type = SelfBuffProvider
		//	BuffType = WarpcoreBuffSmall
		//	//ChainsFromBuffType = WarpcoreBuffSmall
		//	BuffAmount = { BaseValue=0%; BuffType=WarpcoreBuffSmall; BuffMode=Add; }
		//}
		BatteryStorage
		{
			Type = ResourceStorage
			ResourceType = battery
			MaxResources = 8000
			StartingResources = 0
		}
	//	ExtendedBatteryActive
	//	{
	//		Type = MultiToggle
	//		Toggles = [IsConnected]
	//		Mode = All
	//	}
		WarpcoreSmallBuffToggle
		{
			Type = BuffToggle
			BuffType = WarpcoreBuffSmall
		}
		//ExtendedBatteryStorage
		//{
		//	IsOperational = WarpcoreSmallBuffToggle
		//	Type = ResourceStorage
		//	ResourceType = battery
		//	MaxResources = 12000
		//	StartingResources = 0
		//}
		//EnergySubstation2
		//{
		//	Type = ResourceConverter
		//	FromStorage = ExtendedBatteryStorage
		//	FromQuantity = 500
		//	ToStorage = CombinedBatteryStorage
		//	ToQuantity = 500
		//	Interval = 0.5
		//	MinFromQuantityForConversion = 0
		//}
		CombinedBatteryStorage
		{
			Type = MultiResourceStorage
			ResourceType = battery
			ResourceStorages = [BatteryStorage, FtlBatteryStorage]
			ViaBuffs
			{
				OutgoingBuffProviders = [BuffProvider]
				ComponentID = BatteryStorage
			}
			AddMode = DistributeEvenly //PrioritizeLeastResources
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
			ExpectedResourceGenerationRate = { BaseValue = (&../../BatteryProducer/ToQuantity) / (&../../BatteryProducer/Interval/BaseValue); BuffType=WarpcoreBuffSmall; BuffMode=Multiply; }
		}
		InternalCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = CombinedBatteryStorage
			Invert = false
			LowColor = [170, 183, 0]
			HighColor = [238, 255, 0]
			FullColor = [238, 255, 0]
			Height = 5
		}
		InternalAntimatterCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = AntimatterSplitter
			Invert = false
			LowColor = [0, 25, 166]
			HighColor = [0, 34, 227]
			FullColor = [0, 34, 227]
			Height = 4
		}
		AntimatterStorage
		{
			Type = TypedResourceGrid
			ResourceType = antimatter
			MaxResources = 5
			StartingResources = 0
            GridRect = [1, 2, 1, 1]
            Layer = "structure"
            SpriteInset = [12/64, 4/64, 6/64, 11/64]
		}
		AntimatterSplitter
		{
			Type = InlineResourceConverter
			OperationalToggle = IsOperational
			ResourceType = antimatter
			FromStorage = AntimatterStorage
			FromQuantity = 1
			ToQuantity = 5000
		}
		AntimatterConsumer
		{
			Type = TypedResourceGridConsumer
			ResourceType = antimatter
			Storage = AntimatterStorage
			DefaultPriority = &/PRIORITIES/Factory_Supply
			OperationalToggle = PowerToggle
			ConsumptionToggleButtonOffset = [0, -.4]
		}
		ResourceConverter
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			From
			[
				{
					Storage = AntimatterSplitter
					Quantity = 50
				}
			]
			ToStorage = BatteryStorage
			ToQuantity = 195
			Interval = .1
		}
		ConvertEffects
		{
			Type = TriggeredEffects
			Trigger = ResourceConverter
			Location = [2, 2]
			MediaEffects
			[
				: /BASE_SOUNDS/AudioInterior
				{
					Sound = "../../../sounds/create_energy.wav"
					Volume = .1
					Speed = .5
					SpeedVariation = .05
				}
			]
		}
		// BatteryProducer
		// {
			// Type = ResourceConverter
			// ToStorage = BatteryStorage
			// ToQuantity = 1000
			// Interval = .2222 / 3
		// }
		// BatteryConsumer
		// {
			// Type = ResourceConsumer
			// ResourceType = battery
			// Storage = CombinedBatteryStorage
			// DefaultPriority = 0
			// ResupplyThreshold = 1000
		// }
		EmpAbsorber
		{
			Type = ExplosiveResourceDrainSink
			ResourceType = battery
			AbsorbsResourceDrain = 800
			RecoveryRate = (&AbsorbsResourceDrain) * 0.1
		}

		BuffProvider
		{
			Type = GridBuffProvider
			OperationalToggle = IsOperational
			BuffType = AntimatterPower
			BuffAmount = 100%
			GridDistance = 100
		}
		//EnergySubstation
		//{
		//	Type = ResourceConverter
		//	FromStorage = BatteryStorage
		//	FromQuantity = 375
		//	ToStorage = CombinedBatteryStorage
		//	ToQuantity = 375
		//	Interval = 0.075
		//	MinFromQuantityForConversion = 376
		//}
		
		EnergySubstation
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			From
			[
				{
				Storage = BatteryStorage
				Quantity = 195
				MinQuantityForConversion = 195
				}
			]
			To
			[
				{
				Storage = CombinedBatteryStorage
				Quantity = 195
				MinQuantityForConversion = 195
				}
			]
			Interval = { BaseValue=0.1; BuffType=WarpcoreSubstationBuffVSmall; BuffMode=Subtract; MinValue=0.075; }
		}
		// Hyperdrive
		HyperiumStorage
		{
			Type = ResourceStorage
			ResourceType = hyperium
			MaxResources = 30
			UITileRect = [0, 0, 1, 1]
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/ElementDeliver
			DropResourcesWhenDestroyed = true
		}
		HyperiumConsumer
		{
			Type = ResourceConsumer
			ResourceType = hyperium
			Storage = HyperiumStorage
			DefaultPriority = &/PRIORITIES/Utility_Supply
			OperationalToggle = PowerToggle
			ConsumptionToggleButtonOffset = [0, -.4]
		}
		FtlBatteryStorage
		{
			Type = ResourceStorage
			ResourceType = battery
			MaxResources = 4000
			StartingResources = &MaxResources
			//InitToMaxResources = 0
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		// FtlBatteryConsumer
		// {
			// Type = ResourceConsumer
			// ResourceType = battery
			// Storage = FtlBatteryStorage
			// DefaultPriority = &/PRIORITIES/Ftl_Supply
			// OperationalToggle = FtlDrive
			// AllowNonOperationalMinPriorityDelivery = false
			// OverrideExclusiveCrewAssignment = true
		// }
		ReloadProgressBar
		{
			Type = ProgressBar
			OperationalToggle = FtlDrive
			ShowProgressFor = FtlBatteryStorage
		}

		FtlBatteryStorageCharging
		{
			Type = MultiResourceStorage
			ResourceType = battery
			ResourceStorages = [FtlBatteryStorage]
			ToggleOnResources = 1
			ToggleOffResources = 0
		}
		FtlBatteryStorageFull
		{
			Type = MultiResourceStorage
			ResourceType = battery
			ResourceStorages = [FtlBatteryStorage]
			ToggleOnResources = 4000
			ToggleOffResource = 3999
		}

		FtlDrive
		{
			Type = FtlDrive
			OperationalToggle = IsOperational
			PowerStorage = FtlBatteryStorage
			FuelStorage = HyperiumStorage
			SpinDownDuration = 8
			JumpEfficiency = 70%
			JumpEfficiencyDistanceRange = [5, 35]

			JumpOutMediaEffects
			[
				&<./Data/ships/common/particles/ftl_lightning.rules>
				// TODO: Fix size an spacing
			]
			JumpOutGateMediaEffects
			[
				&<./Data/ships/common/particles/ftl_gate_lightning_out.rules>

				: /BASE_SOUNDS/AudioExteriorZoomless
				{
					Sound = "../../../sounds/warp_speed_in.wav"
					Volume = 1
					MaxConcurrentVolume = 1
					Speed = 1
					MaxConcurrent = 3
				}
			]
			JumpInMediaEffects
			[
				: &<./Data/ships/common/particles/ftl_lightning.rules>
				{
					Delay = (&<./Data/ships/base_ship.rules>/FtlEffects/TotalDuration) - (&<./Data/ships/base_ship.rules>/FtlEffects/CropTime/1) - .4
				}
			]
			JumpInGateMediaEffects
			[
				: &<./Data/ships/common/particles/ftl_gate_lightning_in.rules>
				{
					Delay = (&<./Data/ships/base_ship.rules>/FtlEffects/TotalDuration) - (&<./Data/ships/base_ship.rules>/FtlEffects/CropTime/1) - .4
				}

				: /BASE_SOUNDS/AudioExteriorZoomless
				{
					Delay = (&<./Data/ships/base_ship.rules>/FtlEffects/TotalDuration) - (&<./Data/ships/base_ship.rules>/FtlEffects/CropTime/1) - .8
					Sound = "../../../sounds/warp_speed_out.wav"
					Volume = 1
					MaxConcurrentVolume = 1
					Speed = 1
					MaxConcurrent = 3
				}
			]
		}

		Graphics
		{
			Type = Graphics
			Location = [1, 1.5]
			OperationalToggle = IsOperational
			Floor
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [2, 3]
					}
					{
						File = "floor_33.png"
						Size = [2, 3]
					}
					{
						File = "floor_66.png"
						Size = [2, 3]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				DamageLevels
				[
					{
						File = "walls.png"
						Size = [2, 3]
					}
					//{
					//	File = "walls_33.png"
					//	Size = [8, 8]
					//}
					//{
					//	File = "walls_66.png"
					//	Size = [8, 8]
					//}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [2, 3]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [2, 3]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [2, 3]
					}
				]
			}
			// OperationalRoofDoodad
			// {
				// Layer = "roof_doodads"
				// DamageLevels
				// [
					// {
						// File = "./Data/ships/terran/reactor_large/roof_glows.png"
						// Size = [8, 8]
					// }
				// ]
			// }
			NonOperationalDoodad
			{
				Layer = "doodads_high"
				//Offset = [0, -0.515]
				DamageLevels
				[
					{
						File = "offline_doodad.png"
						Size = [2, 3]
					}
				]
			}
		}

		ReactorHum
		{
			Type = ContinuousEffects
			Location = [2, 2]
			MediaEffects
			[
				: /BASE_SOUNDS/AudioInterior
				{
					Sound = "../../../sounds/tng_hum_clean.wav"
					Volume = .5
					Speed = .5
					MaxConcurrent = 1
					DynamicVolume : ^/0/DynamicVolume
					{
						ExteriorVolume = .5
					}
				}
			]
		}
		

		DestroyedEffects
		{
			Type = DeathEffects
			Location = [1.5, 1]

			MediaEffects
			[
				&<boom/reactor_explode_large.rules>
				&<boom/reactor_explode_flash_large.rules>
				&<boom/reactor_shockwave_large.rules>
				&<./Data/common_effects/particles/explosions/huge_part_explode_debris.rules>
				&<./Data/common_effects/particles/explosions/huge_part_explode_smoke.rules>

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "./Data/ships/terran/reactor_small/destroyed.wav"
					Volume = 2
					Speed = .5
					SpeedVariation = .25 * (&Speed)
				}

				: /BASE_SHAKE
				{
					ShakeAmount = .75
					Duration = 4
				}
			]

			HitEffects
			[
				{
					Type = ExplosiveDamage
					TotalDamage = 750000
					Radius = 25
					Delay = .05
					ExpandDuration = .08
					ExpandStartRadius = 6
					ExpandLoss = 50%
					FireChancePerNDamage = 100%
					ImpulsePerNDamage = 5
					NDamage = 1000
					Filter
					{
						OperationalHealth = true
						StructuralHealth = true
						Friendlies = true
					}
				}
				{
					Type = ExplosiveDamage
					TotalDamage = 75000
					Radius = 16
					Delay = .05
					ExpandDuration = .07
					ExpandStartRadius = 4
					ExpandLoss = 100%
					ImpulsePerNDamage = 3
					NDamage = 1000
					Filter
					{
						OperationalHealth = false
						StructuralHealth = true
						Friendlies = true
					}
				}
			]
		}
		
		CrewLocation1
		{
			Type = CrewLocation
			Location = [1.609375, 0.859375]
			Rotation = 225d
		}
		PartCrew
		{
			Type = PartCrew
			Crew = 1
			DefaultPriority = &/PRIORITIES/ControlRoom_Crew
			PrerequisitesBeforeCrewing = [PowerToggle]
			CrewDestinations
			[
				[1.609375, 0.859375]
			]
			CrewLocations
			[
				CrewLocation1
			]
		}

		OperationEffects
		{
			Type = ToggleEffects
			Location = [1, 1]
			Toggle = IsOperational
			ToggledOnMediaEffects = &/COMMON_EFFECTS/PowerOn
			ToggledOffMediaEffects = &/COMMON_EFFECTS/PowerOff
		}
		
		Indicators
		{
			Type = IndicatorSprites
			Location = [1, 1.5]
			Layer = "indicators"
			Indicators
			[
				// Turned off.
				{
					Toggle = PowerToggle
					AtlasSprite
					{
						File = &/INDICATORS/PowerOff
						Size = [1, 1]
					}
				}
				// Out of power.
				{
					Toggle = BatteryStorage
					AtlasSprite
					{
						File = &/INDICATORS/NoPower
						Size = [1, 1]
					}
				}

				// No antimatter.
				{
					Toggle = AntimatterStorage
					AtlasSprite
					{
						File = "../../../images/no_antimatter.png"
						Size = [1, 1]
					}
				}
				// No crew.
				{
					Toggle = PartCrew
					AtlasSprite
					{
						File = &/INDICATORS/NoCrew
						Size = [1, 1]
					}
				}
			]
		}

		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [2, 3]
		}
	}

	Stats
	{
		BasePowerGen = (&~/Part/Components/BatteryProducer/ToQuantity) / (&~/Part/Components/BatteryProducer/Interval/BaseValue) / 1000
		AntimatterPowerGen = (&BasePowerGen) + ((&~/Part/Components/ResourceConverter/ToQuantity) / (&~/Part/Components/ResourceConverter/Interval) / 1000)
		//BatterySize = (&~/Part/Components/BatteryStorage/MaxResourcesPickUp) / 1000
		//BatteryFillTime = 1000 / (&~/Part/Components/BatteryStorage/PickUpRate)
		TransferRate = ((&~/Part/Components/EnergySubstation/From/0/MinQuantityForConversion) / (&~/Part/Components/EnergySubstation/Interval/BaseValue)) / 1000
		PowerCapacity = (&~/Part/Components/BatteryStorage/MaxResources) / 1000
	}
}