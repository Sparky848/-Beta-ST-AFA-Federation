Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/Impulse_Deck_2x3"
	IconNameKey = "Parts/Impulse_Deck_2x3_Icon"
	ID = "stafa.fed_impulse_deck_2x3"
	EditorGroup = "StarfleetFlight"
	DescriptionKey = "Parts/Impulse_Deck_2x3_Desc"
	OtherIDs = [impulse_deck_2x3_L, impulse_deck_2x3_R, stafa.impulse_deck_2x3_L, stafa.impulse_deck_2x3_R]
	FlipWhenLoadingIDs = [impulse_deck_2x3_R, stafa.impulse_deck_2x3_R]
	//FlipHRotate = [0, 3, 2, 1]
	//FlipVRotate = [2, 1, 0, 3]
	IsBuildable = false
	Resources
	[
		[steel, 225]
		[coil, 50]
		[coil2, 55]
		[processor, 5]
		[tristeel, 50]
	]
	TypeCategories = [thruster, uses_power, impulse, is_crewed]
	Size = [2, 3]
	SelectionPriority = 1
	SelectionTypeByRotation = true
	SelectionTypeID = "impulse"
	IsFlippable = true
	MaxHealth = 24000
	ThrusterForce = 19000
	ThrustIncreaseTime = 2
	ThrustRecoveryTime = 1
	FuelUsage = 2400
	ProhibitedBy : ^/0/ProhibitedBy [impulse]
	Blueprints : ^/Blueprints/DrawProhibitedZoneCategories [impulse]
	ProhibitRects
    [
		[impulse, [-1, 3, 5, 15]]
    ]
	ReceivableBuffs : ^/0/ReceivableBuffs [Engine, AntimatterPower, EnginePowerDistribution]
	ForceManhattanPathInPart = true
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [32, 48]
	}
	Components : ^/0/Components
	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, BatteryStorage, PartCrew]
			Mode = All
		}

		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = false
		}

		CommandConsumer
		{
			Type = CommandConsumer
			OperationalToggle = PowerToggle
			CommandPoints = 26//2 per tile, extra 2 per height
		}

		BatteryStorage
		{
			Type = ResourceStorage
			ResourceType = battery
			MaxResources = 16000
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		InternalCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = BatteryStorage
			Invert = false
			LowColor = [170, 183, 0]
			HighColor = [238, 255, 0]
			FullColor = [238, 255, 0]
			Height = 7
		}
		ThrustLevel
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = MainThruster
			Invert = false
			LowColor = [130, 20, 20]
			HighColor = [200, 30, 30]
			FullColor = [245, 40, 40]
			Height = 6
		}
		EngineBuffToggle
		{
			Type = BuffToggle
			BuffType = Engine
		}
		ToggledBatteryConsumer
		{
			Type = ToggledComponents
			Toggle = EngineBuffToggle
			Invert = true
			IncludeInBlueprints = true
			Components
			{
				BatteryConsumer
				{
					Type = ResourceConsumer
					ResourceType = battery
					Storage = BatteryStorage
					DefaultPriority = &/PRIORITIES/Thruster_Supply
					ResupplyThreshold = 2000
					OperationalToggle = PowerToggle
				}
			}
		}

		CrewLocation1
		{
			Type = CrewLocation
			Location = [1.2, 1.5]
			Rotation = 90d
		}
		CrewLocation2
		{
			Type = CrewLocation
			Location = [1, .7]
			Rotation = 180d
		}
		CrewLocation3
		{
			Type = CrewLocation
			Location = [1.8,1.5]
			Rotation = 270d
		}
		PartCrew
		{
			Type = PartCrew
			Crew = 3
			DefaultPriority = &/PRIORITIES/ControlRoom_Crew
			PrerequisitesBeforeCrewing = [PowerToggle]
			HighPriorityPrerequisites = [BatteryStorage]
			CrewDestinations
			[
				&../../CrewLocation1/Location
				&../../CrewLocation2/Location
				&../../CrewLocation3/Location
			]
			CrewLocations
			[
				CrewLocation1
				CrewLocation2
				CrewLocation3
			]
		}

		Graphics
		{
			Type = Graphics
			Location = [1, 1.5]
			OperationalToggle = IsOperational
			AnimationSpeedFactor = MainThruster
			AnimationSpeedFactorRenormalize = [0.75, 2.0]
			Floor
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [2, 3]
					}
					{
						File = "floor_33.png"
						Size = [2, 3]
					}
					{
						File = "floor_66.png"
						Size = [2, 3]
					}
				]
			}
			OperationalDoodad
			{
				Layer = "doodads_low" // Putting on turrets layer because they will rotate frequently.
				Offset = [0, 0]
				DamageLevels
				[
					{
						AnimationFiles
						[
							"chairs/doodads_on1.png"
							"chairs/doodads_on2.png"
							"chairs/doodads_on3.png"
							"chairs/doodads_on4.png"
							"chairs/doodads_on5.png"
							"chairs/doodads_on6.png"
							"chairs/doodads_on7.png"
							"chairs/doodads_on8.png"
						]
						Size = [2, 3]
						AnimationInterval = 0.125
					}
				]
			}
			NonOperationalDoodad
			{
				Layer = "doodads_low" // Putting on turrets layer because they will rotate frequently.
				Offset = [0, 0]
				DamageLevels
				[
					{
						File = "chairs/doodads_off.png"
						Size = [2, 3]
					}
				]
			}
			OperationalLighting
			{
				Layer = "lights_add"
				DamageLevels
				[
					{
						File = "lights.png"
						Size = [2, 3]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				DamageLevels
				[
					{
						File = "walls.png"
						Size = [2, 3]
					}
					{
						File = "walls_33.png"
						Size = [2, 3]
					}
					{
						File = "walls_66.png"
						Size = [2, 3]
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [2, 3]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [2, 3]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [2, 3]
					}
				]
			}
			OperationalRoofLighting
			{
				Layer = "roof_lights_fancy"
				Offset = [0, 0]
				DamageLevels
				[
					{
						File = "./Data/ships/common/light_blob.png"
						Size = [1.5, 1.5]
						Z = 1.0 // Controls the "height" of the light for the purposes of normal mapping.
						VertexColor = [255*1.0,116*1.0, 24*1.0]
					}
				]
			}
		}
		TubeGraphics
		{
			Type = Graphics
			Location = [1, 1.5]
			OperationalToggle = IsOperational
			NonOperationalDoodad
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "tubes.png"
						Size = [2, 3]
					}
				]
			}
			OperationalDoodad
			{
				Layer = "floors"
				DamageLevels
				[
					{
						AnimationFiles
						[
							"tubes/doodads_on1.png"
							"tubes/doodads_on2.png"
							"tubes/doodads_on3.png"
							"tubes/doodads_on4.png"
							"tubes/doodads_on5.png"
							"tubes/doodads_on6.png"
							"tubes/doodads_on7.png"
							"tubes/doodads_on8.png"
							"tubes/doodads_on9.png"
							"tubes/doodads_on10.png"
							"tubes/doodads_on11.png"
							"tubes/doodads_on12.png"
							"tubes/doodads_on13.png"
							"tubes/doodads_on1.png"
						]
						Size = [2, 3]
						AnimationInterval = 1/20
					}
				]
			}
		}

		BatterySprites
		{
			Type = ResourceSprites
			Location = [1, 1.5]
			ResourceStorage = BatteryStorage
			Layer = "doodads_low"
			HasZeroResourceSprite = false
			ResourceLevels
			[
				{
					File = "batteries1.png"
					Size = [2, 3]
				}
				{
					File = "batteries2.png"
					Size = [2, 3]
				}
				{
					File = "batteries3.png"
					Size = [2, 3]
				}
				{
					File = "batteries4.png"
					Size = [2, 3]
				}
				{
					File = "batteries5.png"
					Size = [2, 3]
				}
				{
					File = "batteries6.png"
					Size = [2, 3]
				}
				{
					File = "batteries7.png"
					Size = [2, 3]
				}
				{
					File = "batteries8.png"
					Size = [2, 3]
				}
			]
		}
		LightTest
		{
			Type = Graphics
			GetColorFrom = TestOne
			Location = [1, 1.5]
			Layer = "roof_doodads"
			Rotation = -90d
			DamageLevels
			[
				{
					File = "particles/impulse.png"
					Size = [2, 3]
				}
			]
		}
		TestOne
		{
			Type = ValueColor
			AlphaFrom = MainThruster
			RedFrom = MainThruster
		}

		MainThruster
		{
			Type = Thruster
			Location = [1, 2]// Relative to upper-left corner of unrotated part.
			Rotation = 90d// Relative to unrotated part.
			OperationalToggle = IsOperational
			Force = &../../ThrusterForce
			MinActivation = 0
			MaxActivation = { BaseValue=1; BuffType=Engine; BuffMode=Multiply; }
			MinUncommandedActivation = &MinActivation
			MaxUncommandedActivation = &MaxActivation
			ActivationIncreaseTime = &../../ThrustIncreaseTime
			ActivationRecoveryTime = &../../ThrustRecoveryTime
			FuelStorage = BatteryStorage
			FuelUsagePerSecond = &../../FuelUsage
		}
		ThrustEffects
		{
			Type = ContinuousEffects
			//Rotation = 90d
			Location = [0, 1.5]
			GetColorFrom = TestOne
			//FactorMediaEffectsIntensityWith = MainThruster
			AnchorMediaEffects = true
			MediaEffects
			[
				&<particles/impulse.rules>
				: /COMMON_SOUNDS/ThrusterRumble
				{
					Sound = "impulse_running.wav"
					Volume = 1
					Speed = 1
					MaxConcurrentVolume = 1
				}
			]
		}
		OperationEffects
		{
			Type = ToggleEffects
			Location = [1, 1.5]
			Toggle = IsOperational
			ToggledOnMediaEffects = &/COMMON_EFFECTS/MachinesOn
			ToggledOffMediaEffects = &/COMMON_EFFECTS/MachinesOff
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyed
			Location = [1, 1.5]
		}

		ThrusterHum
		{
			Type = ContinuousEffects
			Location = [1, 1.5]
			OperationalToggle = IsOperational
			MediaEffects
			[
				: /COMMON_SOUNDS/ThrusterHum
				{
					Volume = .05
					Speed = 1.5
					MaxConcurrentVolume = 1
				}
			]
		}

		Indicators
		{
			Type = IndicatorSprites
			Location = [1, 1.5]
			Layer = "indicators"
			Indicators
			[
				// Turned off.
				{
					Toggle = PowerToggle
					AtlasSprite
					{
						File = &/INDICATORS/PowerOff
						Size = [1, 1]
					}
				}

				// Out of power.
				{
					Toggle = BatteryStorage
					AtlasSprite
					{
						File = &/INDICATORS/NoPower
						Size = [1, 1]
					}
				}
				
				// No crew.
				{
					Toggle = PartCrew
					AtlasSprite
					{
						File = &/INDICATORS/NoCrew
						Size = [1, 1]
					}
				}
			]
		}

		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [2, 3]
		}
	}

	Stats
	{
		ThrusterForce = &~/Part/ThrusterForce
		ThrusterRampUp = &~/Part/ThrustIncreaseTime
		ThrusterPowerUsage = (&~/Part/FuelUsage) / 1000
		PowerCapacity = (&~/Part/Components/BatteryStorage/MaxResources) / 1000

		RecPower = (&ThrusterPowerUsage) / 2
		RecCrew = (&RecPower) * 4
	}
}
