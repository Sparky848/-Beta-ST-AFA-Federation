Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/Deflector_Dish"
	IconNameKey = "Parts/Deflector_Dish_Icon"
	ID = "stafa.fed_deflector_dish_2x2"
	EditorGroup = "StarfleetWeapons"
	DescriptionKey = "Parts/Deflector_Dish_Desc"
	Resources
	[
		[steel, 24]
		[coil2, 8]
		[tristeel, 10]
		[diamond, 2]
	]//to be actually checked, and based on performance
	Size = [2, 2]
	MaxHealth = 4500//old warpcore health lol
	TypeCategories = [weapon, turret, uses_power]
	ReceivableBuffs : ^/0/ReceivableBuffs [DeflectorDebuff, DeflectorCounter]//small ship variant needs manual power
	IsRotateable = true
	IsFlippable = true
	CrewSpeedFactor = 1
	CrewCongestedSpeedFactor = .5	
	SelectionPriority = 1
	InitialPenetrationResistance = 2
	PenetrationRectType = Normal
	ProhibitedBy : ^/0/ProhibitedBy [tall]
	Blueprints : ^/Blueprints/DrawProhibitedZoneCategories [tall]
	ProhibitRects
    [
		[tall, [-1, -1, 4, 1]]
		[tall, [0, -2, 3, 1]]
		[tall, [-1, 0, 1, 3]]
		[tall, [2, 0, 1, 2]]
    ]
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [32, 32]
	}
	Components : ^/0/Components
	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, BatteryStorage]
			Mode = All
		}
		
		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = true
		}

		CommandConsumer
		{
			Type = CommandConsumer
			OperationalToggle = PowerToggle
			CommandPoints = 4
		}

		FireModeToggle
		{
			Type = UIToggle
			ToggleID = "fire_mode"
			Default = 1
			ToggledOnChoices = [0, 1, 2]
		}
		AutoTargetToggle
		{
			Type = ModeToggle
			Mode = FireModeToggle
			OnModes = [1, 2]
		}
		AutoFireToggle
		{
			Type = ModeToggle
			Mode = FireModeToggle
			OnMode = 2
		}
		
		DeflectorMode
		{
			Type = UIToggle
			ToggleID = "deflector_type"
			Default = 0
			AlwaysAllowInBuildMode = true
		}

		DeflectorShieldPulseToggle
		{
			Type = ModeToggle
			Mode = DeflectorMode
			OnMode = 0
		}

		DeflectorShieldPulse
		{
			Type = ToggledComponents
			Toggle = DeflectorShieldPulseToggle
			IncludeInBlueprints = true
			Components = &<fed_dd2x1_shield_drain.rules>/Components
		}

		BatteryStorage
		{
			Type = ResourceStorage
			ResourceType = battery
			MaxResources = 12000
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		CommonGasStorage
		{
			ResourceType = common_gas
			MaxResources = 4000//going to use battery style for this. whereby 1 common_gas resource is 1000 units internally. Gives us more freedom for balancing
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		ElectronGasStorage
		{
			ResourceType = electron_gas
			MaxResources = 2000
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		//Smaller Deflector won't use Ionic Gas, and thus be limited to weaker functions
		InternalCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = BatteryStorage
			Invert = false
			LowColor = [170, 183, 0]
			HighColor = [238, 255, 0]
			FullColor = [238, 255, 0]
			Height = 7
		}
		DeflectorDebuffProvider
		{
			Type = GridBuffProvider
			BuffType = DeflectorDebuff
			GridDistance = 500
			AllowDiagonals = true
			BuffAmount = 1
		}
		DeflectorCounterBuff//not sure which I am going to use yet. I imagine it will be Counter
		{
			Type = GridBuffProvider
			BuffType = DeflectorCounter
			GridDistance = 500
			AllowDiagonals = true
			BuffAmount = 1
		}
		DeflectorCount
		{
			Type = BuffableValue
			Value = { BaseValue=1; BuffType=DeflectorCounter; BuffMode=Add; }
		}
		ShieldPulseTurret
		{
			Type = TurretWeapon
			Location = [.5, 1]
			Rotation = -90d// Relative to unrotated part.
			OperationalToggle = IsOperational
			AutoFireToggle = AutoFireToggle
			//FireInterval = 2/30
			FireInterval = 60
			FiringArc = 10d
			RotateSpeed = 360d
			FireThresholdAngle = 1d
			AIFirepowerRating = 550
			FirePermissionToggle = FireModeToggle
			IgnoreSourceShipLowLOSChecks = true
			Emitter = ShieldPulseBeamEmitter

			AutoTargets
			[
				{
					TargetType = ShipParts
					Toggle = AutoTargetToggle
				}
			]

			BlueprintArcSprite
			{
				Texture = &/INDICATORS/WeaponArc
				Size = [0, 1.5]
				Color = [255, 0, 0, 63]
			}
			BlueprintArcRadius = 10
			BlueprintArcSpriteSegments = 64

			CoverageSectorArc
			{
				Texture = &/INDICATORS/VerticalGradient
				VertexColor = [255, 255, 255, 51]
				QuadCount = 64
			}
		}

		ShieldPulseReloadProgressBar
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = ShieldPulseTurret
			Invert = false
		}
		ShieldPulseBeamEmitter : //&<../../../shots/phaser_lance_nerfed/phaser_lance_nerfed.rules>
		{
			Type = BeamEmitter
			ChainedTo = ShieldPulseTurret
			FireTrigger = ShieldPulseTurret
			GetTargetFrom = ShieldPulseTurret
			OperationalToggle = IsOperational
			FireDelay = 2
			ResourceStorage = ShieldPulseStorage
			ResourcesUsed = 
			MinResourcesUsed = 
			IncludeWhenUnderConstruction = false
		}

		ChargeEffect
		{
			Type = TriggeredEffects
			ChainedTo = ShieldPulseTurret
			Trigger = ShieldPulseTurret
			Location = [.5, 1]
			AnchorMediaEffects = true

			MediaEffects
			[
				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "charge.wav"//temp
					Volume = .25
					Speed = 1.5
				}
			]
		}
		Graphics
		{
			Type = Graphics
			Location = [1, 1]
			OperationalToggle = IsOperational
			Floor
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [2, 2]
					}
					{
						File = "floor_33.png"
						Size = [2, 2]
					}
					{
						File = "floor_66.png"
						Size = [2, 2]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				Offset = [0, 0]
				DamageLevels
				[
					{
						File = "walls.png"
						Size = [2, 2]
					}
					{
						File = "walls_33.png"
						Size = [2, 2]
					}
					{
						File = "walls_66.png"
						Size = [2, 2]
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				Location = [1, 1]
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [2, 2]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [2, 2]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [2, 2]
					}
				]
			}
		}

		OperationEffects
		{
			Type = ToggleEffects
			Location = [1, 1]
			Toggle = IsOperational
			ToggledOnMediaEffects = &/COMMON_EFFECTS/PowerOn
			ToggledOffMediaEffects = &/COMMON_EFFECTS/PowerOff
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyed
			Location = [1, 1]
		}
		Indicators
		{
			Type = IndicatorSprites
			Location = [1, 1]
			Layer = "indicators"
			Indicators
			[
				// Turned off.
				{
					Toggle = PowerToggle
					AtlasSprite
					{
						File = &/INDICATORS/PowerOff
						Size = [1, 1]
					}
				}

				// Out of power.
				{
					Toggle = BatteryStorage
					//Delay = &~/Part/Components/Turret/FireInterval
					//Delay = 0.49
					AtlasSprite
					{
						File = &/INDICATORS/NoPower
						Size = [1, 1]
					}
				}
				
				// No crew.
				{
					Toggle = PartCrew
					ShowInBuildMode = true
					AtlasSprite
					{
						File = &/INDICATORS/NoCrew
						Size = [1, 1]
					}
				}
			]
		}
		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [2, 2]
		}
	}
}

