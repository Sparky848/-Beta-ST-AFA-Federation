	TurretGraphicsLeft
	{
		Type = Graphics
		//ChainedTo = TurretLeft
		Location = [0.65625, -1.5]
		Rotation = 0d
		//OperationalToggle = IsOperational
		OperationalDoodad
		{
			Layer = "doodads_low"
			DamageLevels
			[
				{
					File = "turret1.png"
					NormalsFile = "turret1_normals.png"
					Size = [.4375, 3]
					//Offset = [0, 0]
				}
				{
					File = "turret1.png"
					NormalsFile = "turret1_normals.png"
					Size = [.4375, 3]
				//	Offset = [0, -0.75]
				}
				{
					File = "turret1.png"
					NormalsFile = "turret1_normals.png"
					Size = [.4375, 3]
				//	Offset = [0, -0.75]
				}
			]
		}
	}
}


IndicatorsLeft
{
	Type = IndicatorSprites
	Location = [.5, 1.5]
	Layer = "indicators"
	Indicators
	[
		// Turned off.
		{
			Toggle = PowerToggle
			AtlasSprite
			{
				File = &/INDICATORS/PowerOff
				Size = [.5, .5]
			}
		}
		// Out of power.
		{
			Toggle = BatteryStorage
			Delay = (&~/Part/Components/TurretLeft/FireInterval) * 5
			AtlasSprite
			{
				File = &/INDICATORS/NoPower
				Size = [.5, .5]
			}
		}
		
		// No crew.
		{
			Toggle = PartCrew
			AtlasSprite
			{
				File = &/INDICATORS/NoCrew
				Size = [.5, .5]
			}
		}
	]
}

Stats
{
	CrewRequired = &~/Part/Components/PartCrew/Crew
	PowerCapacity = (&~/Part/Components/BatteryStorage/MaxResources) / 200

	RecPower = &../StatsByCategory/0/Stats/PowerPerSecond
	RecCrew = (&CrewRequired) + (&RecPower) * 4
}

StatsByCategory
[
	{
		NameKey = "StatCategories/PhaserBolt"
		Stats
		{
			DamagePerShot = &~/Part/Components/BulletEmitterLeft/Bullet/Components/DamagePool/Damage
			DamagePerSecond = (&DamagePerShot) * (&ROF)
			Damage = [&../DamagePerShot, &../DamagePerSecond]
			ROF = 1 / (&~/Part/Components/TurretLeft/FireInterval)
			RangeLimited = [&~/Part/Components/BulletEmitterLeft/Bullet/Range/BaseValue, &~/Part/Components/BulletEmitterLeft/Bullet/Range/MaxValue]
			Arc = deg(&~/Part/Components/TurretLeft/FiringArc)
			TurretSpeed = deg(&~/Part/Components/TurretLeft/RotateSpeed)
			ShotSpeed = &~/Part/Components/BulletEmitterLeft/Bullet/Speed/BaseValue
			ShotHP = &~/Part/Components/BulletEmitterLeft/Bullet/Components/Targetable/Health
			PowerPerShot = (&~/Part/Components/BulletEmitterLeft/ResourcesUsed) / 1000
			PowerPerSecond = (&PowerPerShot) * (&ROF)
			ShotPowerUsage = [(&../PowerPerShot) / 5, &../PowerPerSecond]
		}
	}
]