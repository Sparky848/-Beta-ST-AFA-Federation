					File = "floor_corner.png"
				}
				{
					File = "floor_corner_33.png"
				}
				{
					File = "floor_corner_66.png"
				}
			]
		}
		: ~/SPLIT_3WAY
		{
			DamageLevelSprites
			[
				{
					File = "floor_3way.png"
				}
				{
					File = "floor_3way_33.png"
				}
				{
					File = "floor_3way_66.png"
