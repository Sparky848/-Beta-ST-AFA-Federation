HUB
{
	SituationCode = "0000"
	AllowRotation = false
}
STUB
{
	SituationCode = "0010"
}
STRAIGHT
{
	SituationCode = "1010"
}
CORNER
{
	SituationCode = "0110"
}
SPLIT_3WAY
{
	SituationCode = "1110"
}
SPLIT_4WAY
{
	SituationCode = "1111"
}

BASE_BLEND_SPRITES
{
	Type = ToggledBlendSprites
	Location = [0.5, 0.5]
	SituationToggles
	[
		Port_Up
		Port_Right
		Port_Down
		Port_Left
	]
}

FloorBlendSprites : BASE_BLEND_SPRITES
{
	Layer = "floors"
	AmbiguousSprites
	[
		: ~/HUB
		{
			DamageLevelSprites 
			[
				{
					File = "floor_hub.png"
				}
				{
					File = "floor_hub_33.png"
				}
				{
					File = "floor_hub_66.png"
				}
			]
		}
		: ~/STUB
		{
			DamageLevelSprites 
			[
				{
					File = "floor_stub.png"
				}
				{
					File = "floor_stub_33.png"
				}
				{
					File = "floor_stub_66.png"
				}
			]
		}
		: ~/STRAIGHT
