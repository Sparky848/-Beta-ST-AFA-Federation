Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/Deflector_Dish_4x3"
	IconNameKey = "Parts/Deflector_Dish_4x3Icon"
	ID = "stafa.fed_deflector_dish_4x3"
	EditorGroup = "StarfleetWeapons"
	DescriptionKey = "Parts/Deflector_Dish_4x3Desc"
	Resources
	[
		[steel, 48]
		[coil2, 16]
		[tristeel, 18]
		[diamond, 3]
	]//to be actually checked, and based on performance
	Size = [4, 3]
	MaxHealth = 15000
	TypeCategories = [weapon, turret, uses_power]
	ReceivableBuffs : ^/0/ReceivableBuffs [DeflectorDebuff, DeflectorCounter, AntimatterPower]
	IsRotateable = true
	IsFlippable = true
	CrewSpeedFactor = .5
	CrewCongestedSpeedFactor = .5	
	SelectionPriority = 1
	InitialPenetrationResistance = 2
	PenetrationRectType = Normal
	AllowedDoorLocations
	[
		[0, 3]
		[1, 3]
		[2, 3]
		[3, 3]
	]
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [72, 42]
	}
	Components : ^/0/Components
	{
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, BatteryStorage, PartCrew]
			Mode = All
		}
		
		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = true
		}

		CommandConsumer
		{
			Type = CommandConsumer
			OperationalToggle = PowerToggle
			CommandPoints = 10
		}

		FireModeToggle
		{
			Type = UIToggle
			ToggleID = "fire_mode"
			Default = 1
			ToggledOnChoices = [0, 1, 2]
		}
		AutoTargetToggle
		{
			Type = ModeToggle
			Mode = FireModeToggle
			OnModes = [1, 2]
		}
		AutoFireToggle
		{
			Type = ModeToggle
			Mode = FireModeToggle
			OnMode = 2
		}
		
		DeflectorMode
		{
			Type = UIToggle
			ToggleID = "deflector_type"
			Default = 0
			AlwaysAllowInBuildMode = true
		}

		DeflectorShieldPulseToggle
		{
			Type = ModeToggle
			Mode = DeflectorMode
			OnMode = 0
		}

		DeflectorShieldPulse
		{
			Type = ToggledComponents
			Toggle = DeflectorShieldPulseToggle
			IncludeInBlueprints = true
			Components = &<fed_dd4x3_shield_drain.rules>/Components
		}

		DeflectorEnergyDrainToggle
		{
			Type = ModeToggle
			Mode = DeflectorMode
			OnMode = 1
		}

		DeflectorEnergyDrain
		{
			Type = ToggledComponents
			Toggle = DeflectorEnergyDrainToggle
			IncludeInBlueprints = true
			Components = &<fed_dd4x3_energy_drain.rules>/Components
		}

		DeflectorGravitonToggle
		{
			Type = ModeToggle
			Mode = DeflectorMode
			OnMode = 2
		}

		DeflectorGraviton
		{
			Type = ToggledComponents
			Toggle = DeflectorGravitonToggle
			IncludeInBlueprints = true
			Components = &<fed_dd4x3_graviton.rules>/Components
		}

		BatteryStorage
		{
			Type = ResourceStorage
			ResourceType = battery
			MaxResources = 48000
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		BatteryConsumer
		{
			Type = ResourceConsumer
			ResourceType = battery
			Storage = BatteryStorage
			DefaultPriority = &/PRIORITIES/Weapon_Supply
			ResupplyThreshold = 500
