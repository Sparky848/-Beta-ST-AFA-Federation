Components
{
	Weapon
	{
		Type = FixedWeapon
		Location = [2, 0.5]
		Rotation =-90d// Relative to unrotated part.
		OperationalToggle = IsOperational
		AutoFireToggle = AutoFireToggle
		FireInterval = { BaseValue=42.0; BuffType=DeflectorCounter; BuffMode=Multiply; MaxValue=100; }
		AIFirepowerRating = 1200
		FirePermissionToggle = FireModeToggle
		IgnoreSourceShipLowLOSChecks = true
		IgnoreJunkLOSChecks = true
		Emitter = BeamEmitter

		AutoTarget
		{
			TargetType = ShipParts
			Toggle = AutoTargetToggle
		}

		CoverageLine//Probably either change to a blue, or change colour based on selected mode
		{
				LineSprite
			{
				Texture = &/INDICATORS/RadialGradient
				VertexColor = [79, 253, 178, 191]
				UVRect = [.5, 0, 0, 1]
			}
			LineThickness = 2

			BeginCapSprite : LineSprite
			{
				UVRect = [0, 0, .5, 1]
			}
			BeginCapSize = [1, 2]

			EndCapSprite : LineSprite
			{
				UVRect = [.5, 0, .5, 1]
			}
			EndCapSize = [1, 2]
		}
	}
	ReloadProgressBar
	{
		Type = ProgressBar
		OperationalToggle = IsOperational
		ShowProgressFor = Weapon
		Invert = false
	}

	BeamEmitter : &<../../../shots/deflector_graviton/deflector_graviton_beam_4x3.rules>
	{
		Type = BeamEmitter
		Location = [0.45, 0]
		ChainedTo = Weapon
		FireTrigger = Weapon
		GetTargetFrom = Weapon
		OperationalToggle = IsOperational
		FireDelay = 5
		ResourceStorage = BatteryStorage
		ResourcesUsed = 11999
		MinResourcesUsed = 1
	}
	ResourceUser : &<../../../shots/empty_beam/med/empty_beam_graviton.rules>
	{
		Type = BeamEmitter
		Location = [0.45, 0]
		ChainedTo = Weapon
		FireTrigger = Weapon
		GetTargetFrom = Weapon
		OperationalToggle = IsOperational
		FireDelay = 7
		ResourceStorage = CloudyGasStorage
		ResourcesUsed = 8
		MinResourcesUsed = 8
	}
	ResourceUser2 : &<../../../shots/empty_beam/med/empty_beam_graviton.rules>
	{
		Type = BeamEmitter
		Location = [0.45, 0]
		ChainedTo = Weapon
		FireTrigger = Weapon
		GetTargetFrom = Weapon
		OperationalToggle = IsOperational
		FireDelay = 7
		ResourceStorage = ElectronGasStorage
		ResourcesUsed = 1
		MinResourcesUsed = 1
	}



	ChargeEffect
	{
		Type = TriggeredEffects
		ChainedTo = Weapon
		Trigger = Weapon
		Location = [0.5, 3]
		AnchorMediaEffects = true

		MediaEffects
		[
			: /BASE_SOUNDS/AudioExterior
			{
				Sound = "charge.wav"
				Volume = .25
				Speed = 1.5
			}
		]
	}
}
