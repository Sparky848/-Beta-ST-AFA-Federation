Components
{
	Weapon
	{
		Type = FixedWeapon
		Location = [3, 0.6]
		Rotation =-90d// Relative to unrotated part.
		OperationalToggle = IsOperational
		AutoFireToggle = AutoFireToggle
		FireInterval = { BaseValue=80.0; BuffType=DeflectorCounter; BuffMode=Multiply; MaxValue=230; }
		AIFirepowerRating = 1750
		FirePermissionToggle = FireModeToggle
		IgnoreSourceShipLowLOSChecks = true
		IgnoreJunkLOSChecks = true
		Emitter = BeamEmitter

		AutoTarget
		{
			TargetType = ShipParts
			Toggle = AutoTargetToggle
		}

		CoverageLine//Probably either change to a blue, or change colour based on selected mode
		{
			LineSprite
			{
				Texture = &/INDICATORS/RadialGradient
				VertexColor = [145, 93, 163, 191]
				UVRect = [.5, 0, 0, 1]
			}
			LineThickness = 2

			BeginCapSprite : LineSprite
			{
				UVRect = [0, 0, .5, 1]
			}
			BeginCapSize = [1, 2]

			EndCapSprite : LineSprite
			{
				UVRect = [.5, 0, .5, 1]
			}
			EndCapSize = [1, 2]
		}
	}
	ReloadProgressBar
	{
		Type = ProgressBar
		OperationalToggle = IsOperational
		ShowProgressFor = Weapon
		Invert = false
	}

	BeamEmitter : &<../../../shots/deflector_energy_drain/deflector_energy_drain_4x4.rules>
	{
		Type = BeamEmitter
		//Location = [0.55, 0]
		ChainedTo = Weapon
		FireTrigger = Weapon
		GetTargetFrom = Weapon
		OperationalToggle = IsOperational
		FireDelay = 11
		ResourceStorage = BatteryStorage
		ResourcesUsed = 59999
		MinResourcesUsed = 59999
	}
	ResourceUser : &<../../../shots/empty_beam/large/empty_beam_energy_drain.rules>
	{
		Type = BeamEmitter
		//Location = [0.55, 0]
		ChainedTo = Weapon
		FireTrigger = Weapon
		GetTargetFrom = Weapon
		OperationalToggle = IsOperational
		FireDelay = 11
		ResourceStorage = CloudyGasStorage
		ResourcesUsed = 25
		MinResourcesUsed = 25
	}
	ResourceUser2 : &<../../../shots/empty_beam/large/empty_beam_energy_drain.rules>
	{
		Type = BeamEmitter
		//Location = [0.55, 0]
		ChainedTo = Weapon
		FireTrigger = Weapon
		GetTargetFrom = Weapon
		OperationalToggle = IsOperational
		FireDelay = 11
		ResourceStorage = ElectronGasStorage
		ResourcesUsed = 16
		MinResourcesUsed = 16
	}


	ChargeEffect
	{
		Type = TriggeredEffects
		ChainedTo = Weapon
		Trigger = Weapon
		Location = [0.5, 3]
		AnchorMediaEffects = true

		MediaEffects
		[
			: /BASE_SOUNDS/AudioExterior
			{
				Sound = "charge.wav"
				Volume = .25
				Speed = 1.5
			}
		]
	}
}
