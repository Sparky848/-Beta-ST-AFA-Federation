		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [6, 3]
		}
		//Heat Stat Providers
		HeatDissipationStatDenominator
		{
			Type = StaticValue
			Value = (&<./Data/statuses/heat/heat.rules>/STATUS_TO_RESOURCE_RATIO) * (&~/Part/Components/HeatDissipationConverter/Interval)
		}

		HeatDissipationStatValue
		{
			Type = StaticValue
			Value = (&~/Part/Components/HeatDissipationConverter/Dissipation_Per_Second)
		}

		HeatDissipationStatProvider
		{
			Type = StatProvider
			Stat = HeatDissipation
			ValueFrom = HeatDissipationStatValue
		}
	}
	Stats
	{
		CrewRequired = &~/Part/Components/PartCrew/Crew
		PowerCapacity = (&~/Part/Components/BatteryStorage/MaxResources) / 1000
		SightRange = &~/Part/Components/Sensor/SightRadius
		RadarRange = &~/Part/Components/Sensor/RadarRadius
		HeatCapacity = (&~/Part/Components/HeatBuffer/MaxResources) / (&<./Data/statuses/heat/heat.rules>/STATUS_TO_RESOURCE_RATIO)
		HeatDissipation = (&~/Part/Components/HeatDissipationConverter/FromQuantity) / (&~/Part/Components/HeatDissipationConverter/Interval) / (&<./Data/statuses/heat/heat.rules>/STATUS_TO_RESOURCE_RATIO)
	}
}

