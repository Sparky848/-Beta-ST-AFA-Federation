		{
			Type = IndicatorSprites
			Location = [3, 1.5]
			Layer = "indicators"
			Indicators
			[
				// Turned off.
				{
					Toggle = PowerToggle
					AtlasSprite
					{
						File = &/INDICATORS/PowerOff
						Size = [1, 1]
					}
				}

				// Out of power.
				{
					Toggle = BatteryStorage
					//Delay = &~/Part/Components/Turret/FireInterval
					//Delay = 0.49
