Components
{
	MissileStorage
	{
		Type = ResourceStorage
		ResourceType = transphasic_torpedo_part
		MaxResources = 20
		ToggleOnResources = 20
		ToggleOffResources = 19
		DelayBeforeReadyToUse = 10
		UITileRect = [.5 + 7/64, 1 + 7/64, 1 - 14/64, 1 - 14/64]
		ReceiveResourceMediaEffects = &/COMMON_EFFECTS/MissileLoad
		DropResourcesWhenDestroyed = false
		DropResourcesWhenRemoved = true
	}
	Consumer
	{
		Type = ResourceConsumer
		ResourceType = transphasic_torpedo_part
		Storage = MissileStorage
		DefaultPriority = &/PRIORITIES/Weapon_Supply
		OperationalToggle = PowerToggle
		ConsumptionToggleButtonOffset = [0, -.4]
	}
	BatteryStorage
	{
		Type = ResourceStorage
		ResourceType = battery
		MaxResources = 20000
		ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
	}
	InternalCapacity
	{
		Type = ProgressBar
		OperationalToggle = IsOperational
		ShowProgressFor = BatteryStorage
		Invert = false
		LowColor = [170, 183, 0]
		HighColor = [238, 255, 0]
		FullColor = [238, 255, 0]
		Height = 5
	}
	BatteryConsumer
	{
		Type = ResourceConsumer
		ResourceType = battery
		Storage = BatteryStorage
		DefaultPriority = &/PRIORITIES/Weapon_Supply
		ResupplyThreshold = 1
		OperarionalToggle = PowerToggle
	}
	MissilesPrereq
	{
		Type = MultiToggle
		Toggles = [MissileStorage]
		Mode = Any
	}

	Weapon
	{
		Type = TurretWeapon
		Location = [1, 0.4]
		Rotation = -90d
		Emitter = Emitter
		OperationalToggle = IsOperational
		AutoFireToggle = AutoFireToggle
		FireInterval = 0 // Uses common reload timer.
		FiringArc = 10d
		TargetingArc = 10d
		ValidArc = 10d
		FireThresholdAngle = (&TargetingArc) / 2
		RotateSpeed = 10d
		AllowFireWithBlockedLOS = true
		AIFirepowerRating = 6200
		FirePermissionToggle = FirePermissionToggle

		AutoTargets
		[
			{
				TargetType = ShipParts
				Toggle = AutoTargetToggle
				EnableInDirectControlMode = true
			}
		]

		BlueprintArcSprite
		{
			Texture = &/INDICATORS/WeaponArc
			Size = [0, 1.5]
			Color = [255, 0, 0, 63]
		}
		BlueprintArcRadius = 10
		BlueprintArcSpriteSegments = 64

		CoverageSectorArc
		{
			Texture = &/INDICATORS/VerticalGradient
			VertexColor = [255, 255, 255, 51]
			QuadCount = 64
		}
	}
	FirePermissionToggle
	{
		Type = MultiToggle
		Toggles = [CommonReloadTimerQuiteLong, FireModeToggle]
		Mode = All
	}

	ReloadProgressBar
	{
		Type = ProgressBar
		OperationalToggle = IsOperational
		ShowProgressFor = CommonReloadTimerQuiteLong
		Invert = true
	}

	CommonReloadResetTrigger
	{
		Type = MultiTrigger
		Triggers = [Weapon]
	}

	Emitter
	{
		Type = BulletEmitter
		ChainedTo = Weapon
		OperationalToggle = IsOperational
		FireTrigger = Weapon
		GetTargetFrom = Weapon
		ResourceUsage
			[
				{
					ResourceStorage = MissileStorage
					ResourcesUsed = 20
				}
				{
					ResourceStorage = BatteryStorage
					ResourcesUsed = 20000
				}
			]
		Bullet = &<../../../../shots/transphasic_torpedo_shot_nerfed/transphasic_torpedo_shot.rules>
		TargetLeadPrediction = false
		Recoil = 1500
	}

	LaunchEffect
	{
		Type = TriggeredEffects
		ChainedTo = Weapon
		Trigger = Weapon

		MediaEffects
		[
			&<../particles/transphasic_torpedo_shot.rules>
			&<../particles/transphasic_torpedo_flash.rules>

			: /BASE_SOUNDS/AudioExterior
			{
				Sound = "../../../../shots/transphasic_torpedo_shot/transphasic_torpedo_shot.wav"
				Speed = 0.75
				SpeedVariation = .1
			}
		]
	}

	External_Walls_Graphics
	{
		Type = Graphics
		Location = [1, 1]
		Walls
		{
			Layer = "external_walls"
			DamageLevels
			[
				{
					File = "external_walls.png"
					NormalsFile = "external_walls_normals.png"
					Size = [2, 3]
				}
				{
					File = "external_walls_33.png"
					NormalsFile = "external_walls_normals_33.png"
					Size = [2, 3]
				}
				{
					File = "external_walls_66.png"
					NormalsFile = "external_walls_normals_66.png"
					Size = [2, 3]
				}
			]
		}
	}

	MissileSprites
	{
		Type = ResourceSprites
		Location = [1, 1.6]
		ResourceStorage = MissileStorage
		Layer = "weapons"
		HasZeroResourceSprite = true
		ResourceLevels
		[
			{
				File = "missile_0.png"
				Offset = [0, 1]
				Size = [2, 1]
			}
			{
				File = "missile_1.png"
				NormalsFile = "missile_normals_1.png"
				Offset = [0, 0.5]
				Size = [2, 2]
			}
			{
				File = "missile_1.png"
				NormalsFile = "missile_normals_1.png"
				Offset = [0, 0.5]
				Size = [2, 2]
			}
			{
				File = "missile_1.png"
				NormalsFile = "missile_normals_1.png"
				Offset = [0, 0.5]
				Size = [2, 2]
			}
			{
				File = "missile_2.png"
				NormalsFile = "missile_normals_2.png"
				Offset = [0, 0.5]
				Size = [2, 2]
			}
			{
				File = "missile_2.png"
				NormalsFile = "missile_normals_2.png"
				Offset = [0, 0.5]
				Size = [2, 2]
			}
			{
				File = "missile_2.png"
				NormalsFile = "missile_normals_2.png"
				Offset = [0, 0.5]
				Size = [2, 2]
			}
			{
				File = "missile_2.png"
				NormalsFile = "missile_normals_2.png"
				Offset = [0, 0.5]
				Size = [2, 2]
			}
			{
				File = "missile_3.png"
				NormalsFile = "missile_normals_3.png"
				Size = [2, 3]
			}
			{
				File = "missile_3.png"
				NormalsFile = "missile_normals_3.png"
				Size = [2, 3]
			}
			{
				File = "missile_3.png"
				NormalsFile = "missile_normals_3.png"
				Size = [2, 3]
			}
			{
				File = "missile_3.png"
				NormalsFile = "missile_normals_3.png"
				Size = [2, 3]
			}
			{
				File = "missile_4.png"
				NormalsFile = "missile_normals_4.png"
				Size = [2, 3]
			}
		]
	}

	DestroyedEffects
	{
		Type = DeathEffects
		MediaEffects = &/COMMON_EFFECTS/BigPartDestroyed
		Location = [1, 2]

		FactorHitEffectsWith = MissileStorage
		HitEffects
		[
			{
				Type = ExplosiveDamage
				TotalDamage = 150000
				Radius = 20
				Delay = .1
				FireChancePerNDamage = 50%
				NDamage = 1000
				CrewKillChance = 50%
				Filter
				{
					OperationalHealth = true
					StructuralHealth = false
					Friendlies = true
				}
			}
			{
				Type = ExplosiveDamage
				TotalDamage = 100000
				Radius = 15
				Delay = .1
				Filter
				{
					OperationalHealth = false
					StructuralHealth = true
					Friendlies = true
					Crew = false
				}
			}
		]
	}

	Indicators
	{
		Type = IndicatorSprites
		Location = [1, 2]
		Layer = "indicators"
		Indicators
		[
			// Turned off.
			{
				Toggle = PowerToggle
				AtlasSprite
				{
					File = &/INDICATORS/PowerOff
					Size = [1, 1]
				}
			}

			// Out of missiles.
			{
				Toggle = MissileStorage
				Delay = &<../fed_torpedo_launcher.rules>/Part/Components/CommonReloadTimerQuiteLong/Duration
				AtlasSprite
				{
					File =  &/INDICATORS/NoTransphasic
					Size = [1, 1]
				}
			}

			// No crew.
			{
				Toggle = PartCrew
				AtlasSprite
				{
					File = &/INDICATORS/NoCrew
					Size = [1, 1]
				}
			}
			// Out of power.
			{
				Toggle = BatteryStorage
				Delay = &<../fed_torpedo_launcher.rules>/Part/Components/CommonReloadTimerQuiteLong/Duration
				AtlasSprite
				{
					File = &/INDICATORS/NoPower
					Size = [.5, .5]
				}
			}
		]
	}
}

MissileStats
{
	NameKey = "StatCategories/transphasicTorpedoLauncher"
	Stats
	{
		DamagePerShot = &~/Components/Emitter/Bullet/Stage2/Components/Hit/HitOperational/HitEffects/0/TotalDamage
		DamagePerSecond = (&DamagePerShot) * (&ROF)
		Damage = [&../DamagePerShot, &../DamagePerSecond]
		DamageArea = &~/Components/Emitter/Bullet/Stage2/Components/Hit/HitOperational/HitEffects/0/Radius
		ROF = 1 / (&<../fed_torpedo_launcher.rules>/Part/Components/CommonReloadTimerQuiteLong/Duration)
		RangeLimited = [&~/Part/Components/Bullet/Range/BaseValue, &~/Part/Components/Bullet/Range/MaxValue]
		Arc = deg(&~/Components/Weapon/ValidArc)
		ShotLaunchSpeed = &~/EmitterBase/Bullet/Speed/BaseValue
		Acceleration = &~/Components/Emitter/Bullet/Stage2/Components/BoostAcceleration/Acceleration
		AccelerationDelay = &~/Components/Emitter/Bullet/Components/DeployDeath/Lifetime
		ShotHP = &~/Components/Emitter/Bullet/Components/Targetable/Health
		MissileParts = &~/Components/Emitter/ResourcesUsed
	}
}
