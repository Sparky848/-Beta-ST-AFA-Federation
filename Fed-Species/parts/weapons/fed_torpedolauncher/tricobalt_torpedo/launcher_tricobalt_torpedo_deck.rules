EditorIcon
{
	Texture
	{
		File = "temp_logo.png"
		SampleMode = Linear
	}
	Size = [40, 100]
}
Components
{
	
	MissileStorageA : ~/MissileStorageBase
	{
		// Nothing different.
	}

	MissileStorageB : ~/MissileStorageBase
	{
		// Nothing different.
	}

	

	CombinedMissileStorage
	{
		Type = MultiResourceStorage
		ResourceType = tricobalt_torpedo_part
		ResourceStorages = [MissileStorageA, MissileStorageB]
		AddMode = PrioritizeLeastEmptyCapacity
		RemoveMode = PrioritizeMostEmptyCapacity
		ToggleOnResources = 16
		ReceiveResourceMediaEffects = &/COMMON_EFFECTS/MissileLoad
		UITileRect = [.5 + 7/64, 1 + 7/64, 1 - 14/64, 1 - 14/64]
	}

	Consumer
	{
		Type = ResourceConsumer
		ResourceType = tricobalt_torpedo_part
		Storage = CombinedMissileStorage
		DefaultPriority = &/PRIORITIES/Weapon_Supply
		OperationalToggle = PowerToggle
		ConsumptionToggleButtonOffset = [0, -.4]
	}

	MissilesPrereq
	{
		Type = MultiToggle
		Toggles = [MissileStorageA, MissileStorageB]
		Mode = All
	}

	

	WeaponA : ~/WeaponBase
	{
		Location = [.7, 1]
		ShowExplicitTarget = false
		Emitter = EmitterA
	}	

	EmitterA : ~/EmitterBase
	{
		ChainedTo = WeaponA
		FireTrigger = WeaponA
		GetTargetFrom = WeaponA
		ResourceStorage = MissileStorageA
	}

	WeaponB : ~/WeaponBase
	{
		Location = [1.3, 1]
		Emitter = EmitterB

		CoverageSectorArc
		{
			Texture = &/INDICATORS/VerticalGradient
			VertexColor = [255, 255, 255, 51]
			QuadCount = 64
		}
	}

	EmitterB : ~/EmitterBase
	{
		ChainedTo = WeaponB
		FireTrigger = WeaponB
		GetTargetFrom = WeaponB
		ResourceStorage = MissileStorageB
	}

	LaunchEffectA : ~/LaunchEffectBase
	{
		ChainedTo = WeaponA
		Trigger = WeaponA
	}

	LaunchEffectB : ~/LaunchEffectBase
	{
		ChainedTo = WeaponB
		Trigger = WeaponB
	}

	FirePermissionToggle
	{
		Type = MultiToggle
		Toggles = [CommonReloadTimerVeryShort, FireModeToggle, CombinedMissileStorage]
		Mode = All
	}

	ReloadProgressBar
	{
		Type = ProgressBar
		OperationalToggle = IsOperational
		ShowProgressFor = CommonReloadTimerShort//CommonReloadTimerLong
		Invert = true
	}
	/*TurretReloadBar
	{
		Type = ProgressBar
		OperationalToggle = IsOperational
		ShowProgressFor = ~/WeaponBase/FireInterval
		Invert = false
		LowColor = [112, 166, 167]
		HighColor = [180, 243, 244]
		FullColor = [180, 243, 244]
		Height = 4
	}*/
	CommonReloadResetTrigger
	{
		Type = MultiTrigger
		Triggers = [WeaponA, WeaponB]
	}

	
	/*ExternalWallsGraphics
	{
		Type = Graphics
		Location = [1, 2]
		Walls
		{
			Layer = "external_walls"
			DamageLevels
			[
				{
					File = "walls_outer.png"
					NormalsFile = "walls_outer_normals.png"
					Size = [2, 4]
				}
				{
					File = "walls_outer.png"
					NormalsFile = "walls_outer_normals.png"
					Size = [2, 4]
				}
				{
					File = "walls_outer.png"
					NormalsFile = "walls_outer_normals.png"
					Size = [2, 4]
				}
			]
		}
	}*/
	TricobaltLighting
	{
		Type = Graphics
		Location = [1, 2]
		OperationalToggle = IsOperational
		OperationalLighting
		{
			Layer = "lights_add"
			Offset = [0, 1]
			DamageLevels
			[
				{
					File = "lights.png"
					Size = [2, 2]
				}
			]
		}
		OperationalRoofDoodad
		{
			Layer = "roof_doodads"
			Offset = [0, 0.5]
			DamageLevels
			[
				{
					File = "roof_glows.png"
					Size = [2, 1]
				}
				{
					File = "roof_glows_33.png"
					Size = [2, 1]
				}
				{
					File = "roof_glows_66.png"
					Size = [2, 1]
				}
			]
		}
		OperationalRoofLighting
		{
			Layer = "roof_lights_fancy"
			Offset = [0, 1.17]
			DamageLevels
			[
				{
					File = "./Data/ships/common/light_blob.png"
					Size = [3.5, 3.5]
					Z = 0.5 // Controls the "height" of the light for the purposes of normal mapping. Set to -1 (or any negative number) to disable normal lighting for this light.
					VertexColor = [195*1.25, 236*1.25, 225*1.25]
				}
			]
		}
	}

	MissileSpritesA
	{
		Type = ResourceSprites
		Location = [.6, 1.6] //[.7, 1.6]
		ResourceStorage = MissileStorageA
		Layer = "weapons"
		HasZeroResourceSprite = true
		ResourceLevels
		[
			{
