			}
			{
				File = "missile_3.png"
				NormalsFile = "missile_normals_3.png"
				Size = [1, 3]
			}
			{
				File = "missile_4.png"
				NormalsFile = "missile_normals_4.png"
				Size = [1, 3]
			}
			{
				File = "missile_4.png"
				NormalsFile = "missile_normals_4.png"
				Size = [1, 3]
			}
			{
				File = "missile_5.png"
				NormalsFile = "missile_normals_5.png"
				Size = [1, 3]
			}
		]
	}

	MissileSpritesB : MissileSpritesA
	{
		Location = [1.4, 1.6]//[1.3, 1.6]
		ResourceStorage = MissileStorageB
	}

	DestroyedEffects
	{
		Type = DeathEffects
		MediaEffects = &/COMMON_EFFECTS/BigPartDestroyed
		Location = [1, 2]

		FactorHitEffectsWith = CombinedMissileStorage
		HitEffects
		[
			{
				Type = ExplosiveDamage
				TotalDamage = 80000//60000
				Radius = 6//5
				Delay = .05
				FireChancePerNDamage = 50%
				NDamage = 1000
				CrewKillChance = 50%
				Filter
				{
					OperationalHealth = true
					StructuralHealth = false
					Friendlies = true
				}
			}
			{
				Type = ExplosiveDamage
				TotalDamage = 20000
				Radius = 4
				Delay = .05
				Filter
				{
					OperationalHealth = false
					StructuralHealth = true
					Friendlies = true
					Crew = false
				}
			}
		]
	}

	Indicators
	{
		Type = IndicatorSprites
		Location = [1, 2]
		Layer = "indicators"
		Indicators
		[
			// Turned off.
			{
				Toggle = PowerToggle
				AtlasSprite
				{
					File = &/INDICATORS/PowerOff
					Size = [1, 1]
				}
			}

			// Out of missiles.
			{
				Toggle = MissilesPrereq
				Delay = &<../fed_torpedo_launcher.rules>/Part/Components/CommonReloadTimerShort/Duration
				AtlasSprite
				{
					File =  &/INDICATORS/NoTricobalt
					Size = [1, 1]
				}
			}

			// No crew.
			{
				Toggle = PartCrew
				AtlasSprite
				{
					File = &/INDICATORS/NoCrew
					Size = [1, 1]
				}
			}
		]
	}
}

WeaponBase
{
	Type = TurretWeapon
	Location = [1, 1]
	Rotation = -90d
	Emitter = Emitter
	OperationalToggle = IsOperational
	AutoFireToggle = AutoFireToggle
	IgnoreSourceShipLowLOSChecks = true
	FireInterval = 12
	FiringArc = 0d
	TargetingArc = 200d
	ValidArc = 200d
	FireThresholdAngle = 2d
	RotateSpeed = 360d
	AllowFireWithBlockedLOS = true
	AIFirepowerRating = 4800
	FirePermissionToggle = FirePermissionToggle
	IgnoreFriendlyShipLowLOSChecks = true

	AutoTargets
	[
		{
			TargetType = ShipParts
			Toggle = AutoTargetToggle
			EnableInDirectControlMode = true
		}
	]

	BlueprintArcSprite
	{
		Texture = &/INDICATORS/WeaponArc
		Size = [0, 1.5]
		Color = [255, 0, 0, 63]
	}
	BlueprintArcRadius = 10
	BlueprintArcSpriteSegments = 64

	CoverageSectorArc
	{
		Texture = &/INDICATORS/VerticalGradient
		VertexColor = [255, 255, 255, 51]
		QuadCount = 64
	}
}

EmitterBase
{
	Type = BulletEmitter
	OperationalToggle = IsOperational
	ResourcesUsed = 8
	Bullet = &<../../../../shots/tricobalt_torpedo_shot/tricobalt_deck_stage1.rules>
	TargetLeadPrediction = false
	Recoil = 175
}

LaunchEffectBase
{
	Type = TriggeredEffects
	ChainedTo = Weapon
	Trigger = Weapon

	MediaEffects
	[
		&<../particles/tricobalt_torpedo_shot.rules>
		&<../particles/tricobalt_torpedo_flash.rules>

		: /BASE_SOUNDS/AudioExterior
		{
			Sound = "../../../../shots/tricobalt_torpedo_shot/tricobalt_torpedo_shot.wav"
			Speed = 0.25
			SpeedVariation = .1
		}
	]
}

MissileStorageBase
{
	Type = ResourceStorage
	ResourceType = tricobalt_torpedo_part
	MaxResources = 8
	ToggleOnResources = 8
	ToggleOffResources = 7
	DelayBeforeReadyToUse = .5
	UITileRect = [.5 + 7/64, 1 + 7/64, 1 - 14/64, 1 - 14/64]
	ReceiveResourceMediaEffects = &/COMMON_EFFECTS/MissileLoad
	DropResourcesWhenDestroyed = true
	DropResourcesWhenRemoved = true
}

MissileStats
{
	NameKey = "StatCategories/TricobaltTorpedoLauncher"
	Stats
	{
		DamagePerShot = &~/Components/Emitter/Bullet/Stage2/Components/Hit/HitOperational/HitEffects/0/TotalDamage
		DamagePerSecond = (&DamagePerShot) * (&ROF)
		Damage = [&../DamagePerShot, &../DamagePerSecond]
		DamageArea = &~/Components/Emitter/Bullet/Stage2/Components/Hit/HitOperational/HitEffects/0/Radius
		ROF = 1 / (&<../fed_torpedo_launcher.rules>/Part/Components/CommonReloadTimerLong/Duration)
		RangeLimited = [&~/Part/Components/Bullet/Range/BaseValue, &~/Part/Components/Bullet/Range/MaxValue]
		Arc = deg(&~/Components/Weapon/ValidArc)
		ShotLaunchSpeed = &~/EmitterBase/Bullet/Speed/BaseValue
		Acceleration = &~/Components/Emitter/Bullet/Stage2/Components/BoostAcceleration/Acceleration
		AccelerationDelay = &~/Components/Emitter/Bullet/Components/DeployDeath/Lifetime
		ShotHP = &~/Components/Emitter/Bullet/Components/Targetable/Health
		MissileParts = &~/Components/Emitter/ResourcesUsed
	}
}