				Size = [1, 2]
			}
			{
				File = "missile_1.png"
				NormalsFile = "missile_normals_1.png"
				Offset = [0, 0.5]
				Size = [1, 2]
			}
			{
				File = "missile_2.png"
				NormalsFile = "missile_normals_2.png"
				Offset = [0, 0.5]
				Size = [1, 2]
			}
			{
				File = "missile_2.png"
				NormalsFile = "missile_normals_2.png"
				Offset = [0, 0.5]
				Size = [1, 2]
			}
			{
				File = "missile_2.png"
				NormalsFile = "missile_normals_2.png"
				Offset = [0, 0.5]
				Size = [1, 2]
			}
			{
				File = "missile_3.png"
				NormalsFile = "missile_normals_3.png"
				Size = [1, 3]
			}
			{
				File = "missile_3.png"
				NormalsFile = "missile_normals_3.png"
