Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/Deflector_Dish_4x4_Sovereign"
	IconNameKey = "Parts/Deflector_Dish_4x4_SovereignIcon"
	ID = "stafa.fed_deflector_dish_4x4_sovereign"
	EditorParentParts = [ "stafa.fed_deflector_dish_external_2x2" ]
	DescriptionKey = "Parts/Deflector_Dish_4x4_SovereignDesc"
	Resources
	[
		[steel, 64]
		[coil2, 20]
		[tristeel, 22]
		[diamond, 4]
	]//to be actually checked, and based on performance
	Size = [4, 4]
	MaxHealth = 20000
	TypeCategories = [weapon, turret, uses_power]
	ReceivableBuffs : ^/0/ReceivableBuffs [DeflectorDebuff, DeflectorCounter, AntimatterPower]
	IsRotateable = true
	IsFlippable = true
	CrewSpeedFactor = .5
	CrewCongestedSpeedFactor = .5	
	SelectionPriority = 1
	InitialPenetrationResistance = 2
	PenetrationRectType = Normal
	AllowedDoorLocations
	[
		[-1, 1]
		[-1, 2]
		[1, 4]
		[2, 4]
		[4, 1]
		[4, 2]
		[1, -1]
		[2, -1]
	]
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [72, 72]
	}
	Components : ^/0/Components
	{
		Sensor
		{
			Type = Sensor
			OperationalToggle = IsOperational
			SightRadius = 1024//1280
			RadarRadius = 3040
		}
		IsOperational
		{
			Type = MultiToggle
			Toggles = [PowerToggle, BatteryStorage, PartCrew]
			Mode = All
		}
		
		PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = true
		}

		CommandConsumer
		{
			Type = CommandConsumer
			OperationalToggle = PowerToggle
			CommandPoints = 14
		}

		FireModeToggle
		{
			Type = UIToggle
			ToggleID = "fire_mode"
			Default = 1
			ToggledOnChoices = [0, 1, 2]
		}
		AutoTargetToggle
		{
			Type = ModeToggle
			Mode = FireModeToggle
			OnModes = [1, 2]
		}
		AutoFireToggle
		{
			Type = ModeToggle
			Mode = FireModeToggle
			OnMode = 2
		}
		
		DeflectorMode
		{
			Type = UIToggle
			ToggleID = "deflector_type"
			Default = 0
			AlwaysAllowInBuildMode = true
		}

		DeflectorShieldPulseToggle
		{
			Type = ModeToggle
			Mode = DeflectorMode
			OnMode = 0
		}

		DeflectorShieldPulse
		{
			Type = ToggledComponents
			Toggle = DeflectorShieldPulseToggle
			IncludeInBlueprints = true
			Components = &<fed_dd4x4_shield_drain.rules>/Components
		}

		DeflectorEnergyDrainToggle
		{
			Type = ModeToggle
			Mode = DeflectorMode
			OnMode = 1
		}

		DeflectorEnergyDrain
		{
			Type = ToggledComponents
			Toggle = DeflectorEnergyDrainToggle
			IncludeInBlueprints = true
			Components = &<fed_dd4x4_energy_drain.rules>/Components
		}

		DeflectorGravitonToggle
		{
			Type = ModeToggle
			Mode = DeflectorMode
			OnMode = 2
		}

		DeflectorGraviton
		{
			Type = ToggledComponents
			Toggle = DeflectorGravitonToggle
			IncludeInBlueprints = true
			Components = &<fed_dd4x4_graviton.rules>/Components
		}

		BatteryStorage
		{
			Type = ResourceStorage
			ResourceType = battery
			MaxResources = 72000
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		BatteryConsumer
		{
			Type = ResourceConsumer
			ResourceType = battery
			Storage = BatteryStorage
			DefaultPriority = &/PRIORITIES/Weapon_Supply
			ResupplyThreshold = 500
			OperationalToggle = PowerToggle
		}
		CloudyGasStorage
		{
			Type = ResourceStorage
			ResourceType = cloudy_gas
			MaxResources = 25
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		CloudyGasConsumer
		{
			Type = ResourceConsumer
			ResourceType = cloudy_gas
			Storage = CloudyGasStorage
			DefaultPriority = &/PRIORITIES/Weapon_Supply
			ResupplyThreshold = 1
			OperationalToggle = PowerToggle
		}
		ElectronGasStorage
		{
			Type = ResourceStorage
			ResourceType = electron_gas
			MaxResources = 12
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		ElectronGasConsumer
		{
			Type = ResourceConsumer
			ResourceType = electron_gas
			Storage = ElectronGasStorage
			DefaultPriority = &/PRIORITIES/Weapon_Supply
			ResupplyThreshold = 1
			OperationalToggle = PowerToggle
		}
		IonGasStorage
		{
			Type = ResourceStorage
			ResourceType = ion_gas
			MaxResources = 6
			ReceiveResourceMediaEffects = &/COMMON_EFFECTS/PowerDeliver
		}
		IonGasConsumer
		{
			Type = ResourceConsumer
			ResourceType = ion_gas
			Storage = IonGasStorage
			DefaultPriority = &/PRIORITIES/Weapon_Supply
			ResupplyThreshold = 1
			OperationalToggle = PowerToggle
		}
		InternalCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = BatteryStorage
			Invert = false
			LowColor = [170, 183, 0]
			HighColor = [238, 255, 0]
			FullColor = [238, 255, 0]
			Height = 4
		}
		InternalCloudyGasCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = CloudyGasStorage
			Invert = false
			LowColor = [115, 137, 155]
			HighColor = [187, 224, 255]
			FullColor = [187, 224, 255]
			Height = 5
		}
		InternalElectronGasCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = ElectronGasStorage
			Invert = false
			LowColor = [105, 147, 45]
			HighColor = [180, 155, 77]
			FullColor = [180, 155, 77]
			Height = 5
		}
		InternalIonGasCapacity
		{
			Type = ProgressBar
			OperationalToggle = IsOperational
			ShowProgressFor = IonGasStorage
			Invert = false
			LowColor = [199, 0, 0]
			HighColor = [255, 4, 0]
			FullColor = [255, 4, 0]
			Height = 5
		}
		DeflectorDebuffProvider
		{
			Type = GridBuffProvider
			BuffType = DeflectorDebuff
			GridDistance = 500
			AllowDiagonals = true
			BuffAmount = 1
		}
		DeflectorCounterBuff//not sure which I am going to use yet. I imagine it will be Counter
		{
			Type = GridBuffProvider
			BuffType = DeflectorCounter
			GridDistance = 500
			AllowDiagonals = true
			BuffAmount = 1
		}
		DeflectorCount
		{
			Type = BuffableValue
			Value = { BaseValue=1; BuffType=DeflectorCounter; BuffMode=Add; }
		}

		//Radiator Stuff - I do not know how this works, it just kinda does
		IsConnected
		{
			Type = MultiToggle
			Toggles = [Port_LeftU, Port_LeftD, Port_DownL, Port_DownR, Port_RightD, Port_RightU, Port_UpR, Port_UpL]
			Mode = Any
		}

		Port_LeftU
		{
			Type = NetworkPort
			Location = [0, 1]
			Direction = Left
			Types = [ thermal ]
			RouteSource = NetworkedHeatBuffer
			RouteEndpoint = NetworkedHeatBuffer
			BlueprintRouteSource = BlueprintNetworkNode
			BlueprintRouteEndpoint = BlueprintNetworkNode
			Overlay
			{
				OverlayIcon = "ThermalPort"
				RouteLine = "Thermal"
				DrawRouteHub = false
				ConnectedEdgeIcon = "ThermalDot"
				HighlightPartOnPrimaryConnection = true
    			PartHighlightColor = [255, 217, 0, 61]
			}
		}
		Port_LeftD : Port_LeftU
		{
			Location = [0, 2]
			Direction = Left
		}
		Port_DownL : Port_LeftU
		{
			Location = [1, 3]
			Direction = Down
		}
		Port_DownR : Port_LeftU
		{
			Location = [2, 3]
			Direction = Down
		}
		Port_RightD : Port_LeftU
		{
			Location = [3, 1]
			Direction = Right
		}
		Port_RightU : Port_LeftU
		{
			Location = [3, 2]
			Direction = Right
		}
		Port_UpR : Port_LeftU
		{
			Location = [2, 0]
			Direction = Up
		}
		Port_UpL : Port_LeftU
		{
			Location = [1, 0]
			Direction = Up
		}
		

		BlueprintNetworkNode
		{
			Type = NetworkBasicNode
			IncludeInBlueprints = true
		}

		Router
		{
			Type = NetworkRouter
			RouteGenerators
			[
				{
					Type = Bidirectional
					Routes
					[
						[NetworkedHeatBuffer, NetworkHeatOutput, 0]
						[NetworkedHeatBuffer, NetworkedThermalDissipationLoadValue, 0]
					]
				}
			]
		}

		HeatBuffer
		{
			Type = ResourceStorage
			ResourceType = heat
			MaxResources = (&../HeatDissipationConverter/Dissipation) * 2000
			//MaxResources = (&../DissipationScore/MAX_SCORE) * 2
			ProvidedValueRange = 0
			ProvidedValuePerResource = 1
			InitToMaxResources = 0
			IgnoreResourcesForInitToMax = true
		}

		NetworkedHeatBuffer
		{
			Type = NetworkResourceStore
			ResourceType = heat
			ResourceStorage = HeatBuffer
			Categories = [ thermal_storage ]
		}

		NetworkHeatOutput
		{
			Type = NetworkResourceOutput
			ResourceType = heat
			Mode = DistributeProportionallyByAvailable
			ProvidedValueRange = 0
			ProvidedValuePerResource = 1
			Categories = [ thermal_storage ]
		}
		//Heat Output
		HeatDissipationConverter 
		{
			Type = ResourceConverter
			OperationalToggle = IsOperational
			FromStorage = NetworkHeatOutput
			MinFromQuantityForConversion = 1
			Dissipation = 5184 //This number needs to be half what you want the MJ/sec output to be
			Dissipation_Per_Second = (&Dissipation) / (&Interval)
			FromQuantity = (&Dissipation) * (&<./Data/statuses/heat/heat.rules>/STATUS_TO_RESOURCE_RATIO)
			Interval = 0.5
		}

		SteamEffects
		{
			Type = ContinuousEffects
			Location = [2, 4.5]
			OperationalToggle = IsOperational
			//OperationalToggle = HeatDissipationConverter
			//FactorMediaEffectsIntensityWith = NetworkHeatOutput
			FactorMediaEffectsIntensityWith = NormalizedDissipationValueSmoothed
			MediaEffects
			[
				//&<particles/radiator_steam.rules>
				//&<./Data/ships/terran/radiator/particles/radiator_steam_distortion.rules>
				//&<./Data/ships/terran/radiator/particles/radiator_heat_base.rules>
				//&<./Data/ships/terran/radiator/particles/radiator_heat_scaling.rules>
				//&<../fed_deflector_dish_2x2/radiator_particles/radiator_heat_sparks.rules> //disabled gfx until it renders under the ship

				: /BASE_SOUNDS/AudioExterior
				{
					Sound = "./Data/ships/terran/radiator/sounds/radiator_venting.wav"
					RampUpTime = .2
					RampDownTime = .4

					DynamicVolume
					{
						MinDistance = 0
						MaxDistance = 10
						DistanceFalloff = 1.5

						MinZoom = 1
						MaxZoom = 50
						ZoomFalloff = 3
					}

					DynamicFilter
					{
						MinDistance = 0
						MaxDistance = 2
						DistanceFalloff = 1

						MinZoom = 1
						MaxZoom = 12
						ZoomFalloff = 2

						Filter
						{
							FilterType = LowPassAmplify
							FromFrequency = 7350
							ToFrequency = 250
							FrequencyFactorExponent = 0.25
						}
					}
				}
			]
		}

		//graphical
		Fraction { Type = StaticValue; Value = 0.9 }//thx armour heat sinks
		One { Type = StaticValue; Value = 1 }
		DissipationBuff
		{
			Type = SelfBuffProvider
			BuffType = HeatDissipation
			BuffAmount = 1
			BuffMultiplier = One
		}

		HeatDissipationConverter2
		{
			Type = ResourceConverter
			OperationalToggle = IsConnected
			FromStorage = NetworkHeatOutput
			MinFromQuantityForConversion = 1
			FromQuantity
			{
				BaseValue = 1
				BuffType = HeatDissipation
				BuffMode = Multiply
			}
			Interval = 0.5
		}

		NormalizedDissipationValue
		{
			Type = ValueOperation
			Operator = Divide
			ValueOne
			{
				ID = HeatDissipationConverter2
				ValueID = "LastConversion"
			}
			ValueTwo = Fraction
		}
		
		Zero { Type = StaticValue; Value = 0 }
		
		DissipationSmoothingTargetValue
		{
			Type = ToggleValueSelector
			Toggle = IsConnected
			ToggleOffValue = Zero
			ToggleOnValue = NormalizedDissipationValue
		}
		
		NormalizedDissipationValueSmoothed
		{
			Type = SmoothedValue
			ValueSource = DissipationSmoothingTargetValue
			MaxDelta = 0.25
			Deterministic = false
		}

		NetworkedThermalDissipationLoadValue
		{
			Type = NetworkValue
			ValueSource = NormalizedDissipationValueSmoothed
			Categories = [ thermal_load_dissipation ]
		}

		//Radiator Stuff End

		Graphics
		{
			Type = Graphics
			Location = [2, 2]
			OperationalToggle = IsOperational
			Floor
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [4, 4]
					}
					{
						File = "floor_33.png"
						Size = [4, 4]
					}
					{
						File = "floor_66.png"
						Size = [4, 4]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				Offset = [0, 0]
				DamageLevels
				[
					{
						File = "walls.png"
						Size = [4, 4]
					}
					{
						File = "walls_33.png"
						Size = [4, 4]
					}
					{
						File = "walls_66.png"
						Size = [4, 4]
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				Location = [2, 2]
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [4, 4]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [4, 4]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [4, 4]
					}
				]
			}
			OperationalDoodad
			{
				Layer = "doodads_low"
				//Offset = [0, 1.5]
				DamageLevels
				[
					{
						AnimationFiles
						[
							"floor_doodads_1.png"
							"floor_doodads_2.png"
							"floor_doodads_3.png"
							"floor_doodads_4.png"
							"floor_doodads_5.png"
							"floor_doodads_6.png"
						]
						Size = [4, 4]
						AnimationInterval = 0.12
						AnimationStartTime = Zero
					}
					{
						AnimationFiles
						[
							"floor_doodads_1.png"
							"floor_doodads_2.png"
							"floor_doodads_3.png"
							"floor_doodads_4.png"
							"floor_doodads_5.png"
							"floor_doodads_6.png"
						]
						Size = [4, 4]
						AnimationInterval = 0.12
						AnimationStartTime = Zero
					}
					{
						AnimationFiles
						[
							"floor_doodads_1.png"
							"floor_doodads_2.png"
							"floor_doodads_3.png"
							"floor_doodads_4.png"
							"floor_doodads_5.png"
							"floor_doodads_6.png"
						]
						Size = [4, 4]
						AnimationInterval = 0.12
						AnimationStartTime = Zero
					}
				]
			}
			NonOperationalDoodad
			{
				Layer = "doodads_low"
				DamageLevels
				[
					{
						File = "floor_doodads_off.png"
						Size = [4, 4]
					}
				]
			}
		}
		
		CrewLocation1
		{
			Type = CrewLocation
			Location = [.51, .51]
			Rotation = -45d
		}
		CrewLocation2
		{
			Type = CrewLocation
			Location = [3.49, .51]
			Rotation = 45d
		}
		CrewLocation3
		{
			Type = CrewLocation
			Location = [.51, 3.49]
			Rotation = -135d
		}
		CrewLocation4
		{
			Type = CrewLocation
			Location = [3.49, 3.49]
			Rotation = 135d
		}
		CrewLocation5
		{
			Type = CrewLocation
			Location = [1.35, 3.5]
			Rotation = 180d
		}
		CrewLocation6
		{
			Type = CrewLocation
			Location = [2.65, 3.5]
			Rotation = 180d
		}
		PartCrew
		{
			Type = PartCrew
			Crew = 6
			DefaultPriority = &/PRIORITIES/Weapon_Crew
			PrerequisitesBeforeCrewing = [PowerToggle]
			HighPriorityPrerequisites = [BatteryStorage]
			CrewDestinations
			[
				&../../CrewLocation1/Location
				&../../CrewLocation2/Location
				&../../CrewLocation3/Location
				&../../CrewLocation4/Location
				&../../CrewLocation5/Location
				&../../CrewLocation6/Location
			]
			CrewLocations
			[
				CrewLocation1
				CrewLocation2
				CrewLocation3
				CrewLocation4
				CrewLocation5
				CrewLocation6
			]
		}

		OperationEffects
		{
			Type = ToggleEffects
			Location = [2, 2]
			Toggle = IsOperational
			ToggledOnMediaEffects = &/COMMON_EFFECTS/PowerOn
			ToggledOffMediaEffects = &/COMMON_EFFECTS/PowerOff
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyed
			Location = [2, 2]
		}
		Indicators
		{
			Type = IndicatorSprites
			Location = [2, 2]
			Layer = "indicators"
			Indicators
			[
				// Turned off.
				{
					Toggle = PowerToggle
					AtlasSprite
					{
						File = &/INDICATORS/PowerOff
						Size = [1, 1]
					}
				}

				// Out of power.
				{
					Toggle = BatteryStorage
					//Delay = &~/Part/Components/Turret/FireInterval
					//Delay = 0.49
					AtlasSprite
					{
						File = &/INDICATORS/NoPower
						Size = [1, 1]
					}
				}
				
				// No crew.
				{
					Toggle = PartCrew
					ShowInBuildMode = true
					AtlasSprite
					{
						File = &/INDICATORS/NoCrew
						Size = [1, 1]
					}
				}
			]
		}
		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [4, 4]
		}
		//Heat Stat Providers
		HeatDissipationStatDenominator
		{
			Type = StaticValue
			Value = (&<./Data/statuses/heat/heat.rules>/STATUS_TO_RESOURCE_RATIO) * (&~/Part/Components/HeatDissipationConverter/Interval)
		}

		HeatDissipationStatValue
		{
			Type = StaticValue
			Value = (&~/Part/Components/HeatDissipationConverter/Dissipation_Per_Second)
		}

		HeatDissipationStatProvider
		{
			Type = StatProvider
			Stat = HeatDissipation
			ValueFrom = HeatDissipationStatValue
		}
	}
	Stats
	{
		CrewRequired = &~/Part/Components/PartCrew/Crew
		PowerCapacity = (&~/Part/Components/BatteryStorage/MaxResources) / 1000
		SightRange = &~/Part/Components/Sensor/SightRadius
		RadarRange = &~/Part/Components/Sensor/RadarRadius
		HeatCapacity = (&~/Part/Components/HeatBuffer/MaxResources) / (&<./Data/statuses/heat/heat.rules>/STATUS_TO_RESOURCE_RATIO)
		HeatDissipation = (&~/Part/Components/HeatDissipationConverter/FromQuantity) / (&~/Part/Components/HeatDissipationConverter/Interval) / (&<./Data/statuses/heat/heat.rules>/STATUS_TO_RESOURCE_RATIO)
	}
}

