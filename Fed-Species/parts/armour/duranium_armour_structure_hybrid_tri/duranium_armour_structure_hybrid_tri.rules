Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/DuraniumArmourStructureHybridTri"
	IconNameKey = "Parts/DuraniumArmourStructureHybridTriIcon"
	ID = stafa.duranium_armour_structure_hybrid_tri // Part IDs must always be in the form of "author_name.part_name". If making your own mod, do *not* use "cosmoteer" as your author name, because it may conflict with future vanilla parts.
	//EditorGroups = ["StarfleetDefences"]
	EditorParentParts = [ "stafa.duranium_armour" ]
	DescriptionKey = "Parts/DuraniumArmourStructureHybridTriDesc"
	Resources
	[
		[tristeel, 3]
	]
	AIValueFactor = 0
	Size = [1, 1]
	SelectionTypeID = "durarmour"
	MaxHealth = 2000
	ExplosiveDamageAbsorption = 100%
	DamageResistances
	{
		explosive = 65%
		thermal = -5%
	}
	TypeCategories = [durarmour, non_flammable]
	ReceivableBuffs : ^/0/ReceivableBuffs []
	CreatePartPerTileWhenGrabbed = ""
	InitialPenetrationResistance = 4
	ContinuingPenetrationResistance = &InitialPenetrationResistance
	CrewSpeedFactor = 0
	Density = 6
	IsRotateable = true
	IsWalled = true
	IsSelfDestructible = false
	ExternalWalls = [BottomRight, Bottom, BottomLeft]
	InternalWalls = [Left, TopLeft, Top, TopRight, Right]
	VirtualInternalCells
	[
		{ExternalCell=[-1, 0]; InternalCell=[0, 1]}
		{ExternalCell=[1, 0]; InternalCell=[0, 1]}
	]
	AllowedDoorLocations = []
	GeneratorRequiresDoor = false
	GenerateRectCollider = false
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [32, 32]
	}
	Components : ^/0/Components
	{
		Collider
		{
			Type = PolygonCollider
			Vertices
			[
				[.5, .5]
				[1, 1]
				[0, 1]
			]
		}

		EmpAbsorber
		{
			Type = ExplosiveResourceDrainSink
			ResourceType = battery
			AbsorbsResourceDrain = 500
			RecoveryRate = (&AbsorbsResourceDrain) * 0.1
		}

		Graphics
		{
			Type = Graphics
			Location = [0.5, 0.5]
			Floor // This is needed so that armour shows up in ship ghosts.
			{
				Layer = "structure"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "floor_33.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "floor_66.png"
						Size = [1, 1]
						UVRotation = 0
					}
				]
			}
			Walls
			{
				Layer = "external_walls"
				DamageLevels
				[
					{
						File = "../duranium_armour_tri/armour.png"
						NormalsFile = "external_wall_normals.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "armour_33.png"
						NormalsFile = "external_wall_normals_33.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "armour_66.png"
						NormalsFile = "external_wall_normals_66.png"
						Size = [1, 1]
						UVRotation = 0
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "../duranium_armour_tri/roof.png"
						NormalsFile = "../duranium_armour_tri/roof_normals.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "../duranium_armour_tri/roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "../duranium_armour_tri/roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [1, 1]
						UVRotation = 0
					}
				]
			}
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyedDry
			Location = [.5, .5]
		}

		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [1, 1]
		}
	}

	Stats
	{
		EMPResist = (&~/Part/Components/EmpAbsorber/AbsorbsResourceDrain) / 1000
		AOEResist = (&~/Part/DamageResistances/explosive) * 100
	}
}