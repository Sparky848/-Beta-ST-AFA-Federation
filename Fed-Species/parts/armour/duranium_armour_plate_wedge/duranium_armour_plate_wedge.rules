Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/DuraniumArmourPlateWedge"
	IconNameKey = "Parts/DuraniumArmourPlateWedgeIcon"
	ID = stafa.duranium_armour_plate_wedge	 // Part IDs must always be in the form of "author_name.part_name". If making your own mod, do *not* use "cosmoteer" as your author name, because it may conflict with future vanilla parts.
	//EditorGroup = "StarfleetDefences"
	EditorParentParts = [ "stafa.duranium_armour" ]
	DescriptionKey = "Parts/DuraniumArmourPlateWedgeDesc"
	Resources
	[
		[tristeel, 1]
	]
	AIValueFactor = 0
	Size = [1, 1]
	SelectionPriority = 0	
	SelectionTypeID = "durarmourplate"
	MaxHealth = 1000
	ExplosiveDamageAbsorption = 125%
	DamageResistances
	{
		default = { BaseValue=0%; BuffType=HullPolariser; BuffMode=Add; MaxValue=30%; }
		explosive = 65%
		thermal = 10%
	}
	InitialPenetrationResistance = 7
	ContinuingPenetrationResistance = &InitialPenetrationResistance
	CreatePartPerTileWhenGrabbed = ""
	CrewSpeedFactor = 0
	Density = 6
	ContiguityOriginPriority = 1
	TypeCategories = [durarmourplate, durarmour, non_flammable, armour]
	Flammable = false
	ReceivableBuffs : ^/0/ReceivableBuffs [HullPolariser]
	CreateUnderlyingWhenDestroyed = false
	IsExternal = true
	ExternalWalls = []
	InternalWalls = [Left, TopLeft, TopRight, Right, Top, BottomLeft, Bottom]
	AllowedContiguity = [Right, Bottom]
	FlipHRotate = [1, 0, 3, 2]
	FlipVRotate = [3, 2, 1, 0]
	IsWalled = true
	IsSelfDestructible = false
	GeneratorRequiresDoor = false
	GenerateRectCollider = false
	AllowedDoorLocations = []
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear	
		}
		Size = [32, 32]
	}
	Components : ^/0/Components
	{
		Collider
		{
			Type = PolygonCollider
			Vertices
			[
				[1, .78125]
				[1, 1]
				[.78125, 1]
			]
		}

		EmpAbsorber
		{
			Type = ExplosiveResourceDrainSink
			ResourceType = battery
			AbsorbsResourceDrain = 500
			RecoveryRate = (&AbsorbsResourceDrain) * 0.1
		}

		Graphics
		{
			Type = Graphics
			Location = [0.5, 0.5]
			Floor // This is needed so that armour shows up in ship ghosts.
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [1, 1]
					}
					{
						File = "floor_33.png"
						Size = [1, 1]
					}
					{
						File = "floor_66.png"
						Size = [1, 1]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				DamageLevels
				[
					{
						File = "armour.png"
						Size = [1, 1]
					}
					{
						File = "armour_33.png"
						Size = [1, 1]
					}
					{
						File = "armour_66.png"
						Size = [1, 1]
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [1, 1]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [1, 1]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [1, 1]
					}
				]
			}
		}
		
		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyedDry
			Location = [.5, .5]
		}
		SalvagedEffects
		{
			Type = DeathEffects
			WhenSalvaged = true

			MediaEffects
			[
				: /BASE_SOUNDS/AudioExteriorDetail
				{
					Sound = "./data/ships/common/sounds/salvage_finish.wav"
					Volume = 0.75
					SpeedVariation = .25
				}
			]
		}
		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [1, 1]
		}
	}


	Stats
	{
		EMPResist = (&~/Part/Components/EmpAbsorber/AbsorbsResourceDrain) / 1000
		AOEResist = (&~/Part/DamageResistances/explosive) * 100
	}
}