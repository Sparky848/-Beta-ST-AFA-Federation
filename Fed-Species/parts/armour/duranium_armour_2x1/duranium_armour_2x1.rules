Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/DuraniumArmour2x1"
	IconNameKey = "Parts/DuraniumArmour2x1Icon"
	ID = stafa.duranium_armour_2x1 // Part IDs must always be in the form of "author_name.part_name". If making your own mod, do *not* use "cosmoteer" as your author name, because it may conflict with future vanilla parts.
	OtherIDs = [durarmour2]
	EditorParentParts = [ "stafa.duranium_armour" ]
	//EditorGroup = "StarfleetDefences"
	EditorReplacementPartID = durarmour
	DescriptionKey = "Parts/DuraniumArmour2x1Desc"
	Resources
	[
		[tristeel, 16]
	]
	AIValueFactor = 0
	Size = [2, 1]
	FlipHRotate = [0, 1, 2, 3] // Disable flipping UI.
	FlipVRotate = [0, 1, 2, 3] // Disable flipping UI.
	SelectionTypeID = "durarmour"
	MaxHealth = 16000
	ExplosiveDamageAbsorption = 100%
	DamageResistances
	{
		default = { BaseValue=0%; BuffType=HullPolariser; BuffMode=Add; MaxValue=30%; }
		explosive = 65%
		thermal = -5%
	}
	TypeCategories = [durarmour, non_flammable, armour]
	Flammable = false
	InitialPenetrationResistance = 14
	ContinuingPenetrationResistance = &InitialPenetrationResistance
	CreatePartPerTileWhenGrabbed = ""
	CrewSpeedFactor = 0
	Density = 6
	IsRotateable = true
	IsWalled = true
	IsSelfDestructible = false
	AllowedDoorLocations = []
	GeneratorRequiresDoor = false
	IgnoreRotationForMirroredSelection = true
	ReceivableBuffs : ^/0/ReceivableBuffs [HullPolariser]
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [64, 32]
	}
	Components : ^/0/Components
	{
		EmpAbsorber
		{
			Type = ExplosiveResourceDrainSink
			ResourceType = battery
			AbsorbsResourceDrain = 4000
			RecoveryRate = (&AbsorbsResourceDrain) * 0.1
		}

		Graphics
		{
			Type = Graphics
			Location = [1, 0.5]
			Floor // This is needed so that armour shows up in ship ghosts.
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "armour.png"
						Size = [2, 1]
					}
					{
						File = "armour_33.png"
						Size = [2, 1]
					}
					{
						File = "armour_66.png"
						Size = [2, 1]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				DamageLevels
				[
					{
						File = "armour.png"
						Size = [2, 1]
					}
					{
						File = "armour_33.png"
						Size = [2, 1]
					}
					{
						File = "armour_66.png"
						Size = [2, 1]
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [2, 1]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [2, 1]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [2, 1]
					}
				]
			}
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyedDry
			Location = [1, .5]
		}

		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [2, 1]
		}
	}

	Stats
	{
		EMPResist = (&~/Part/Components/EmpAbsorber/AbsorbsResourceDrain) / 1000
		AOEResist = (&~/Part/DamageResistances/explosive) * 100
	}
}