Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/DuraniumArmour3x3BCCowling"
	IconNameKey = "Parts/DuraniumArmour3x3BCCowlingIcon"
	ID = stafa.duranium_armour_3x3_bc_cowling // Part IDs must always be in the form of "author_name.part_name". If making your own mod, do *not* use "cosmoteer" as your author name, because it may conflict with future vanilla parts.
//	EditorGroup = "StarfleetDefences"
	EditorParentParts = [ "stafa.duranium_armour" ]
	DescriptionKey = "Parts/DuraniumArmour3x3BCCowlingDesc"
	EditorReplacementPartID = ""
	Resources
	[
		[tristeel, 1]
	]
	AIValueFactor = 0
	Size = [1, 1]
	IsFlippable = true
	AllowedContiguity = [Right, Bottom]
	SelectionTypeID = "durarmour"
	MaxHealth = 2000
	ExplosiveDamageAbsorption = 100%
	DamageResistances
	{
		explosive = 65%
		thermal = -5%
	}
	TypeCategories = [durarmour, non_flammable]
	ReceivableBuffs : ^/0/ReceivableBuffs []
	UnderlyingPartPerTile = ""
	CreatePartPerTileWhenGrabbed = ""
	InitialPenetrationResistance = 6
	ContinuingPenetrationResistance = &InitialPenetrationResistance
	CrewSpeedFactor = 0
	Density = 6
	IsRotateable = true
	IsWalled = true
	IsSelfDestructible = false
	ExternalWalls = []
	InternalWalls = [Left, TopLeft, TopRight, Right, Top, BottomLeft, Bottom]
	AllowedDoorLocations = []
	GeneratorRequiresDoor = false
	GenerateRectCollider = false
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [32, 32]
	}
	Components : ^/0/Components
	{
		Collider
		{
			Type = PolygonCollider
			Vertices
			[
				[0.78125, 1]
				[1, 1]
				[1, 0.375]
			]
		}

		EmpAbsorber
		{
			Type = ExplosiveResourceDrainSink
			ResourceType = battery
			AbsorbsResourceDrain = 1750
			RecoveryRate = (&AbsorbsResourceDrain) * 0.1
		}

		Graphics
		{
			Type = Graphics
			Location = [0.5 , 0.5]
			Floor // This is needed so that armour shows up in ship ghosts.
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [1, 1]
					}
					{
						File = "floor_33.png"
						Size = [1, 1]
					}
					{
						File = "floor_66.png"
						Size = [1, 1]
					}
				]
			}
			Walls
			{
				Layer = "external_walls"
				DamageLevels
				[
					{
						File = "armour.png"
						NormalsFile = "external_wall_normals.png"
						Size = [1, 1]
					}
					{
						File = "armour_33.png"
						NormalsFile = "external_wall_normals_33.png"
						Size = [1, 1]
					}
					{
						File = "armour_66.png"
						NormalsFile = "external_wall_normals_66.png"
						Size = [1, 1]
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [1, 1]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [1, 1]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [1, 1]
					}
				]
			}
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyedDry
			Location = [.5, .5]
		}

		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [1, 1]
		}

		SalvagedEffects
		{
			Type = DeathEffects
			WhenSalvaged = true

			MediaEffects
			[
				: /BASE_SOUNDS/AudioExteriorDetail
				{
					Sound = "./data/ships/common/sounds/salvage_finish.wav"
					Volume = 0.75
					SpeedVariation = .25
				}
			]
		}
	}

	Stats
	{
		EMPResist = (&~/Part/Components/EmpAbsorber/AbsorbsResourceDrain) / 1000
		AOEResist = (&~/Part/DamageResistances/explosive) * 100
	}
}