Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/DuraniumArmour"
	IconNameKey = "Parts/DuraniumArmourIcon"
	ID = stafa.duranium_armour // Part IDs must always be in the form of "author_name.part_name". If making your own mod, do *not* use "cosmoteer" as your author name, because it may conflict with future vanilla parts.
	OtherIDs = [durarmour]
	EditorGroup = "StarfleetDefences"
	//EditorReplacementPartID = durarmour
	DescriptionKey = "Parts/DuraniumArmourDesc"
	Resources
	[
		[tristeel, 8]
	]
	AIValueFactor = 0
	Size = [1, 1]
	SelectionTypeID = "durarmour"
	MaxHealth = 8000
	ExplosiveDamageAbsorption = 100%
	DamageResistances
	{
		default = { BaseValue=0%; BuffType=HullPolariser; BuffMode=Add; MaxValue=30%; }
		explosive = 65%
		thermal = -5%
	}
	//UnderlyingPartPerTile = cosmoteer.corridor
	TypeCategories = [durarmour, non_flammable, armour]
	Flammable = false
	InitialPenetrationResistance = 8
	ContinuingPenetrationResistance = &InitialPenetrationResistance
	CreatePartPerTileWhenGrabbed = ""
	CrewSpeedFactor = 0
	Density = 6
	IsRotateable = true
	IsWalled = true
	IsSelfDestructible = false
	AllowedDoorLocations = []
	GeneratorRequiresDoor = false
	IgnoreRotationForMirroredSelection = true
	ReceivableBuffs : ^/0/ReceivableBuffs [HullPolariser]
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [32, 32]
	}
	Components : ^/0/Components
	{
		EmpAbsorber
		{
			Type = ExplosiveResourceDrainSink
			ResourceType = battery
			AbsorbsResourceDrain = 2000
			RecoveryRate = (&AbsorbsResourceDrain) * 0.1
		}
		/*PowerToggle
		{
			Type = UIToggle
			ToggleID = "on_off"
			Default = 1
			RequiresCommand = false
		}*/

		Graphics
		{
			Type = Graphics
			Location = [0.5, 0.5]
			Floor // This is needed so that armour shows up in ship ghosts.
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "armour.png"
						Size = [1, 1]
					}
					{
						File = "armour_33.png"
						Size = [1, 1]
					}
					{
						File = "armour_66.png"
						Size = [1, 1]
					}
				]
			}
			Walls
			{
				Layer = "walls"
				DamageLevels
				[
					{
						File = "armour.png"
						Size = [1, 1]
					}
					{
						File = "armour_33.png"
						Size = [1, 1]
					}
					{
						File = "armour_66.png"
						Size = [1, 1]
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [1, 1]
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [1, 1]
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [1, 1]
					}
				]
			}
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyedDry
			Location = [.5, .5]
		}

		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [1, 1]
		}
	}

	Stats
	{
		EMPResist = (&~/Part/Components/EmpAbsorber/AbsorbsResourceDrain) / 1000
		AOEResist = (&~/Part/DamageResistances/explosive) * 100
	}
}