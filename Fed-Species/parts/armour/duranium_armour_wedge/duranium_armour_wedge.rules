Part : <./Data/ships/terran/base_part_terran.rules>/Part
{
	NameKey = "Parts/DuraniumArmourWedge"
	IconNameKey = "Parts/DuraniumArmourWedgeIcon"
	ID = stafa.duranium_armour_wedge // Part IDs must always be in the form of "author_name.part_name". If making your own mod, do *not* use "cosmoteer" as your author name, because it may conflict with future vanilla parts.
	OtherIDs = [durarmour_wedge]
	//EditorGroup = "StarfleetDefences"
	EditorParentParts = [ "stafa.duranium_armour" ]
	DescriptionKey = "Parts/DuraniumArmourWedgeDesc"
	Resources
	[
		[tristeel, 4]
	]
	AIValueFactor = 0
	Size = [1, 1]
	AllowedContiguity = [Right, Bottom]
	SelectionTypeID = "durarmour"
	MaxHealth = 4000
	ExplosiveDamageAbsorption = 100%
	DamageResistances
	{
		default = { BaseValue=0%; BuffType=HullPolariser; BuffMode=Add; MaxValue=30%; }
		explosive = 65%
		thermal = -5%
	}
	TypeCategories = [durarmour, non_flammable, armour]
	ReceivableBuffs : ^/0/ReceivableBuffs [HullPolariser]
	UnderlyingPartPerTile = ""
	UnderlyingPart = cosmoteer.structure_wedge
	CreatePartPerTileWhenGrabbed = ""
	InitialPenetrationResistance = 6
	ContinuingPenetrationResistance = &InitialPenetrationResistance
	CrewSpeedFactor = 0
	Density = 6
	IsRotateable = true
	IsWalled = true
	IsSelfDestructible = false
	ExternalWalls = [TopRight, Right, BottomRight, Bottom, BottomLeft]
	InternalWalls = [Left, TopLeft, Top]
	VirtualInternalCells
	[
		{ExternalCell=[0, -1]; InternalCell=[1, 0]}
		{ExternalCell=[-1, 0]; InternalCell=[0, 1]}
	]
	AllowedDoorLocations = []
	GeneratorRequiresDoor = false
	FlipHRotate = [1, 0, 3, 2]
	FlipVRotate = [3, 2, 1, 0]
	GenerateRectCollider = false
	EditorIcon
	{
		Texture
		{
			File = "icon.png"
			SampleMode = Linear
		}
		Size = [32, 32]
	}
	Components : ^/0/Components
	{
		Collider
		{
			Type = PolygonCollider
			Vertices
			[
				[1, 0]
				[1, 1]
				[0, 1]
			]
		}

		EmpAbsorber
		{
			Type = ExplosiveResourceDrainSink
			ResourceType = battery
			AbsorbsResourceDrain = 1000
			RecoveryRate = (&AbsorbsResourceDrain) * 0.1
		}

		Graphics
		{
			Type = Graphics
			Location = [0.5, 0.5]
			Floor // This is needed so that armour shows up in ship ghosts.
			{
				Layer = "floors"
				DamageLevels
				[
					{
						File = "floor.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "floor_33.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "floor_66.png"
						Size = [1, 1]
						UVRotation = 0
					}
				]
			}
			Walls
			{
				Layer = "external_walls"
				DamageLevels
				[
					{
						File = "armour.png"
						NormalsFile = "external_wall_normals.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "armour_33.png"
						NormalsFile = "external_wall_normals_33.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "armour_66.png"
						NormalsFile = "external_wall_normals_66.png"
						Size = [1, 1]
						UVRotation = 0
					}
				]
			}
			Roof
			{
				Layer = "roofs"
				DamageLevels
				[
					{
						File = "roof.png"
						NormalsFile = "roof_normals.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "roof_33.png"
						NormalsFile = "roof_normals_33.png"
						Size = [1, 1]
						UVRotation = 0
					}
					{
						File = "roof_66.png"
						NormalsFile = "roof_normals_66.png"
						Size = [1, 1]
						UVRotation = 0
					}
				]
			}
		}

		DestroyedEffects
		{
			Type = DeathEffects
			MediaEffects = &/COMMON_EFFECTS/SmallPartDestroyedDry
			Location = [.5, .5]
		}

		Blueprints
		{
			Type = BlueprintSprite
			File = "blueprints.png"
			Size = [1, 1]
		}

		ConstructionStructureSprite
		{
			Type = Sprite
			IncludeWhenUnderConstruction = true
			IncludeWhenNotUnderConstruction = false
			Layer = "structure"
			Location = [.5, .5]
			AtlasSprite = &<./Data/ships/terran/structure_wedge/structure_wedge.rules>/Part/Components/Graphics/Floor/DamageLevels/0
		}
	}

	Stats
	{
		EMPResist = (&~/Part/Components/EmpAbsorber/AbsorbsResourceDrain) / 1000
		AOEResist = (&~/Part/DamageResistances/explosive) * 100
	}
}