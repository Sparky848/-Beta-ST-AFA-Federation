	// Weapons
	Phaser_Pointdefense = "Small Phaser Array"
	Phaser_Pointdefense_Icon = "Small Phaser Array"
	Phaser_Pointdefense_Desc = "A small phaser beam weapon with numerous emitters that allows it to fire in a wide arc. Its primary use is as point defense systems against incoming missiles."
	Dual_Phaser_Cannon = "Dual Impulse Phaser Cannons"
	Dual_Phaser_Cannon_Icon = "Dual Impulse Phaser Cannons"
	Dual_Phaser_Cannon_Desc = "Dual Impulse Phaser Cannons use a rapid succession of phaser pulses instead of a continuous phaser beam."
	Torpedolauncher = "Burst Torpedo Launcher"
	Torpedolauncher_Icon = "Burst Torpedo Launcher"
	Torpedolauncher_Desc = "Launches different torpedo types in a burst that is capable of dealing devastating damage to an enemy."
	TorpedolauncherDeck = "Deck Burst Torpedo Launcher"
	TorpedolauncherDeck_Icon = "Deck Burst Torpedo Launcher"
	TorpedolauncherDeck_Desc = "Launches different torpedo types in a burst that is capable of dealing devastating damage to an enemy."
	Phaser_Cannon_Deck = "Impulse Phaser Cannons"
	Phaser_Cannon_Deck_Icon = "Impulse Phaser Cannons"
	Phaser_Cannon_Deck_Desc = "Impulse Phaser Cannons use a rapid succession of phaser pulses instead of a continuous phaser beam. This is the deck version, which fires only single volleys."\
							  "\n<s20><red>Cannot be placed within 2 tiles of other 'tall' parts</red></s20>"
	Phaser_Bank_Controller = "Phaser Bank Controller"
    Phaser_Bank_Controller_Icon = "Phaser Bank Controller"
    Phaser_Bank_Controller_Desc = "Phaser Bank Control room, which will control adjacent Phaserbanks."\
								"\n<s20><red>Must be placed in parallel/with the 2 long side of the controller touching the phaserbank.</red></s20>\n"
    Phaser_Bank = "Standard Phaser Bank"
    Phaser_Bank_Icon = "Standard Phaser Bank"
    Phaser_Bank_Desc = "The Standard Phaser Bank is a beam weapon with numerous emitters that allows it to fire in a selectable 180°-45° arc.\n"\
						"<cyan>Each phaser bank needs a horizontally connected control room to work.</cyan>\n\n"\
					    "<s20><red>Due to the strain impacted on ship systems having greater than 30 phaserbanks (excl. point defence) will significantly reduce performance</red></s20>"
    Phaser_Bank_Modular = "Phaser Bank"
    Phaser_Bank_Modular_Icon = "Phaser Bank"
    Phaser_Bank_Modular_Desc = "Phaser Bank beam weapon with numerous emitters that allows it to fire in a 180°-45° arc. IN DEVELOPMENT"
	Burst_Phaser_Bank_PD = "Burst PD Phaser Bank"
	Burst_Phaser_Bank_PD_Icon = "Burst PD Phaser Bank"
	Burst_Phaser_Bank_PD_Desc = "Burst PD Phaser Bank for eliminating fast moving projectiles such as HE.\n"\
								"<cyan>Each phaser bank needs a horizontally connected control room to work.</cyan>\n\n"
								//"<red><s18>Indicators currently broken for this part</s18></red>"
	Burst_Phaser_Bank_COM = "Multi-Emitter Combat Phaser Bank"
	Burst_Phaser_Bank_COM_Icon = "Multi-Emitter Combat Phaser Bank"
	Burst_Phaser_Bank_COM_Desc = "Multi-Emitter Phaser Bank adapted for combat, Fires multiple untargetable beams.\n"\
								"<cyan>Each phaser bank needs a horizontally connected control room to work.</cyan>\n\n"\
								 "<s20><red>Due to the strain impacted on ship systems having greater than 30 phaserbanks (excl. point defence) will significantly reduce performance</red></s20>"

	Tiny_Phaser_Bank_1x1 = "Shuttle Phaser Emitter"
	Tiny_Phaser_Bank_1x1_Icon = "Shuttle Phaser Emitter"
	Tiny_Phaser_Bank_1x1_Desc = "Phaser emitter designed solely for the emergency defence of small craft\n"\
								"<red><s18>Due to complex power requirements it is unable to be placed within 10 tiles of another phaser</s18></red>\n"
	Tiny_Phaser_Bank_2x1 = "Shuttle Phaser Emitter 2x1"
	Tiny_Phaser_Bank_2x1_Icon = "Shuttle Phaser Emitter 2x1"
	Tiny_Phaser_Bank_2x1_Desc = "Phaser emitter designed solely for the emergency defence of small craft, functionally identical to the 1x1 variant\n"\
								"<red><s18>Due to complex power requirements it is unable to be placed within 10 tiles of another phaser</s18></red>\n"
